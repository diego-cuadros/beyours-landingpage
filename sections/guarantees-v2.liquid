{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --guarantees-v2-image-radius: {{ section.settings.content_image_radius }}px;
    --guarantees-v2-image-height: {{ section.settings.content_image_height }}px;
    --guarantees-v2-image-background: {{ section.settings.content_image_background_color | default: '#ffffff' }};
    --guarantees-v2-subheading-font-size: {{ section.settings.subheading_font_size | default: 20 }}px;
    --guarantees-v2-subheading-color: {{ section.settings.subheading_color | default: '#6b7280' }};
    {%- if section.settings.use_custom_colors %}
      --color-icon: {{ section.settings.colors_icon.red }}, {{ section.settings.colors_icon.green }}, {{ section.settings.colors_icon.blue }};
      --gradient-background: {% if section.settings.gradient_background != blank %}{{ section.settings.gradient_background }}{% else %}{{ section.settings.colors_background }}{% endif %};
      --color-background: {{ section.settings.colors_background.red }}, {{ section.settings.colors_background.green }}, {{ section.settings.colors_background.blue }};
      --color-foreground: {{ section.settings.colors_text.red }}, {{ section.settings.colors_text.green }}, {{ section.settings.colors_text.blue }};
      --color-heading: var(--color-foreground);
      --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
    {% endif -%}
  }
{%- endstyle -%}

{{ 'section-guarantees.css' | asset_url | stylesheet_tag }}
{{ 'section-guarantees-v2.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">

{%- liquid
  assign custom_class = ''
  if section.settings.use_custom_colors
    if section.settings.colors_background != settings.colors_background
      assign custom_class = custom_class | append: ' guarantees--colored'
    endif

    if section.settings.colors_icon != section.settings.colors_background
      assign custom_class = custom_class | append: ' guarantees-icon--colored'
    endif
  endif

  if section.settings.horizontal_content
    assign custom_class = custom_class | append: ' guarantees--horizontal'
  endif

  if section.settings.content_image_height > 0
    assign custom_class = custom_class | append: ' guarantees--v2-fixed-image-height'
  endif
-%}

{%- if section.settings.show_divider %}<div class="section--divider">{% endif -%}
  <div class="page-width{% if section.settings.full_width %} page-width--full-width{% endif %}">
    <div class="guarantees guarantees--v2 section--padding{{ custom_class }}">
      {%- if section.settings.heading != blank and section.settings.layout == 'default' -%}
        <div class="title-wrapper{% if section.settings.heading == blank %} title-wrapper--no-heading{% endif %} {{ section.settings.column_alignment }}">
          <{{ section.settings.heading_tag }} class="title {{ section.settings.heading_size }}">
            {%- render 'highlight-text', 
              hl_input: section.settings.heading, 
              hl_style: section.settings.highlight_style,
              hl_enable: section.settings.enable_highlight,
              hl_animateWrap: true -%}
          </{{ section.settings.heading_tag }}>
          {%- if section.settings.subheading != blank -%}
            <{{ section.settings.subheading_tag }} class="guarantees__subheading {{ section.settings.subheading_size }}">
              {{ section.settings.subheading }}
            </{{ section.settings.subheading_tag }}>
          {%- endif -%}
        </div>
      {%- endif -%}
      
      <div class="flex-grid flex-grid--2-col-mobile">
        {%- if section.settings.heading != blank and section.settings.layout == 'sidebar' -%}
          <div class="flex-grid__item flex-grid__item--one-quarter">
            <div class="guarantees__title-wrap">
              <{{ section.settings.heading_tag }} class="guarantees__title {{ section.settings.heading_size }}">
                {%- render 'highlight-text', 
                  hl_input: section.settings.heading, 
                  hl_style: section.settings.highlight_style,
                  hl_enable: section.settings.enable_highlight,
                  hl_animateWrap: true -%}
              </{{ section.settings.heading_tag }}>
              {%- if section.settings.subheading != blank -%}
                <{{ section.settings.subheading_tag }} class="guarantees__subheading {{ section.settings.subheading_size }}">
                  {{ section.settings.subheading }}
                </{{ section.settings.subheading_tag }}>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <slider-component class="slider-mobile-gutter flex-grid__item{% if section.settings.heading == blank or section.settings.layout == 'default' %} flex-grid__item--full-width{% else %} flex-grid__item--three-quarter{% endif %}">
            <ul id="Guarantees-{{ section.id }}"
              class="flex-grid flex-grid--2-col{% if section.settings.columns_mobile == '1' %} flex-grid--1-col-mobile{% endif %}{% if section.settings.heading == blank or section.settings.layout == 'default' %}{% if section.blocks.size == 4 %} flex-grid--2-col-tablet{% else %} flex-grid--3-col-tablet{% endif %} flex-grid--rigid flex-grid--{{ section.settings.columns_desktop }}-col-desktop{% else %} flex-grid--2-col-tablet{% endif %}{% if section.settings.swipe_on_mobile %} slider slider--tablet{% endif %}"
              role="list"
              tabindex="0"
              aria-label="{{ 'accessibility.guarantees_list_scrollable' | t }}"
            >
              {%- for block in section.blocks -%}
                <li id="Slide-{{ section.id }}-{{ forloop.index }}"
                  class="flex-grid__item{% if section.settings.swipe_on_mobile %} slider__slide{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  <use-animate data-animate="zoom-fade" class="guarantee__item {{ section.settings.column_alignment }} guarantee-icon--{{ block.settings.icon_size }}{% if block.settings.image != blank %} guarantee__item--has-content-image{% endif %}">
                    {%- if block.settings.image != blank -%}
                      <div class="image-animate guarantee__media media-wrapper">
                        <div class="media media--{{ section.settings.content_image_ratio }}"{% if section.settings.content_image_ratio == 'adapt' %} style="--image-ratio-percent: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;"{% endif %}>
                          {{
                            block.settings.image
                            | image_url: width: 1600
                            | image_tag:
                              loading: 'lazy',
                              widths: '320, 480, 640, 800, 1000, 1200, 1600',
                              sizes: '(min-width: 1200px) 22vw, (min-width: 750px) 40vw, 92vw',
                              class: 'image-fit',
                              alt: block.settings.image.alt,
                              is: 'lazy-image'
                          }}
                        </div>
                      </div>
                    {%- elsif block.settings.custom_icon != blank -%}
                      <span class="image-animate guarantee__icon">
                        {{ block.settings.custom_icon }}
                      </span>
                    {%- elsif block.settings.icon != 'none' -%}
                      <span class="image-animate guarantee__icon">
                        {% render 'icon-guarantee', icon: block.settings.icon %}
                      </span>
                    {%- endif -%}
                    <div>
                      <p class="{{ block.settings.title_size }}">
                        {%- render 'highlight-text', 
                          hl_input: block.settings.title, 
                          hl_style: block.settings.highlight_style,
                          hl_enable: block.settings.enable_highlight,
                          hl_animateWrap: true -%}
                      </p>
                      <div class="rte typeset">
                        {%- render 'highlight-text', 
                          hl_input: block.settings.text, 
                          hl_style: block.settings.highlight_style,
                          hl_enable: block.settings.enable_highlight,
                          hl_animateWrap: true -%}
                      </div>
                    </div>
                  </use-animate>
                </li>
              {%- endfor -%}
            </ul>
          </slider-component>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- if section.settings.show_divider %}</div>{% endif -%}

