{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --image-with-text-v3-heading-text-gap: {{ section.settings.heading_text_gap }}px;
    --image-with-text-v3-hanging-quote-size: 5rem;
    --image-with-text-v3-hanging-quote-offset: clamp(1.4rem, 2vw, 2.4rem);
    --image-with-text-v3-hanging-quote-color: {{ section.settings.hanging_quote_color | default: '#9ca3af' }};
    --image-with-text-v3-collage-gap: clamp(1.2rem, 1.5vw, 1.6rem);
    --image-with-text-v3-collage-radius: 1.6rem;
    --image-with-text-v3-primary-height: clamp(36rem, 50vw, 54rem);
    --image-with-text-v3-secondary-height: calc((var(--image-with-text-v3-primary-height) - var(--image-with-text-v3-collage-gap)) / 2);
    --image-with-text-v3-primary-height-mobile: clamp(28rem, 68vw, 36rem);
    --image-with-text-v3-secondary-height-mobile: calc((var(--image-with-text-v3-primary-height-mobile) - 1rem) / 2);
    --image-with-text-v3-full-width-max-content: {{ section.settings.full_width_max_content_width }}px;
    --image-with-text-v3-full-width-image-padding: {{ section.settings.full_width_image_padding }}px;
    {%- if section.settings.use_custom_colors %}
      --gradient-background: {% if section.settings.gradient_background != blank %}{{ section.settings.gradient_background }}{% else %}{{ section.settings.colors_background }}{% endif %};
      --color-background: {{ section.settings.colors_background.red }}, {{ section.settings.colors_background.green }}, {{ section.settings.colors_background.blue }};
      --color-foreground: {{ section.settings.colors_text.red }}, {{ section.settings.colors_text.green }}, {{ section.settings.colors_text.blue }};
      --color-link: var(--color-foreground);
      --color-border: var(--color-foreground);
      --color-heading: var(--color-foreground);
      --color-button-background: {{ section.settings.colors_button_background.red }}, {{ section.settings.colors_button_background.green }}, {{ section.settings.colors_button_background.blue }};
      --color-button-text: {{ section.settings.colors_button_label.red }}, {{ section.settings.colors_button_label.green }}, {{ section.settings.colors_button_label.blue }};
      --color-button-border: var(--color-button-background);
      --color-shadow: var(--color-foreground);
    {% endif -%}
    --shadow-opacity: 0.3;
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
  }

  #shopify-section-{{ section.id }} .image-with-text__text--hanging-quotes {
    position: relative;
    padding-inline: var(--image-with-text-v3-hanging-quote-offset);
  }

  #shopify-section-{{ section.id }} .image-with-text__subheading {
    text-transform: none;
    letter-spacing: normal;
  }

  #shopify-section-{{ section.id }} .image-with-text,
  #shopify-section-{{ section.id }} .image-with-text__grid {
    background: transparent !important;
    background-color: transparent !important;
  }

  #shopify-section-{{ section.id }} .image-with-text__media-item {
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .image-with-text__content > :is(.image-with-text__heading, .image-with-text__subheading) + .image-with-text__text {
    margin-top: var(--image-with-text-v3-heading-text-gap);
  }

  #shopify-section-{{ section.id }} .image-with-text__social-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.6rem;
    align-items: center;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .image-with-text__content > .image-with-text__social-stats {
    margin-top: var(--image-with-text-v3-social-stats-margin-top, 2rem);
  }

  #shopify-section-{{ section.id }} .image-with-text__social-stat {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    color: inherit;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .image-with-text__social-stat-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: rgba(var(--color-highlight), 0.12);
    color: rgb(var(--color-highlight));
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .image-with-text__social-stat-icon .icon {
    width: 1.2rem;
    height: 1.2rem;
  }

  #shopify-section-{{ section.id }} .image-with-text__social-stat-text {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    flex-wrap: wrap;
    line-height: 1.25;
  }

  #shopify-section-{{ section.id }} .image-with-text__social-stat-value {
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .image-with-text__social-stat-label {
    opacity: 0.72;
  }

  #shopify-section-{{ section.id }} .image-with-text__content.center .image-with-text__social-stats,
  #shopify-section-{{ section.id }} .image-with-text__content.mobile-center .image-with-text__social-stats {
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .image-with-text__content.right .image-with-text__social-stats,
  #shopify-section-{{ section.id }} .image-with-text__content.mobile-right .image-with-text__social-stats {
    justify-content: flex-end;
  }

  #shopify-section-{{ section.id }} a.image-with-text__social-stat:hover {
    opacity: 0.8;
  }

  #shopify-section-{{ section.id }} .image-with-text.page-width--full-width .image-with-text__media-item {
    padding: var(--image-with-text-v3-full-width-image-padding);
  }

  #shopify-section-{{ section.id }} .image-with-text__text--hanging-quotes > *:first-child,
  #shopify-section-{{ section.id }} .image-with-text__text--hanging-quotes > *:last-child {
    position: relative;
  }

  #shopify-section-{{ section.id }} .image-with-text__text--hanging-quotes > *:first-child::before {
    content: '“';
    position: absolute;
    left: calc(var(--image-with-text-v3-hanging-quote-offset) * -1);
    top: -0.35em;
    font-size: var(--image-with-text-v3-hanging-quote-size);
    line-height: 1;
    color: var(--image-with-text-v3-hanging-quote-color);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .image-with-text__text--hanging-quotes > *:last-child::after {
    content: '”';
    position: absolute;
    right: calc(var(--image-with-text-v3-hanging-quote-offset) * -0.9);
    bottom: -0.55em;
    font-size: var(--image-with-text-v3-hanging-quote-size);
    line-height: 1;
    color: var(--image-with-text-v3-hanging-quote-color);
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .image-with-text__text--hanging-quotes {
      padding-inline: 1.6rem;
    }

    #shopify-section-{{ section.id }} .image-with-text__text--hanging-quotes > *:first-child::before {
      left: -1.4rem;
      font-size: 4rem;
    }

    #shopify-section-{{ section.id }} .image-with-text__text--hanging-quotes > *:last-child::after {
      right: -1.2rem;
      font-size: 4rem;
    }
  }

  @media screen and (min-width: 1600px) {
    #shopify-section-{{ section.id }} .image-with-text.page-width--full-width > .image-with-text__grid {
      max-width: min(100%, var(--image-with-text-v3-full-width-max-content));
      margin-inline: auto;
    }
  }
{%- endstyle -%}

{{ 'section-image-with-text.css' | asset_url | stylesheet_tag }}
{{ 'section-image-with-text-v3.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign grid_class = 'image-with-text__grid'
  if section.settings.layout == 'text_first'
    assign grid_class = grid_class | append: ' image-with-text__grid--reverse'
  endif

  if section.settings.mobile_layout == 'text_first'
    assign grid_class = grid_class | append: ' image-with-text__grid-mobile--reverse'
  endif

  if section.settings.mobile_layout == 'no_image'
    assign grid_class = grid_class | append: ' image-with-text__grid-mobile--no-image'
  endif

  if section.settings.mobile_layout == 'overlap'
    assign grid_class = grid_class | append: ' image-with-text__grid-mobile--overlap'
  endif
-%}

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="image-with-text{% if section.settings.use_custom_colors and section.settings.colors_background != settings.colors_background %} image-with-text--colored{% else %} image-with-text--alt{% endif %}{% if section.settings.enlarge_content %} image-with-text--enlarge{% endif %} page-width{% if section.settings.full_width %} page-width--full-width{% endif %}">
    <div class="{{ grid_class }} flex-grid flex-grid--gapless flex-grid--1-col flex-grid--2-col-tablet">
      <div class="flex-grid__item image-with-text__media-item">
        {%- liquid
          assign desktop_widths = '375, 550, 750, 1100, 1500, 2000'
          assign mobile_widths = '375, 550, 750, 1100'
          assign collage_image_style = 'object-position: ' | append: section.settings.image_position
          capture collage_sizes
            if section.settings.full_width
              echo '(min-width: 1600px) '
              echo section.settings.full_width_max_content_width | divided_by: 2
              echo 'px, '
            endif
            echo '(min-width: '
            echo settings.page_width
            echo 'px) '
            echo settings.page_width | minus: 100 | divided_by: 2
            echo 'px, (min-width: 750px) calc((100vw - 10rem) / 2), '
            if section.settings.full_width
              echo '50vw'
            else
              echo 'calc((100vw - 3rem) / 2)'
            endif
          endcapture
        -%}
        <use-animate data-animate="zoom-fade" class="media-wrapper image-with-text-v3__media-wrapper">
          <div class="image-with-text-v3__collage image-animate{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}">
            <div class="image-with-text-v3__frame image-with-text-v3__frame--primary">
              {%- if section.settings.image != blank -%}
                {%- if section.settings.image_mobile != blank -%}
                  {{
                    section.settings.image_mobile
                    | image_url: width: 2000
                    | image_tag:
                      loading: 'lazy',
                      class: 'image-fit medium-hide large-up-hide',
                      sizes: collage_sizes,
                      widths: mobile_widths,
                      style: collage_image_style,
                      is: 'lazy-image'
                  }}
                  {{
                    section.settings.image
                    | image_url: width: 3000
                    | image_tag:
                      loading: 'lazy',
                      class: 'image-fit small-hide',
                      sizes: collage_sizes,
                      widths: desktop_widths,
                      style: collage_image_style,
                      is: 'lazy-image'
                  }}
                {%- else -%}
                  {{
                    section.settings.image
                    | image_url: width: 3000
                    | image_tag:
                      loading: 'lazy',
                      class: 'image-fit',
                      sizes: collage_sizes,
                      widths: desktop_widths,
                      style: collage_image_style,
                      is: 'lazy-image'
                  }}
                {%- endif -%}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder' }}
              {%- endif -%}
            </div>
            <div class="image-with-text-v3__frame image-with-text-v3__frame--secondary">
              {%- if section.settings.image_2 != blank -%}
                {{
                  section.settings.image_2
                  | image_url: width: 2400
                  | image_tag:
                    loading: 'lazy',
                    class: 'image-fit',
                    sizes: collage_sizes,
                    widths: desktop_widths,
                    style: collage_image_style,
                    is: 'lazy-image'
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder' }}
              {%- endif -%}
            </div>
            <div class="image-with-text-v3__frame image-with-text-v3__frame--tertiary">
              {%- if section.settings.image_3 != blank -%}
                {{
                  section.settings.image_3
                  | image_url: width: 2400
                  | image_tag:
                    loading: 'lazy',
                    class: 'image-fit',
                    sizes: collage_sizes,
                    widths: desktop_widths,
                    style: collage_image_style,
                    is: 'lazy-image'
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder' }}
              {%- endif -%}
            </div>
          </div>
        </use-animate>
      </div>
      <div class="flex-grid__item">
        <div class="image-with-text__content {{ section.settings.text_box_position }} {{ section.settings.text_alignment }} mobile-{{ section.settings.mobile_text_alignment }}">
          {%- for block in section.blocks -%}
            {% case block.type %}
              {%- when 'heading' -%}
                <{{ block.settings.heading_tag }} class="image-with-text__heading {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                  {%- render 'highlight-text', 
                    hl_input: block.settings.heading, 
                    hl_style: block.settings.highlight_style,
                    hl_enable: block.settings.enable_highlight,
                    hl_animateWrap: true -%}
                </{{ block.settings.heading_tag }}>
                {%- if block.settings.heading_subheading != blank -%}
                  <p class="image-with-text__subheading {{ block.settings.heading_subheading_size }}">
                    {%- render 'highlight-text',
                      hl_input: block.settings.heading_subheading,
                      hl_style: block.settings.highlight_style,
                      hl_enable: block.settings.enable_highlight,
                      hl_animateWrap: true
                    -%}
                  </p>
                {%- endif -%}
              {%- when 'subheading' -%}
                <p class="image-with-text__subheading{% if block.settings.secondary_color %} image-with-text__subheading--colored{% endif %} {{ block.settings.subheading_size }}" {{ block.shopify_attributes }}>
                  {%- render 'highlight-text', 
                    hl_input: block.settings.subheading, 
                    hl_style: block.settings.highlight_style,
                    hl_enable: block.settings.enable_highlight,
                    hl_animateWrap: true -%}
                </p>
              {%- when 'text' -%}
                <div class="image-with-text__text{% if block.settings.show_hanging_quotes != false %} image-with-text__text--hanging-quotes{% endif %}{% if block.settings.secondary_color %} image-with-text__text--colored{% endif %} {{ block.settings.text_size }} rte" style="margin-top: {{ block.settings.margin_top }}px;" {{ block.shopify_attributes }}>
                  {%- render 'highlight-text', 
                    hl_input: block.settings.text, 
                    hl_style: block.settings.highlight_style,
                    hl_enable: block.settings.enable_highlight,
                    hl_animateWrap: true -%}
                </div>
              {%- when 'custom_liquid' -%}
                <div class="image-with-text__text rte" {{ block.shopify_attributes }}>{{ block.settings.custom_liquid }}</div>
              {%- when 'button' -%}
                <div class="button-group">
                  {%- if block.settings.button_label != blank or block.settings.button_alt_label != blank -%}
                    {%- if block.settings.button_label != blank -%}
                      {%- if block.settings.button_style_secondary -%}
                        <a class="button button--cta button--{{ block.settings.button_size }}"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                          <span class="label">{{ block.settings.button_label | escape }}</span>
                          {% render 'icon', icon: 'arrow' %}
                        </a>
                      {%- else -%}
                        <a class="button button--{{ block.settings.button_size }}"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                          {{ block.settings.button_label | escape }}
                        </a>
                      {%- endif -%}
                    {%- endif -%}
                    {%- if block.settings.button_alt_label != blank -%}
                      {%- if block.settings.button_alt_style_secondary -%}
                        <a class="button button--cta button--{{ block.settings.button_size }}"{% if block.settings.button_alt_link != blank %} href="{{ block.settings.button_alt_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                          <span class="label">{{ block.settings.button_alt_label | escape }}</span>
                          {% render 'icon', icon: 'arrow' %}
                        </a>
                      {%- else -%}
                        <a class="button button--secondary button--{{ block.settings.button_size }}"{% if block.settings.button_alt_link != blank %} href="{{ block.settings.button_alt_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                          {{ block.settings.button_alt_label | escape }}
                        </a>
                      {%- endif -%}
                    {%- endif -%}
                  {%- elsif section.blocks.size == 1 and block.settings.button_link != blank -%}
                    <a class="full-unstyled-link" href="{{ block.settings.button_link }}" {{ block.shopify_attributes }} aria-label="{{ block.settings.heading | default: block.settings.subheading | escape }}"></a>
                  {%- endif -%}
                </div>
              {%- when 'social_stat' -%}
                {%- liquid
                  assign previous_block_index = forloop.index0 | minus: 1
                  assign previous_block_type = ''

                  if previous_block_index >= 0
                    assign previous_block_type = section.blocks[previous_block_index].type
                  endif
                -%}
                {%- if previous_block_type != 'social_stat' -%}
                  <div
                    class="image-with-text__social-stats"
                    style="--image-with-text-v3-social-stats-margin-top: {{ block.settings.margin_top }}px;"
                  >
                    {%- for social_block in section.blocks offset: forloop.index0 -%}
                      {%- if social_block.type != 'social_stat' -%}
                        {% break %}
                      {%- endif -%}
                      {%- if social_block.settings.stat_value == blank and social_block.settings.stat_label == blank -%}
                        {% continue %}
                      {%- endif -%}
                      {%- if social_block.settings.stat_link != blank -%}
                        <a
                          class="image-with-text__social-stat"
                          href="{{ social_block.settings.stat_link }}"
                          {{ social_block.shopify_attributes }}
                        >
                      {%- else -%}
                        <div class="image-with-text__social-stat" {{ social_block.shopify_attributes }}>
                      {%- endif -%}
                        {%- if social_block.settings.platform != 'none' -%}
                          <span class="image-with-text__social-stat-icon" aria-hidden="true">
                            {% render 'icon-brand', icon: social_block.settings.platform %}
                          </span>
                        {%- endif -%}
                        <span class="image-with-text__social-stat-text">
                          {%- if social_block.settings.stat_value != blank -%}
                            <span class="image-with-text__social-stat-value">{{ social_block.settings.stat_value | escape }}</span>
                          {%- endif -%}
                          {%- if social_block.settings.stat_label != blank -%}
                            <span class="image-with-text__social-stat-label">{{ social_block.settings.stat_label | escape }}</span>
                          {%- endif -%}
                        </span>
                      {%- if social_block.settings.stat_link != blank -%}
                        </a>
                      {%- else -%}
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with text (v3)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Primary image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Secondary image"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Tertiary image"
    },
    {
      "type": "select",
      "id": "image_position",
      "options": [
        {
          "value": "20% 0",
          "label": "t:sections.all.image_position.options__1.label"
        },
        {
          "value": "top center",
          "label": "t:sections.all.image_position.options__2.label"
        },
        {
          "value": "80% 0",
          "label": "t:sections.all.image_position.options__3.label"
        },
        {
          "value": "20% 50%",
          "label": "t:sections.all.image_position.options__4.label"
        },
        {
          "value": "center center",
          "label": "t:sections.all.image_position.options__5.label"
        },
        {
          "value": "80% 50%",
          "label": "t:sections.all.image_position.options__6.label"
        },
        {
          "value": "20% 100%",
          "label": "t:sections.all.image_position.options__7.label"
        },
        {
          "value": "bottom center",
          "label": "t:sections.all.image_position.options__8.label"
        },
        {
          "value": "80% 100%",
          "label": "t:sections.all.image_position.options__9.label"
        }
      ],
      "default": "center center",
      "label": "t:sections.all.image_position.label",
      "info": "t:sections.all.image_position.info"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "image_first",
          "label": "t:sections.image-with-text.settings.layout.options__1.label"
        },
        {
          "value": "text_first",
          "label": "t:sections.image-with-text.settings.layout.options__2.label"
        }
      ],
      "default": "image_first",
      "label": "t:sections.image-with-text.settings.layout.label"
    },
    {
      "type": "select",
      "id": "text_box_position",
      "options": [
        {
          "value": "top",
          "label": "t:sections.image-with-text.settings.text_box_position.options__1.label"
        },
        {
          "value": "middle",
          "label": "t:sections.image-with-text.settings.text_box_position.options__2.label"
        },
        {
          "value": "bottom",
          "label": "t:sections.image-with-text.settings.text_box_position.options__3.label"
        }
      ],
      "default": "middle",
      "label": "t:sections.image-with-text.settings.text_box_position.label"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.all.text_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.all.text_alignment.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.all.text_alignment.options__3.label"
        }
      ],
      "default": "left",
      "label": "t:sections.all.text_alignment.label"
    },
    {
      "type": "range",
      "id": "heading_text_gap",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Heading to text gap",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "enlarge_content",
      "default": false,
      "label": "t:sections.image-with-text.settings.enlarge_content.label"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": false,
      "label": "t:sections.all.full_width.label"
    },
    {
      "type": "range",
      "id": "full_width_max_content_width",
      "min": 1200,
      "max": 2800,
      "step": 20,
      "unit": "px",
      "label": "Full width max content width",
      "default": 1800
    },
    {
      "type": "range",
      "id": "full_width_image_padding",
      "min": 0,
      "max": 80,
