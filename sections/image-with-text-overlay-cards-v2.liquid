{%- liquid
  assign image_position_x = '50%'
  assign image_position_y = '50%'

  case section.settings.image_position
    when '20% 0'
      assign image_position_x = '20%'
      assign image_position_y = '0%'
    when 'top center'
      assign image_position_x = '50%'
      assign image_position_y = '0%'
    when '80% 0'
      assign image_position_x = '80%'
      assign image_position_y = '0%'
    when '20% 50%'
      assign image_position_x = '20%'
      assign image_position_y = '50%'
    when 'center center'
      assign image_position_x = '50%'
      assign image_position_y = '50%'
    when '80% 50%'
      assign image_position_x = '80%'
      assign image_position_y = '50%'
    when '20% 100%'
      assign image_position_x = '20%'
      assign image_position_y = '100%'
    when 'bottom center'
      assign image_position_x = '50%'
      assign image_position_y = '100%'
    when '80% 100%'
      assign image_position_x = '80%'
      assign image_position_y = '100%'
  endcase
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --operating-system-overlay-width-desktop: {{ section.settings.content_width_desktop }}%;
    --operating-system-overlay-card-max-width: {{ section.settings.card_max_width }}px;
    --operating-system-overlay-card-radius: {{ section.settings.card_radius }}px;
    --operating-system-overlay-card-gap: {{ section.settings.card_gap }}px;
    --operating-system-overlay-color: {{ section.settings.overlay_color.red }}, {{ section.settings.overlay_color.green }}, {{ section.settings.overlay_color.blue }};
    --operating-system-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --operating-system-overlay-mobile-background: {{ section.settings.mobile_background }};
    --operating-system-overlay-title-color: {{ section.settings.title_color.red }}, {{ section.settings.title_color.green }}, {{ section.settings.title_color.blue }};
    --operating-system-overlay-card-background: {{ section.settings.card_background.red }}, {{ section.settings.card_background.green }}, {{ section.settings.card_background.blue }};
    --operating-system-overlay-card-text: {{ section.settings.card_text_color.red }}, {{ section.settings.card_text_color.green }}, {{ section.settings.card_text_color.blue }};
    --operating-system-overlay-image-position-x: {{ image_position_x }};
    --operating-system-overlay-image-position-y: {{ image_position_y }};
    --operating-system-overlay-image-offset-x: {{ section.settings.image_offset_x }}px;
    --operating-system-overlay-image-offset-x-mobile: {{ section.settings.image_offset_x_mobile }}px;
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
    {%- if section.settings.video != null -%}
      {% assign poster = section.settings.video.preview_image %}
      --image-ratio-percent: {{ 1 | divided_by: poster.aspect_ratio | times: 100 }}%;
    {%- elsif section.settings.video_url != blank -%}
      --image-ratio-percent: 56.25%;
    {%- elsif section.settings.image != blank -%}
      --image-ratio-percent: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;
    {%- endif -%}
    --image-position: {{ image_position_x }} {{ image_position_y }};
  }

  {%- if section.settings.image_mobile != blank and section.settings.mobile_image_ratio == 'adapt' -%}
    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} {
        --image-ratio-percent: {{ 1 | divided_by: section.settings.image_mobile.aspect_ratio | times: 100 }}%;
      }
    }
  {%- endif -%}
{%- endstyle -%}

{{ 'section-image-with-text-overlay-cards-v2.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_heading = false
  if section.settings.heading != blank
    assign has_heading = true
  endif
-%}

{%- capture heading_markup -%}
  {%- if has_heading -%}
    <{{ section.settings.heading_tag }} class="operating-system-overlay__heading {{ section.settings.heading_size }}">
      {%- render 'highlight-text',
        hl_input: section.settings.heading,
        hl_style: section.settings.highlight_style,
        hl_enable: section.settings.enable_highlight,
        hl_animateWrap: true
      -%}
    </{{ section.settings.heading_tag }}>
  {%- endif -%}
{%- endcapture -%}

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full-width{% endif %}">
    <div class="operating-system-overlay{% if section.settings.image_ratio == 'content' %} operating-system-overlay--desktop-content-height{% endif %}">
      <div class="operating-system-overlay__media{% if section.settings.video != null or section.settings.video_url != null %} operating-system-overlay__media--video{% endif %}">
        <use-animate data-animate="zoom-fade" class="media-wrapper media-wrapper--large">
          <div class="image-animate media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}">
            {%- if section.settings.video != null or section.settings.video_url != null -%}
              {%- if section.settings.video == null and section.settings.video_url != null -%}
                <video-section
                  data-video-hero
                  data-type="{{ section.settings.video_url.type }}"
                  data-loop="1"
                  data-video-id="{{ section.settings.video_url.id }}"
                ></video-section>
              {%- else -%}
                <video-section data-video-hero data-type="mp4">
                  {{
                    section.settings.video
                    | video_tag:
                      image_size: '3840px',
                      autoplay: true,
                      loop: true,
                      controls: false,
                      muted: true,
                      playsinline: true
                  }}
                </video-section>
              {%- endif -%}
            {%- else -%}
              {%- if section.settings.image != blank -%}
                {%- capture sizes -%}
                  {% if section.settings.full_width %}100vw{% else %}(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px, (min-width: 750px) calc(100vw - 10rem), calc(100vw - 3rem){% endif %}
                {%- endcapture -%}
                {%- if section.settings.image_behavior == 'ambient' -%}
                  {%- assign widths = '450, 900, 1320, 1800, 2136, 2400, 3600, 4680' -%}
                  {%- capture sizes -%}
                    {% if section.settings.full_width %}calc(100vw / 1.667){% else %}(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 1.6667 }}px, (min-width: 750px) calc((100vw - 10rem) / 1.667), calc((100vw - 3rem) / 1.667){% endif %}
                  {%- endcapture -%}
                {%- else -%}
                  {%- assign widths = '375, 750, 1100, 1500, 1780, 2000, 3000, 3840' -%}
                {%- endif -%}
                {%- liquid
                  if section.settings.image_mobile == blank
                    echo section.settings.image | image_url: width: 3840 | image_tag: loading: 'lazy', class: 'image-fit', sizes: sizes, widths: widths, is: 'lazy-image'
                  else
                    echo section.settings.image_mobile | image_url: width: 3840 | image_tag: loading: 'lazy', class: 'image-fit medium-hide large-up-hide', sizes: sizes, widths: widths, is: 'lazy-image'
                    echo section.settings.image | image_url: width: 3840 | image_tag: loading: 'lazy', class: 'image-fit small-hide', sizes: sizes, widths: widths, is: 'lazy-image'
                  endif
                -%}
              {%- else -%}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder image-animate' }}
              {%- endif -%}
            {%- endif -%}
          </div>
        </use-animate>
      </div>

      {%- if has_heading -%}
        <div class="operating-system-overlay__mobile-heading">
          {{ heading_markup }}
        </div>
      {%- endif -%}

      <div class="operating-system-overlay__content">
        {%- if has_heading -%}
          <div class="operating-system-overlay__desktop-heading">
            {{ heading_markup }}
          </div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="operating-system-overlay__cards" role="list">
            {%- for block in section.blocks -%}
              <div class="operating-system-overlay__card-shell" role="listitem" {{ block.shopify_attributes }}>
                <use-animate data-animate="zoom-fade-small" class="operating-system-overlay__card-wrap">
                  <article class="operating-system-overlay__card">
                    {%- if block.settings.title != blank -%}
                      <{{ block.settings.title_tag }} class="operating-system-overlay__card-title {{ block.settings.title_size }}">
                        {{ block.settings.title }}
                      </{{ block.settings.title_tag }}>
                    {%- endif -%}
                    {%- if block.settings.text != blank -%}
                      <div class="operating-system-overlay__card-text rte">
                        {{ block.settings.text }}
                      </div>
                    {%- endif -%}
                  </article>
                </use-animate>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

