{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --image-position: {{ section.settings.image_position }};
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
    --tab-font-size: {{ section.settings.tab_font_size }}px;
    --tab-font-weight: {{ section.settings.tab_font_weight }};
    --tab-text-transform: {{ section.settings.tab_text_transform }};
    --tab-text-color: {{ section.settings.tab_text_color }};
    --tab-active-text-color: {{ section.settings.tab_active_text_color }};
    --tab-background-color: {{ section.settings.tab_background_color }};
    --tab-active-background-color: {{ section.settings.tab_active_background_color }};
    --product-title-size: {{ section.settings.product_title_size }}px;
    --product-title-color: {{ section.settings.product_title_color }};
    --product-price-color: {{ section.settings.product_price_color }};
    --product-compare-price-color: {{ section.settings.product_compare_price_color }};
    --product-compare-line-color: {{ section.settings.product_compare_line_color }};
  }

  #shopify-section-{{ section.id }} .tabs-grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, minmax(160px, 1fr));
    grid-template-rows: auto 1fr;
    column-gap: 1rem;
  }

  #shopify-section-{{ section.id }} .tabs-grid details {
    display: grid;
    grid-template-columns: subgrid;
    grid-template-rows: subgrid;
    grid-column: 1 / -1;
    grid-row: 1 / span 2;
  }

  #shopify-section-{{ section.id }} .tabs-grid summary {
    grid-row: 1;
    grid-column: var(--tab-index) / span 1;
    display: grid;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    min-height: 6.4rem;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    list-style: none;
    text-align: center;
    transition: all 0.2s ease;
    z-index: 1;
    font-size: var(--tab-font-size);
    font-weight: var(--tab-font-weight);
    text-transform: var(--tab-text-transform);
    color: var(--tab-text-color);
    background-color: var(--tab-background-color);
  }

  #shopify-section-{{ section.id }} .tabs-grid summary::-webkit-details-marker {
    display: none;
  }

  #shopify-section-{{ section.id }} .tabs-grid summary:hover {
    background-color: rgba(var(--color-foreground), 0.05);
  }

  #shopify-section-{{ section.id }} .tabs-grid details[open] summary {
    border-bottom-color: rgb(var(--color-highlight));
    background-color: var(--tab-active-background-color);
    color: var(--tab-active-text-color);
  }

  #shopify-section-{{ section.id }} .tabs-grid details::details-content {
    grid-row: 2;
    grid-column: 1 / -1;
    padding-top: 2rem;
  }

  #shopify-section-{{ section.id }} .tabs-grid:has(.slider-buttons) details::details-content {
    padding-top: 0.5rem;
  }

  #shopify-section-{{ section.id }} .tabs-grid details:not([open])::details-content {
    display: none;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .slider-mobile-gutter {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    #shopify-section-{{ section.id }} .slider-buttons {
      order: 0;
      position: static !important;
      display: flex;
      justify-content: flex-end;
      gap: 0.5rem;
      margin-bottom: 0;
    }

    #shopify-section-{{ section.id }} .product-grid {
      order: 1;
    }
  }

  #shopify-section-{{ section.id }} .fake-tabs-desktop,
  #shopify-section-{{ section.id }} .fake-tabs-mobile {
    display: none;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.1);
  }

  #shopify-section-{{ section.id }} .fake-tabs-desktop::-webkit-scrollbar,
  #shopify-section-{{ section.id }} .fake-tabs-mobile::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .fake-tabs-container {
    display: flex;
    gap: 0.75rem;
    min-width: max-content;
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .fake-tab-item {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 6.4rem;
    padding: 1rem 1.5rem;
    cursor: pointer;
    white-space: normal;
    text-align: center;
    border-bottom: 2px solid transparent;
    transition: all 0.2s ease;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    font-size: var(--tab-font-size);
    font-weight: var(--tab-font-weight);
    text-transform: var(--tab-text-transform);
    color: var(--tab-text-color);
    background-color: var(--tab-background-color);
  }

  #shopify-section-{{ section.id }} .fake-tab-item.active {
    border-bottom-color: rgb(var(--color-highlight));
    background-color: var(--tab-active-background-color);
    color: var(--tab-active-text-color);
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .fake-tabs-mobile {
      display: block;
    }

    #shopify-section-{{ section.id }} .fake-tab-item:active {
      opacity: 0.7;
    }

    #shopify-section-{{ section.id }} .tabs-grid summary {
      display: none;
    }

    #shopify-section-{{ section.id }} .tabs-grid {
      grid-template-columns: 1fr;
      grid-template-rows: 1fr;
    }

    #shopify-section-{{ section.id }} .tabs-grid details {
      grid-row: 1;
      grid-column: 1;
    }

    #shopify-section-{{ section.id }} .tabs-grid details::details-content {
      grid-row: 1;
      grid-column: 1;
      min-width: 0;
    }

    #shopify-section-{{ section.id }} .tabs-grid,
    #shopify-section-{{ section.id }} .tabs-grid details,
    #shopify-section-{{ section.id }} .tab-content,
    #shopify-section-{{ section.id }} .slider-mobile-gutter {
      min-width: 0;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .tab-content {
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .slider-mobile-gutter {
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
    }

    #shopify-section-{{ section.id }} .product-grid {
      display: flex;
      flex-wrap: nowrap;
    }

    #shopify-section-{{ section.id }} .product-grid.flex-grid--1-col-mobile .flex-grid__item {
      width: calc(100vw - var(--page-width-margin) * 2);
    }
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .fake-tabs-desktop {
      display: block;
    }

    #shopify-section-{{ section.id }} .tabs-grid summary {
      display: none;
    }

    #shopify-section-{{ section.id }} .tabs-grid {
      grid-template-columns: 1fr;
      grid-template-rows: 1fr;
    }

    #shopify-section-{{ section.id }} .tabs-grid details {
      grid-row: 1;
      grid-column: 1;
    }

    #shopify-section-{{ section.id }} .tabs-grid details::details-content {
      grid-row: 1;
      grid-column: 1;
    }
  }

  #shopify-section-{{ section.id }} .card-information__text {
    font-size: var(--product-title-size);
    line-height: 1.2;
    color: var(--product-title-color);
  }

  #shopify-section-{{ section.id }} .card-information__text:hover {
    color: var(--product-title-color);
  }

  #shopify-section-{{ section.id }} .price,
  #shopify-section-{{ section.id }} .price .price-item--sale,
  #shopify-section-{{ section.id }} .price .price-item--regular {
    color: var(--product-price-color);
  }

  #shopify-section-{{ section.id }} .price .price__compare,
  #shopify-section-{{ section.id }} .price .price__compare .price-item,
  #shopify-section-{{ section.id }} .price .price__compare s {
    color: var(--product-compare-price-color);
  }

  #shopify-section-{{ section.id }} .price .price__compare s {
    text-decoration-color: var(--product-compare-line-color);
  }

  #shopify-section-{{ section.id }} .loox-rating,
  #shopify-section-{{ section.id }} .rating,
  #shopify-section-{{ section.id }} .rating-text,
  #shopify-section-{{ section.id }} .rating-count {
    display: none !important;
  }
{%- endstyle -%}

{%- liquid
  assign section_anchor_id = section.settings.section_id | handleize
-%}

<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.quick_view_enabled and section.settings.enable_quick_view -%}
  <link rel="stylesheet" href="{{ 'section-main-product.css' | asset_url }}" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}
<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-price.css' | asset_url | stylesheet_tag }}</noscript>

{{ 'component-product-grid.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
<script src="{{ 'multicollection-subscription-grid.js' | asset_url }}" defer="defer"></script>

<div{% if section_anchor_id != blank %} id="{{ section_anchor_id }}"{% endif %} class="section--padding multicollection-subscription-grid{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="page-width">
    <div class="title-wrapper{% if section.settings.heading == blank %} title-wrapper--no-heading{% endif %} {{ section.settings.heading_alignment }}">
      <{{ section.settings.heading_tag }} class="title {{ section.settings.heading_size }}">
        {%- render 'highlight-text', 
          hl_input: section.settings.heading, 
          hl_style: section.settings.highlight_style,
          hl_enable: section.settings.enable_highlight,
          hl_animateWrap: true -%}
      </{{ section.settings.heading_tag }}>
    </div>

    {%- if section.blocks.size == 1 -%}
      {%- assign block = section.blocks.first -%}
      {%- assign collection = block.settings.collection -%}

      {%- liquid
        assign products_to_display = 0
        for product in collection.products
          assign has_selling_plans = false
          if product.selling_plan_groups != blank and product.selling_plan_groups.size > 0
            assign has_selling_plans = true
          endif
          if section.settings.only_subscription_products and has_selling_plans == false
            continue
          endif

          assign products_to_display = products_to_display | plus: 1
          if products_to_display >= section.settings.products_to_show
            break
          endif
        endfor

        assign class_slider = 'slider'
        if section.settings.swipe_on_mobile
          assign class_slider = class_slider | append: ' slider--tablet'
        endif
        assign class_grid_2_col_tablet = 'flex-grid--2-col-tablet'
        assign class_grid_3_col_tablet = 'flex-grid--3-col-tablet'
        assign class_grid_3_col_desktop = 'flex-grid--3-col-desktop'
        assign class_grid_4_col_desktop = 'flex-grid--4-col-desktop'
        assign disable_image_click = false

        if section.settings.horizontal_scroll
          assign class_grid_2_col_tablet = 'flex-grid--2p3-col-tablet'
          assign class_grid_3_col_tablet = 'flex-grid--3p3-col-tablet'
          assign class_grid_3_col_desktop = 'flex-grid--3p3-col-desktop'
          assign class_grid_4_col_desktop = 'flex-grid--4p3-col-desktop'
          assign class_slider = class_slider | append: ' slider--tablet-up'
          if section.settings.products_to_show > 4 and section.settings.enable_drag
            assign disable_image_click = true
            assign class_slider = class_slider | append: ' cursor--drag'
          endif
        endif
      %}

      <div class="slider-mobile-gutter">
        <ul id="Slider-{{ section.id }}"
          class="product-grid flex-grid flex-grid--rigid{% if section.settings.columns_mobile == '1' %} flex-grid--1-col-mobile{% endif %} flex-grid--2-col{% if collection == blank or products_to_display == 4 and section.settings.swipe_on_mobile == false %} {{ class_grid_2_col_tablet }} {{ class_grid_4_col_desktop }}{% else %} {{ class_grid_3_col_tablet }}{% if products_to_display == 6 %} {{ class_grid_3_col_desktop }}{% else %} {{ class_grid_4_col_desktop }}{% endif %}{% endif %}{% if products_to_display > 2 and section.settings.products_to_show > 2 %} {{ class_slider }}{% endif %}{% if collection == blank %} {{ class_slider }}{% endif %}"
          role="list"{% if section.settings.horizontal_scroll %} is="scroll-snap-slider" data-draggable="{{ section.settings.enable_drag }}"{% endif %}
        >
          {%- liquid
            assign rendered_products = 0
          -%}
          {%- for product in collection.products -%}
            {%- liquid
              assign has_selling_plans = false
              if product.selling_plan_groups != blank and product.selling_plan_groups.size > 0
                assign has_selling_plans = true
              endif
              if section.settings.only_subscription_products and has_selling_plans == false
                continue
              endif
              if rendered_products >= section.settings.products_to_show
                break
              endif

              assign custom_price = blank
              assign custom_compare_at_price = blank
              assign custom_price_min = blank
              assign custom_price_max = blank
              assign custom_compare_at_price_min = blank
              assign custom_compare_at_price_max = blank
              assign first_selling_plan_id = blank
              assign pricing_exempt = false
              assign show_from_lowest_price_card = true
              assign has_subscription_pricing = false
              assign subscription_price_min_cents = blank
              assign subscription_price_max_cents = blank
              assign discount_multiplier = blank
              assign base_price_min_cents = product.price_min
              assign base_price_max_cents = product.price_max

              if product.gift_card?
                assign pricing_exempt = true
                assign show_from_lowest_price_card = false
              endif

              if product.variants.size == 1 and product.selling_plan_groups != blank
                assign first_group = product.selling_plan_groups.first
                if first_group and first_group.selling_plans != blank
                  assign first_plan = first_group.selling_plans.first
                  if first_plan
                    assign first_selling_plan_id = first_plan.id
                  endif
                endif
              endif

              if pricing_exempt == false
                for variant in product.variants
                  assign first_subscription_allocation = variant.selling_plan_allocations | first
                  if first_subscription_allocation
                    assign has_subscription_pricing = true
                    if subscription_price_min_cents == blank or first_subscription_allocation.price < subscription_price_min_cents
                      assign subscription_price_min_cents = first_subscription_allocation.price
                    endif
                    if subscription_price_max_cents == blank or first_subscription_allocation.price > subscription_price_max_cents
                      assign subscription_price_max_cents = first_subscription_allocation.price
                    endif
                  endif
                endfor
              endif

              if pricing_exempt == false and collection.handle == 'bundles'
                if section.settings.show_bundle_discount_price and base_price_min_cents != blank
                  assign discount_multiplier = 100 | minus: section.settings.bundle_discount_percentage
                  assign custom_compare_at_price = base_price_min_cents
                  assign custom_price = custom_compare_at_price | times: discount_multiplier | divided_by: 100
                  assign custom_compare_at_price_min = base_price_min_cents
                  assign custom_compare_at_price_max = base_price_max_cents
                  assign custom_price_min = custom_compare_at_price_min | times: discount_multiplier | divided_by: 100
                  assign custom_price_max = custom_compare_at_price_max | times: discount_multiplier | divided_by: 100
                endif
              elsif pricing_exempt == false and section.settings.show_dtc_discount_price
                if has_subscription_pricing
                  assign custom_price = subscription_price_min_cents
                  assign custom_compare_at_price = subscription_price_min_cents
                  assign custom_price_min = subscription_price_min_cents
                  assign custom_price_max = subscription_price_max_cents
                  assign custom_compare_at_price_min = subscription_price_min_cents
                  assign custom_compare_at_price_max = subscription_price_max_cents
                elsif base_price_min_cents != blank
                  assign discount_multiplier = 100 | minus: section.settings.dtc_discount_percentage
                  assign custom_price = base_price_min_cents | times: discount_multiplier | divided_by: 100
                  assign custom_compare_at_price = custom_price
                  assign custom_price_min = base_price_min_cents | times: discount_multiplier | divided_by: 100
                  assign custom_price_max = base_price_max_cents | times: discount_multiplier | divided_by: 100
                  assign custom_compare_at_price_min = custom_price_min
                  assign custom_compare_at_price_max = custom_price_max
                endif
              endif

              assign rendered_products = rendered_products | plus: 1
            -%}
            <li id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="flex-grid__item{% if products_to_display > 2 and section.settings.swipe_on_mobile and section.settings.products_to_show > 2 %} slider__slide{% endif %}"
            >
              {% render 'card-product',
                card_product: product,
                card_collection: collection,
                media_size: section.settings.image_ratio,
                show_secondary_image: section.settings.show_secondary_image,
                show_quick_buy: section.settings.show_quick_buy,
                show_vendor: section.settings.show_vendor,
                show_rating: false,
                enable_quick_view: section.settings.enable_quick_view,
                enable_color_swatches: section.settings.enable_color_swatches,
                enable_countdown: section.settings.enable_countdown,
                enable_image_fill: section.settings.enable_image_fill,
                disable_image_click: disable_image_click,
                custom_price: custom_price,
                custom_compare_at_price: custom_compare_at_price,
                custom_price_min: custom_price_min,
                custom_price_max: custom_price_max,
                custom_compare_at_price_min: custom_compare_at_price_min,
                custom_compare_at_price_max: custom_compare_at_price_max,
                show_from_lowest_price: show_from_lowest_price_card,
                first_selling_plan_id: first_selling_plan_id
              %}
            </li>
          {%- endfor -%}
          {%- if rendered_products == 0 -%}
            {%- for i in (1..4) -%}
              <li class="flex-grid__item{% if section.settings.swipe_on_mobile %} slider__slide{% endif %}">
                {% render 'card-product-placeholder', media_size: section.settings.image_ratio %}
              </li>
            {%- endfor -%}
          {%- endif -%}
        </ul>
        {% if section.settings.horizontal_scroll %}
          <div class="slider-buttons no-js-hidden small-hide{% if section.settings.products_to_show <= 4 %} large-up-hide{% if section.settings.products_to_show <= 3 %} medium-hide{% endif %}{% endif %}">
            <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}" disabled="disabled">
              {% render 'icon', icon: 'arrow' %}
            </button>
            <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
              {% render 'icon', icon: 'arrow' %}
            </button>
          </div>
        {% endif %}
      </div>

      {%- if section.settings.show_view_all and collection.all_products_count > section.settings.products_to_show -%}
        <div class="view-all center">
          <a href="{{ collection.url }}"
            class="button"
            aria-label="{{ 'sections.featured_collection.view_all_label' | t: collection_name: collection.title }}"
          >
            {{ 'sections.featured_collection.view_all' | t }}
          </a>
        </div>
      {%- endif -%}
    {%- elsif section.blocks.size > 1 -%}
      <subscription-grid-tabs>
        <div class="fake-tabs-desktop">
          <div class="fake-tabs-container">
            {%- for block in section.blocks -%}
              {%- liquid
                assign collection = block.settings.collection
                assign tab_label = block.settings.tab_label
                if tab_label == blank and collection != blank
                  assign tab_label = collection.title
                elsif tab_label == blank
                  assign tab_label = 'Tab ' | append: forloop.index
                endif
              -%}
              <div class="fake-tab-item{% if forloop.first %} active{% endif %}" data-tab-index="{{ forloop.index }}">
                {{ tab_label }}
              </div>
            {%- endfor -%}
          </div>
        </div>

        <div class="fake-tabs-mobile">
          <div class="fake-tabs-container">
            {%- for block in section.blocks -%}
              {%- liquid
                assign collection = block.settings.collection
                assign tab_label = block.settings.tab_label
                if tab_label == blank and collection != blank
                  assign tab_label = collection.title
                elsif tab_label == blank
                  assign tab_label = 'Tab ' | append: forloop.index
                endif
              -%}
              <div class="fake-tab-item{% if forloop.first %} active{% endif %}" 
                   data-tab-index="{{ forloop.index }}">
                {{ tab_label }}
              </div>
            {%- endfor -%}
          </div>
        </div>

        <div class="tabs-grid">
        {%- for block in section.blocks -%}
          {%- liquid
            assign collection = block.settings.collection
            assign tab_label = block.settings.tab_label
            if tab_label == blank and collection != blank
              assign tab_label = collection.title
            elsif tab_label == blank
              assign tab_label = 'Tab ' | append: forloop.index
            endif

            assign products_to_display = 0
            for product in collection.products
              assign has_selling_plans = false
              if product.selling_plan_groups != blank and product.selling_plan_groups.size > 0
                assign has_selling_plans = true
              endif
              if section.settings.only_subscription_products and has_selling_plans == false
                continue
              endif

              assign products_to_display = products_to_display | plus: 1
              if products_to_display >= section.settings.products_to_show
                break
              endif
            endfor

            assign class_slider = 'slider'
            if section.settings.swipe_on_mobile
              assign class_slider = class_slider | append: ' slider--tablet'
            endif
            assign class_grid_2_col_tablet = 'flex-grid--2-col-tablet'
            assign class_grid_3_col_tablet = 'flex-grid--3-col-tablet'
            assign class_grid_3_col_desktop = 'flex-grid--3-col-desktop'
            assign class_grid_4_col_desktop = 'flex-grid--4-col-desktop'
            assign disable_image_click = false

            if section.settings.horizontal_scroll
              assign class_grid_2_col_tablet = 'flex-grid--2p3-col-tablet'
              assign class_grid_3_col_tablet = 'flex-grid--3p3-col-tablet'
              assign class_grid_3_col_desktop = 'flex-grid--3p3-col-desktop'
              assign class_grid_4_col_desktop = 'flex-grid--4p3-col-desktop'
              assign class_slider = class_slider | append: ' slider--tablet-up'
              if section.settings.products_to_show > 4 and section.settings.enable_drag
                assign disable_image_click = true
                assign class_slider = class_slider | append: ' cursor--drag'
              endif
            endif
          %}

          <details class="tab-item" 
                   name="tabbed-collection-{{ section.id }}" 
                   style="--tab-index: {{ forloop.index }}"
                   {% if forloop.first %}open{% endif %}
                   {{ block.shopify_attributes }}>
            <summary class="tab-label">{{ tab_label }}</summary>
            
            <div class="tab-content">
              <div class="slider-mobile-gutter">
                <ul id="Slider-{{ section.id }}-{{ block.id }}"
                  class="product-grid flex-grid flex-grid--rigid{% if section.settings.columns_mobile == '1' %} flex-grid--1-col-mobile{% endif %} flex-grid--2-col{% if collection == blank or products_to_display == 4 and section.settings.swipe_on_mobile == false %} {{ class_grid_2_col_tablet }} {{ class_grid_4_col_desktop }}{% else %} {{ class_grid_3_col_tablet }}{% if products_to_display == 6 %} {{ class_grid_3_col_desktop }}{% else %} {{ class_grid_4_col_desktop }}{% endif %}{% endif %}{% if products_to_display > 2 and section.settings.products_to_show > 2 %} {{ class_slider }}{% endif %}{% if collection == blank %} {{ class_slider }}{% endif %}"
                  role="list"{% if section.settings.horizontal_scroll %} is="scroll-snap-slider" data-draggable="{{ section.settings.enable_drag }}"{% endif %}
                >
                  {%- liquid
                    assign rendered_products = 0
                  -%}
                  {%- for product in collection.products -%}
                    {%- liquid
                      assign has_selling_plans = false
                      if product.selling_plan_groups != blank and product.selling_plan_groups.size > 0
                        assign has_selling_plans = true
                      endif
                      if section.settings.only_subscription_products and has_selling_plans == false
                        continue
                      endif
                      if rendered_products >= section.settings.products_to_show
                        break
                      endif

                      assign custom_price = blank
                      assign custom_compare_at_price = blank
                      assign custom_price_min = blank
                      assign custom_price_max = blank
                      assign custom_compare_at_price_min = blank
                      assign custom_compare_at_price_max = blank
                      assign first_selling_plan_id = blank
                      assign pricing_exempt = false
                      assign show_from_lowest_price_card = true
                      assign has_subscription_pricing = false
                      assign subscription_price_min_cents = blank
                      assign subscription_price_max_cents = blank
                      assign discount_multiplier = blank
                      assign base_price_min_cents = product.price_min
                      assign base_price_max_cents = product.price_max

                      if product.gift_card?
                        assign pricing_exempt = true
                        assign show_from_lowest_price_card = false
                      endif

                      if product.variants.size == 1 and product.selling_plan_groups != blank
                        assign first_group = product.selling_plan_groups.first
                        if first_group and first_group.selling_plans != blank
                          assign first_plan = first_group.selling_plans.first
                          if first_plan
                            assign first_selling_plan_id = first_plan.id
                          endif
                        endif
                      endif

                      if pricing_exempt == false
                        for variant in product.variants
                          assign first_subscription_allocation = variant.selling_plan_allocations | first
                          if first_subscription_allocation
                            assign has_subscription_pricing = true
                            if subscription_price_min_cents == blank or first_subscription_allocation.price < subscription_price_min_cents
                              assign subscription_price_min_cents = first_subscription_allocation.price
                            endif
                            if subscription_price_max_cents == blank or first_subscription_allocation.price > subscription_price_max_cents
                              assign subscription_price_max_cents = first_subscription_allocation.price
                            endif
                          endif
                        endfor
                      endif

                      if pricing_exempt == false and collection.handle == 'bundles'
                        if section.settings.show_bundle_discount_price and base_price_min_cents != blank
                          assign discount_multiplier = 100 | minus: section.settings.bundle_discount_percentage
                          assign custom_compare_at_price = base_price_min_cents
                          assign custom_price = custom_compare_at_price | times: discount_multiplier | divided_by: 100
                          assign custom_compare_at_price_min = base_price_min_cents
                          assign custom_compare_at_price_max = base_price_max_cents
                          assign custom_price_min = custom_compare_at_price_min | times: discount_multiplier | divided_by: 100
                          assign custom_price_max = custom_compare_at_price_max | times: discount_multiplier | divided_by: 100
                        endif
                      elsif pricing_exempt == false and section.settings.show_dtc_discount_price
                        if has_subscription_pricing
                          assign custom_price = subscription_price_min_cents
                          assign custom_compare_at_price = subscription_price_min_cents
                          assign custom_price_min = subscription_price_min_cents
                          assign custom_price_max = subscription_price_max_cents
                          assign custom_compare_at_price_min = subscription_price_min_cents
                          assign custom_compare_at_price_max = subscription_price_max_cents
                        elsif base_price_min_cents != blank
                          assign discount_multiplier = 100 | minus: section.settings.dtc_discount_percentage
                          assign custom_price = base_price_min_cents | times: discount_multiplier | divided_by: 100
                          assign custom_compare_at_price = custom_price
                          assign custom_price_min = base_price_min_cents | times: discount_multiplier | divided_by: 100
                          assign custom_price_max = base_price_max_cents | times: discount_multiplier | divided_by: 100
                          assign custom_compare_at_price_min = custom_price_min
                          assign custom_compare_at_price_max = custom_price_max
                        endif
                      endif

                      assign rendered_products = rendered_products | plus: 1
                    -%}
                    <li id="Slide-{{ section.id }}-{{ block.id }}-{{ forloop.index }}"
                      class="flex-grid__item{% if products_to_display > 2 and section.settings.swipe_on_mobile and section.settings.products_to_show > 2 %} slider__slide{% endif %}"
                    >
                      {% render 'card-product',
                        card_product: product,
                        card_collection: collection,
                        media_size: section.settings.image_ratio,
                        show_secondary_image: section.settings.show_secondary_image,
                        show_quick_buy: section.settings.show_quick_buy,
                        show_vendor: section.settings.show_vendor,
                        show_rating: false,
                        enable_quick_view: section.settings.enable_quick_view,
                        enable_color_swatches: section.settings.enable_color_swatches,
                        enable_countdown: section.settings.enable_countdown,
                        enable_image_fill: section.settings.enable_image_fill,
                        disable_image_click: disable_image_click,
                        custom_price: custom_price,
                        custom_compare_at_price: custom_compare_at_price,
                        custom_price_min: custom_price_min,
                        custom_price_max: custom_price_max,
                        custom_compare_at_price_min: custom_compare_at_price_min,
                        custom_compare_at_price_max: custom_compare_at_price_max,
                        show_from_lowest_price: show_from_lowest_price_card,
                        first_selling_plan_id: first_selling_plan_id
                      %}
                    </li>
                  {%- endfor -%}
                  {%- if rendered_products == 0 -%}
                    {%- for i in (1..4) -%}
                      <li class="flex-grid__item{% if section.settings.swipe_on_mobile %} slider__slide{% endif %}">
                        {% render 'card-product-placeholder', media_size: section.settings.image_ratio %}
                      </li>
                    {%- endfor -%}
                  {%- endif -%}
                </ul>
                {% if section.settings.horizontal_scroll %}
                  <div class="slider-buttons no-js-hidden small-hide{% if section.settings.products_to_show <= 4 %} large-up-hide{% if section.settings.products_to_show <= 3 %} medium-hide{% endif %}{% endif %}">
                    <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}" disabled="disabled">
                      {% render 'icon', icon: 'arrow' %}
                    </button>
                    <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
                      {% render 'icon', icon: 'arrow' %}
                    </button>
                  </div>
                {% endif %}
              </div>

              {%- if section.settings.show_view_all and collection.all_products_count > section.settings.products_to_show -%}
                <div class="view-all center">
                  <a href="{{ collection.url }}"
                    class="button"
                    aria-label="{{ 'sections.featured_collection.view_all_label' | t: collection_name: collection.title }}"
                  >
                    {{ 'sections.featured_collection.view_all' | t }}
                  </a>
                </div>
              {%- endif -%}
            </div>
          </details>
        {%- endfor -%}
        </div>
      </subscription-grid-tabs>
    {%- else -%}
      <div class="placeholder-content">
        <p>Add collection blocks to display the subscription grid.</p>
      </div>
    {%- endif -%}
  </div>
</div>

