{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .dc_tat__section {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  #shopify-section-{{ section.id }} .dc_tat__container {
    display: flex;
    flex-direction: {% if section.settings.image_position == 'right' %}row{% else %}row-reverse{% endif %};
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid {{ section.settings.border_color }};
    min-height: 400px;
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
  }

  #shopify-section-{{ section.id }} .dc_tat__info {
    flex: 1 1 50%;
    padding: 60px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .dc_tat__image-wrapper {
    flex: 1 1 50%;
    min-height: 400px;
    position: relative;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .dc_tat__image-wrapper img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .dc_tat__title {
    font-size: 63px;
    font-weight: 600;
    margin: 0 0 16px;
    line-height: 1.1;
  }

  #shopify-section-{{ section.id }} .dc_tat__subtitle {
    font-size: 30px;
    font-weight: 500;
    margin: 0 0 16px;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .dc_tat__content {
    font-size: 17px;
    font-weight: 400;
    margin: 0 0 16px;
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .dc_tat__button {
    text-align:center;
    display: inline-block;
    align-self: flex-start;
    padding: 14px 28px;
    border-radius: 30px;
    font-size: 20px;
    font-weight: 500;
    line-height: 1.2;
    text-decoration: none;
    background-color: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    transition: opacity 0.2s ease;
    border: none;
    cursor: pointer;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .dc_tat__button:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .dc_tat__container {
      flex-direction: column;
      min-height: unset;
    }

    #shopify-section-{{ section.id }} .dc_tat__image-wrapper {
      flex: none;
      width: 100%;
      aspect-ratio: 1 / 1;
      min-height: unset;
      order: -1;
      position: relative;
    }

    #shopify-section-{{ section.id }} .dc_tat__image-wrapper img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }

    #shopify-section-{{ section.id }} .dc_tat__info {
      flex: none;
      padding: 25px;
    }

    #shopify-section-{{ section.id }} .dc_tat__title {
      font-size: 28px;
    }

    #shopify-section-{{ section.id }} .dc_tat__subtitle {
      font-size: 18.5px;
      margin-bottom: 0;
    }

    #shopify-section-{{ section.id }} .dc_tat__content {
      font-size: 16px;
      margin-bottom: 0;
    }

    #shopify-section-{{ section.id }} .dc_tat__button {
      font-size: 19px;
      align-self: stretch;
      text-align: center;
    }
  }
{%- endstyle -%}

<div class="dc_tat__section">
  <div class="page-width">
    <div class="dc_tat__container">
      <div class="dc_tat__info">
        {%- if section.settings.title != blank -%}
          <h2 class="dc_tat__title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.subtitle_1 != blank -%}
          <h3 class="dc_tat__subtitle">{{ section.settings.subtitle_1 | escape }}</h3>
        {%- endif -%}

        {%- if section.settings.content_1 != blank -%}
          <div class="dc_tat__content">{{ section.settings.content_1 }}</div>
        {%- endif -%}

        {%- if section.settings.subtitle_2 != blank -%}
          <h3 class="dc_tat__subtitle">{{ section.settings.subtitle_2 | escape }}</h3>
        {%- endif -%}

        {%- if section.settings.content_2 != blank -%}
          <div class="dc_tat__content">{{ section.settings.content_2 }}</div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a
            class="dc_tat__button"
            {%- if section.settings.button_link != blank %}
              href="{{ section.settings.button_link }}"
            {%- else %}
              role="link" aria-disabled="true"
            {%- endif %}
          >
            {{- section.settings.button_label | escape -}}
          </a>
        {%- endif -%}
      </div>

      <div class="dc_tat__image-wrapper">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1400
            | image_tag:
              loading: 'lazy',
              widths: '400, 600, 800, 1000, 1200, 1400',
              sizes: '(max-width: 749px) 100vw, 50vw',
              is: 'lazy-image'
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "📼 Trust & Testing",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Every batch tested, see our results"
    },
    {
      "type": "text",
      "id": "subtitle_1",
      "label": "Subtitle 1",
      "default": "Beyond USP"
    },
    {
      "type": "richtext",
      "id": "content_1",
      "label": "Content 1",
      "default": "<p>Did you know many supplements on the market can be contaminated or inaccurately labeled? The U.S. Pharmacopeia (USP) sets the gold standard for testing and verifying pharmaceutical-grade ingredients.</p>"
    },
    {
      "type": "text",
      "id": "subtitle_2",
      "label": "Subtitle 2",
      "default": "2x Testing"
    },
    {
      "type": "richtext",
      "id": "content_2",
      "label": "Content 2",
      "default": "<p>At Troscriptions, we go a step further. Every batch of ingredients is tested 2x for purity and safety. All our test results are publicly available.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Request Certificate of Analysis"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Container border color",
      "default": "#e2e2e2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "📼 Trust & Testing"
    }
  ]
}
{% endschema %}
