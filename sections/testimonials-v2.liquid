{%- liquid
  assign testimonials_content_source = section.settings.testimonials_content_source | default: 'manual'
  assign render_manual_testimonials = false
  if testimonials_content_source == 'manual' or testimonials_content_source == 'both'
    assign render_manual_testimonials = true
  endif

  assign render_metafield_testimonials = false
  if testimonials_content_source == 'metafield' or testimonials_content_source == 'both'
    assign render_metafield_testimonials = true
  endif

  assign testimonials_metafield_source = section.settings.metafield_source_product
  if testimonials_metafield_source == blank
    if product != blank
      assign testimonials_metafield_source = product
    elsif collection != blank
      assign testimonials_metafield_source = collection
    elsif article != blank
      assign testimonials_metafield_source = article
    elsif page != blank
      assign testimonials_metafield_source = page
    endif
  endif

  assign testimonials_metafield_namespace = section.settings.metafield_namespace | default: 'custom' | strip
  assign testimonials_metafield_key = section.settings.metafield_key | default: 'testimonials' | strip

  assign testimonials_metafield_items = blank
  if render_metafield_testimonials and testimonials_metafield_source != blank and testimonials_metafield_namespace != blank and testimonials_metafield_key != blank
    assign testimonials_metafield_items = testimonials_metafield_source.metafields[testimonials_metafield_namespace][testimonials_metafield_key].value
  endif

  assign testimonials_metafield_count = 0
  if testimonials_metafield_items != blank
    assign testimonials_metafield_count = testimonials_metafield_items.count | default: testimonials_metafield_items.size | default: 0
  endif

  assign manual_testimonials_count = 0
  if render_manual_testimonials
    assign manual_testimonials_count = section.blocks.size
  endif

  assign testimonial_count = manual_testimonials_count | plus: testimonials_metafield_count
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
    --testimonial-item-gap: {{ section.settings.card_item_gap | default: 16 }}px;
    --testimonial-slider-margin-top: {{ section.settings.slider_margin_top | default: 0 }}px;
    --testimonial-indicators-margin-top: {{ section.settings.indicators_margin_top | default: 24 }}px;
    --testimonial-image-radius: {{ section.settings.image_border_radius | default: 16 }}px;
    --testimonial-image-shadow: {% if section.settings.enable_image_shadow %}0 1rem 1.5rem 0 rgba(var(--color-foreground), 0.06), 0 0.8rem 2.5rem 0 rgba(var(--color-foreground), 0.1){% else %}none{% endif %};
    --testimonial-author-meta-gap: {{ section.settings.author_meta_gap | default: 4 }}px;
    --testimonial-author-description-size: {{ section.settings.author_description_font_size | default: 14 }}px;
    --subheading-font-size: {{ section.settings.subheading_font_size | default: 20 }}px;
    --subheading-color: {{ section.settings.subheading_color | default: '#6b7280' }};
  }
  {%- if section.settings.hide_images -%}
    #shopify-section-{{ section.id }} .testimonial__list-wrapper {
      display: none;
    }
  {%- endif -%}

  {%- if testimonial_count > 1 -%}
    {%- for index in (1..testimonial_count) -%}
      #shopify-section-{{ section.id }} testimonials-component:has(.testimonial__preview:nth-child({{ index }}).is-selected) .testimonials__indicator:nth-child({{ index }}) {
        opacity: 1;
        background-color: rgb(var(--color-foreground));
      }
    {%- endfor -%}
  {%- endif -%}
{%- endstyle -%}

{{ 'section-testimonials.css' | asset_url | stylesheet_tag }}
{{ 'section-testimonials-v2.css' | asset_url | stylesheet_tag }}
{{ 'component-rating.css' | asset_url | stylesheet_tag }}

<div class='section--padding{% if section.settings.show_divider %} section--divider{% endif %}'>
  <div class='testimonials testimonials--v2 page-width'>
    <div class='title-wrapper{% if section.settings.heading == blank %} title-wrapper--no-heading{% endif %} {{ section.settings.heading_alignment }}'>
      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class='title {{ section.settings.heading_size }}'>
          {%- render 'highlight-text',
            hl_input: section.settings.heading,
            hl_style: section.settings.highlight_style,
            hl_enable: section.settings.enable_highlight,
            hl_animateWrap: true
          -%}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <{{ section.settings.subheading_tag | default: 'p' }} class='testimonials__subheading {{ section.settings.subheading_size | default: 'typeset2' }}'>
          {{ section.settings.subheading }}
        </{{ section.settings.subheading_tag | default: 'p' }}>
      {%- endif -%}
    </div>

    {%- if testimonial_count > 0 -%}
      <svg class='visually-hidden'>
        <defs>
          <clipPath id="testimonial-clip-path" clipPathUnits="objectBoundingBox"><path d="M0.11,0.09 C0.014,0.174,-0.003,0.398,0,0.499 C-0.003,0.618,0.015,0.849,0.125,0.919 C0.235,0.989,0.413,0.997,0.504,0.999 C0.604,0.999,0.719,0.999,0.869,0.924 C0.974,0.849,0.994,0.704,0.999,0.499 C1,0.295,0.984,0.155,0.879,0.075 C0.796,0.011,0.593,-0.003,0.504,0 C0.413,-0.005,0.206,0.006,0.11,0.09"></path></clipPath>
        </defs>
      </svg>
      <testimonials-component
        data-slider='{% if testimonial_count > 1 %}true{% else %}false{% endif %}'
        data-autorotate='{{ section.settings.autorotate }}'
        data-autorotate-speed='{{ section.settings.autorotate_speed | times: 1000 }}'
        style='--block-count: {{ testimonial_count | minus: 1 }};'
      >
        <div class='testimonial__list-wrapper'>
          <div class='testimonial__list' id='Testimonials-{{ section.id }}'>
            {%- assign testimonial_index = 0 -%}
            {%- if render_manual_testimonials -%}
              {%- for block in section.blocks -%}
                {%- assign testimonial_index = testimonial_index | plus: 1 -%}
                <div
                  class='testimonial__item{% if testimonial_index == 1 or testimonial_count == 1 %} is-selected{% endif %}'
                  {{ block.shopify_attributes }}
                >
                  <div class='testimonial__image media-wrapper media-wrapper--small'>
                    {%- if block.settings.image != blank -%}
                      <div class='media media--square'>
                        <img
                          srcset='{{ block.settings.image | image_url: width: 320 }} 1x, {{ block.settings.image | image_url: width: 640 }} 2x'
                          src='{{ block.settings.image | image_url: width: 320 }}'
                          alt='{{ block.settings.image.alt | escape }}'
                          loading='lazy'
                          width='320'
                          height='{{ 320 | divided_by: block.settings.image.aspect_ratio | ceil }}'
                          is='lazy-image'
                        >
                      </div>
                    {%- else -%}
                      <div class='media media--square'>
                        {{ 'image' | placeholder_svg_tag: 'placeholder' }}
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            {%- endif -%}
            {%- if render_metafield_testimonials and testimonials_metafield_count > 0 -%}
              {%- for testimonial_item in testimonials_metafield_items -%}
                {%- liquid
                  assign testimonial_index = testimonial_index | plus: 1
                  assign testimonial_portrait = testimonial_item.portrait.value | default: testimonial_item.portrait | default: testimonial_item.image.value | default: testimonial_item.image
                  assign testimonial_author_name = testimonial_item.author_name.value | default: testimonial_item.author_name | default: testimonial_item.author.value | default: testimonial_item.author
                -%}
                <div class='testimonial__item{% if testimonial_index == 1 or testimonial_count == 1 %} is-selected{% endif %}'>
                  <div class='testimonial__image media-wrapper media-wrapper--small'>
                    {%- if testimonial_portrait != blank -%}
                      <div class='media media--square'>
                        <img
                          srcset='{{ testimonial_portrait | image_url: width: 320 }} 1x, {{ testimonial_portrait | image_url: width: 640 }} 2x'
                          src='{{ testimonial_portrait | image_url: width: 320 }}'
                          alt='{{ testimonial_portrait.alt | default: testimonial_author_name | escape }}'
                          loading='lazy'
                          width='320'
                          height='{{ 320 | divided_by: testimonial_portrait.aspect_ratio | ceil }}'
                          is='lazy-image'
                        >
                      </div>
                    {%- else -%}
                      <div class='media media--square'>
                        {{ 'image' | placeholder_svg_tag: 'placeholder' }}
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>
        <div class='testimonial__previews'>
          {%- if render_manual_testimonials -%}
            {%- for block in section.blocks -%}
              <div class='testimonial__preview'>
                <blockquote class='testimonial__blockquote'>
                  {%- if block.settings.icon != 'none' -%}
                    {%- if block.settings.icon == 'quote' -%}
                      <div class='quote-icon'>
                        <svg aria-hidden='true' focusable='false' class='icon icon-quote' viewBox='0 0 41 35'>
                          <path d="M10.208 17.711h6.124v16.332H0V21.684C0 8.184 5.444.956 16.332 0v6.125c-4.083 1.14-6.124 4.414-6.124 9.82v1.766zm24.498 0h6.124v16.332H24.498V21.684C24.498 8.184 29.942.956 40.83 0v6.125c-4.083 1.14-6.124 4.414-6.124 9.82v1.766z" fill="currentColor" fill-rule="evenodd"/>
                        </svg>
                      </div>
                    {%- else -%}
                      <div
                        class='rating'
                        role='img'
                        aria-label='{{ 'accessibility.rating_stars' | t: rating: block.settings.icon }}'
                      >
                        <span
                          aria-hidden='true'
                          class='rating-star'
                          style='--rating: {{ block.settings.icon }};--rating-max: 5;--rating-decimal: 0;'
                        ></span>
                      </div>
                    {%- endif -%}
                  {%- endif -%}

                  {%- if block.settings.text != blank -%}
                    <div class='rte typeset2'>
                      {%- render 'highlight-text',
                        hl_input: block.settings.text,
                        hl_style: block.settings.highlight_style,
                        hl_enable: block.settings.enable_highlight,
                        hl_animateWrap: true
                      -%}
                    </div>
                  {%- endif -%}

                  {%- if block.settings.author != blank or block.settings.author_description != blank -%}
                    <div class='testimonial__author-group'>
                      {%- if block.settings.author != blank -%}
                        <cite class='testimonial__author'>
                          {%- render 'highlight-text',
                            hl_input: block.settings.author,
                            hl_style: block.settings.highlight_style,
                            hl_enable: block.settings.enable_highlight,
                            hl_animateWrap: true
                          -%}
                        </cite>
                      {%- endif -%}
                      {%- if block.settings.author_description != blank -%}
                        <div class='testimonial__author-description'>
                          {%- render 'highlight-text',
                            hl_input: block.settings.author_description,
                            hl_style: block.settings.highlight_style,
                            hl_enable: block.settings.enable_highlight,
                            hl_animateWrap: true
                          -%}
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </blockquote>
              </div>
            {%- endfor -%}
          {%- endif -%}
          {%- if render_metafield_testimonials and testimonials_metafield_count > 0 -%}
            {%- for testimonial_item in testimonials_metafield_items -%}
              {%- liquid
                assign testimonial_author_name = testimonial_item.author_name.value | default: testimonial_item.author_name | default: testimonial_item.author.value | default: testimonial_item.author
                assign testimonial_author_title = testimonial_item.author_title.value | default: testimonial_item.author_title | default: testimonial_item.author_description.value | default: testimonial_item.author_description
                assign testimonial_quote_field = testimonial_item.quote
                assign testimonial_quote_value = testimonial_item.quote.value | default: testimonial_item.quote | default: testimonial_item.text.value | default: testimonial_item.text
              -%}
              <div class='testimonial__preview'>
                <blockquote class='testimonial__blockquote'>
                  {%- if section.settings.metafield_icon != 'none' -%}
                    {%- if section.settings.metafield_icon == 'quote' -%}
                      <div class='quote-icon'>
                        <svg aria-hidden='true' focusable='false' class='icon icon-quote' viewBox='0 0 41 35'>
                          <path d="M10.208 17.711h6.124v16.332H0V21.684C0 8.184 5.444.956 16.332 0v6.125c-4.083 1.14-6.124 4.414-6.124 9.82v1.766zm24.498 0h6.124v16.332H24.498V21.684C24.498 8.184 29.942.956 40.83 0v6.125c-4.083 1.14-6.124 4.414-6.124 9.82v1.766z" fill="currentColor" fill-rule="evenodd"/>
                        </svg>
                      </div>
                    {%- else -%}
                      <div
                        class='rating'
                        role='img'
                        aria-label='{{ 'accessibility.rating_stars' | t: rating: section.settings.metafield_icon }}'
                      >
                        <span
                          aria-hidden='true'
                          class='rating-star'
                          style='--rating: {{ section.settings.metafield_icon }};--rating-max: 5;--rating-decimal: 0;'
                        ></span>
                      </div>
                    {%- endif -%}
                  {%- endif -%}

                  {%- if testimonial_quote_value != blank -%}
                    <div class='rte typeset2'>
                      {%- if testimonial_quote_field != blank and testimonial_quote_field.value != blank -%}
                        {{ testimonial_quote_field | metafield_tag }}
                      {%- else -%}
                        {{ testimonial_quote_value }}
                      {%- endif -%}
                    </div>
                  {%- endif -%}

                  {%- if testimonial_author_name != blank or testimonial_author_title != blank -%}
                    <div class='testimonial__author-group'>
                      {%- if testimonial_author_name != blank -%}
                        <cite class='testimonial__author'>{{ testimonial_author_name | escape }}</cite>
                      {%- endif -%}
                      {%- if testimonial_author_title != blank -%}
                        <div class='testimonial__author-description'>{{ testimonial_author_title | escape }}</div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </blockquote>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
        {%- if testimonial_count > 1 and section.settings.autorotate == false -%}
          <div class='testimonials__indicators' aria-hidden='true'>
            {%- for index in (1..testimonial_count) -%}
              <span class='testimonials__indicator'></span>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </testimonials-component>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Testimonials (v2)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "autorotate",
      "default": false,
      "label": "t:sections.testimonials.settings.autorotate.label"
    },
    {
      "type": "range",
      "id": "autorotate_speed",
      "label": "t:sections.testimonials.settings.autorotate_speed.label",
      "max": 9,
      "min": 3,
      "step": 2,
      "unit": "t:sections.testimonials.settings.autorotate_speed.unit",
      "default": 5
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "header",
      "content": "Testimonial source"
    },
    {
      "type": "select",
      "id": "testimonials_content_source",
      "options": [
        {
          "value": "manual",
          "label": "Manual blocks"
        },
        {
          "value": "metafield",
          "label": "Metafield only"
        },
        {
          "value": "both",
          "label": "Manual + metafield"
        }
      ],
      "default": "manual",
      "label": "Testimonial content source"
    },
    {
      "type": "product",
      "id": "metafield_source_product",
      "label": "Metafield source product",
      "info": "If empty, uses current page object."
    },
    {
      "type": "text",
      "id": "metafield_namespace",
      "label": "Metafield namespace",
      "default": "custom"
    },
    {
      "type": "text",
      "id": "metafield_key",
      "label": "Metafield key",
      "default": "testimonials"
    },
    {
      "type": "select",
      "id": "metafield_icon",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "quote",
          "label": "Quote"
        },
        {
          "value": "5",
          "label": "5 stars"
        },
        {
          "value": "4",
          "label": "4 stars"
        },
        {
          "value": "3",
          "label": "3 stars"
        },
        {
          "value": "2",
          "label": "2 stars"
        },
        {
          "value": "1",
          "label": "1 star"
        }
      ],
      "default": "quote",
      "label": "Metafield testimonial icon"
    },
    {
      "type": "range",
      "id": "card_item_gap",
      "label": "Card item gap",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "slider_margin_top",
      "label": "Slider top margin",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "indicators_margin_top",
      "label": "Indicators top margin",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 24
