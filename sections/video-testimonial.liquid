{%- liquid
  assign uploaded_video = section.settings.video
  assign thumbnail = section.settings.thumbnail | default: uploaded_video.preview_image
  assign title_tag = section.settings.title_tag
-%}

{%- style -%}
    #shopify-section-{{ section.id }} .dc_video-testimonial-section {
    	padding: 56px 0;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-shell {
    	max-width: 1320px;
    	margin: 0 auto;
    	padding: 0 16px;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-title {
    	margin: 0 0 30px;
    	text-align: center;
    	font-size: 28px;
    	line-height: 1.08;
    	font-weight: 600;
    	color: #1d1d1f;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-grid {
    	display: grid;
    	grid-template-columns: minmax(0, 1fr);
    	gap: 40px;
    	align-items: center;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-media {
    	order: 1;
    	width: min(100%, 345px);
    	margin: 0 auto;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-content {
   padding: 0px 40px 40px 40px;
    	order: 2;
    	width: 100%;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-author {
    	display: flex;
    	align-items: center;
    	gap: 20px;
    	margin-bottom: 20px;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-author-image {
    	width: 50px;
    	height: 50px;
    	border-radius: 999px;
    	overflow: hidden;
    	flex: 0 0 50px;
    	background-color: #f5f5f5;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-author-image img {
    	display: block;
    	width: 100%;
    	height: 100%;
    	object-fit: contain;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-author-text {
    	min-width: 0;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-author-name {
    	margin: 0;
    	font-size: 17px;
    	line-height: 1.2;
    	font-weight: 400;
    	color: #1d1d1f;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-author-description {
    	margin: 4px 0 0;
    	font-size: 13px;
    	line-height: 1.35;
    	font-weight: 400;
    	color: #3f3f46;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-quote {
    	margin: 0;
    	font-family: "New York", "Iowan Old Style", "Apple Garamond", Baskerville, "Times New Roman", "Droid Serif", Times, "Source Serif Pro", serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    	font-size: 22px;
    	line-height: 1.12;
    	font-weight: 400;
    	color: #1d1d1f;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-video-wrap {
    	position: relative;
    	width: 100%;
    	overflow: hidden;
    	background-color: #000000;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-video {
    	display: block;
    	width: 100%;
    	height: auto;
    	background-color: #000000;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-overlay {
    	position: absolute;
    	inset: 0;
    	display: flex;
    	align-items: center;
    	justify-content: center;
    	cursor: pointer;
    	border: 0;
    	padding: 0;
    	background: transparent;
    	transition: opacity 0.2s ease, visibility 0.2s ease;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-overlay.is-hidden {
    	opacity: 0;
    	visibility: hidden;
    	pointer-events: none;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-thumbnail {
    	position: absolute;
    	inset: 0;
    	width: 100%;
    	height: 100%;
    	object-fit: cover;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-overlay::after {
    	content: '';
    	position: absolute;
    	inset: 0;
    	background: linear-gradient(180deg, rgba(0, 0, 0, 0.06) 0%, rgba(0, 0, 0, 0.12) 100%);
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-play-button {
    	position: relative;
    	z-index: 1;
    	display: inline-flex;
    	align-items: center;
    	justify-content: center;
    	width: 72px;
    	height: 72px;
    	border: 0;
    	border-radius: 999px;
    	padding: 0;
    	color: #111111;
    	background: rgba(255, 255, 255, 0.82);
    	box-shadow: 0 10px 30px rgba(0, 0, 0, 0.16);
    	transition: transform 0.2s ease, background-color 0.2s ease;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-overlay:hover .dc_video-testimonial-play-button,
    #shopify-section-{{ section.id }} .dc_video-testimonial-overlay:focus-visible .dc_video-testimonial-play-button {
    	transform: scale(1.06);
    	background: rgba(255, 255, 255, 0.9);
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-play-icon {
    	display: block;
    	width: 26px;
    	height: 26px;
    }

    #shopify-section-{{ section.id }} .dc_video-testimonial-placeholder {
    	display: flex;
    	align-items: center;
    	justify-content: center;
    	aspect-ratio: 9 / 16;
    	width: 100%;
    	font-size: 14px;
    	color: #ffffff;
    	background: #1d1d1f;
    }

    @media screen and (min-width: 990px) {
    	#shopify-section-{{ section.id }} .dc_video-testimonial-section {
    		padding: 96px 0;
    	}

    	#shopify-section-{{ section.id }} .dc_video-testimonial-shell {
    		padding: 0 24px;
    	}

    	#shopify-section-{{ section.id }} .dc_video-testimonial-title {
    		font-size: 63px;
    	}

    	#shopify-section-{{ section.id }} .dc_video-testimonial-grid {
    		grid-template-columns: minmax(0, 1fr) minmax(0, 640px);
    		gap: 50px;
    	}

    	#shopify-section-{{ section.id }} .dc_video-testimonial-media {
    		order: 2;
    		width: 100%;
    		max-width: 640px;
    	}

    	#shopify-section-{{ section.id }} .dc_video-testimonial-content {
    		order: 1;
    		max-width: 560px;
    		justify-self: end;
   	padding:0px;
    	}

  #shopify-section-{{ section.id }} .dc_video-testimonial-author-image {
  	width: 70px;
    	height: 70px;
  flex: 0 0 70px;
   }

    	#shopify-section-{{ section.id }} .dc_video-testimonial-author-name {
    		font-size: 19px;
    	}

    	#shopify-section-{{ section.id }} .dc_video-testimonial-author-description {
    		font-size: 15px;
    	}

    	#shopify-section-{{ section.id }} .dc_video-testimonial-quote {
    		font-size: 30px;
    	}
    }
{%- endstyle -%}

<section class="dc_video-testimonial-section">
  <div class="dc_video-testimonial-shell">
    {%- if section.settings.show_title and section.settings.title != blank -%}
      <{{ title_tag }} class="dc_video-testimonial-title">{{ section.settings.title | escape }}</{{ title_tag }}>
    {%- endif -%}

    <div class="dc_video-testimonial-grid">
      <div class="dc_video-testimonial-content">
        {%- if section.settings.author_name != blank
          or section.settings.author_description != blank
          or section.settings.author_image != blank
        -%}
          <div class="dc_video-testimonial-author">
            {%- if section.settings.author_image != blank -%}
              <div class="dc_video-testimonial-author-image">
                {{
                  section.settings.author_image
                  | image_url: width: 140
                  | image_tag: loading: 'lazy', widths: '70, 140', sizes: '70px', alt: section.settings.author_name
                  | escape
                }}
              </div>
            {%- endif -%}

            <div class="dc_video-testimonial-author-text">
              {%- if section.settings.author_name != blank -%}
                <p class="dc_video-testimonial-author-name">{{ section.settings.author_name | escape }}</p>
              {%- endif -%}

              {%- if section.settings.author_description != blank -%}
                <p class="dc_video-testimonial-author-description">
                  {{ section.settings.author_description | escape }}
                </p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.testimonial != blank -%}
          <p class="dc_video-testimonial-quote">{{ section.settings.testimonial | escape | newline_to_br }}</p>
        {%- endif -%}
      </div>

      <div class="dc_video-testimonial-media">
        {%- if uploaded_video != blank -%}
          <div class="dc_video-testimonial-video-wrap" data-dc-video-testimonial>
            <video
              class="dc_video-testimonial-video"
              playsinline
              webkit-playsinline
              preload="metadata"
              {% if section.settings.show_controls %}
                controls
              {% endif %}
              {% if thumbnail != blank %}
                poster="{{ thumbnail | image_url: width: 1280 }}"
              {% endif %}
            >
              {%- for source in uploaded_video.sources -%}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {%- endfor -%}
            </video>

            {%- if thumbnail != blank -%}
              <button class="dc_video-testimonial-overlay" type="button" aria-label="Play video" data-dc-video-trigger>
                {{
                  thumbnail
                  | image_url: width: 1280
                  | image_tag:
                    loading: 'lazy',
                    widths: '345, 690, 960, 1280',
                    sizes: '(min-width: 990px) 640px, 345px',
                    class: 'dc_video-testimonial-thumbnail',
                    alt: section.settings.title
                  | escape
                }}
                <span class="dc_video-testimonial-play-button">
                  {% render 'svg-icon-play', class: 'dc_video-testimonial-play-icon' %}
                </span>
              </button>
            {%- else -%}
              <button class="dc_video-testimonial-overlay" type="button" aria-label="Play video" data-dc-video-trigger>
                <span class="dc_video-testimonial-play-button">
                  {% render 'svg-icon-play', class: 'dc_video-testimonial-play-icon' %}
                </span>
              </button>
            {%- endif -%}
          </div>
        {%- elsif thumbnail != blank -%}
          <div class="dc_video-testimonial-video-wrap">
            {{
              thumbnail
              | image_url: width: 1280
              | image_tag:
                loading: 'lazy',
                widths: '345, 690, 960, 1280',
                sizes: '(min-width: 990px) 640px, 345px',
                class: 'dc_video-testimonial-video',
                alt: section.settings.title
              | escape
            }}
          </div>
        {%- else -%}
          <div class="dc_video-testimonial-placeholder">Add a video or thumbnail</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const sectionRoot = document.getElementById('shopify-section-{{ section.id }}');

    if (!sectionRoot) return;

    const videoWrap = sectionRoot.querySelector('[data-dc-video-testimonial]');
    if (!videoWrap) return;

    const video = videoWrap.querySelector('video');
    const trigger = videoWrap.querySelector('[data-dc-video-trigger]');

    if (!video || !trigger) return;

    const hideOverlay = () => trigger.classList.add('is-hidden');
    const showOverlay = () => trigger.classList.remove('is-hidden');

    trigger.addEventListener('click', () => {
      hideOverlay();
      video.play();
    });

    video.addEventListener('play', hideOverlay);
    video.addEventListener('ended', showOverlay);
  })();
</script>

{% schema %}
{
  "name": "Video testimonial",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Endorsed by Thomas DeLauer"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show section title",
      "default": true
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Title tag",
      "default": "h2",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        }
      ]
    },
    {
      "type": "image_picker",
      "id": "author_image",
      "label": "Author profile picture"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author name",
      "default": "Thomas DeLauer"
    },
    {
      "type": "text",
      "id": "author_description",
      "label": "Author description",
      "default": "Nutrition and Business Performance Coach"
    },
    {
      "type": "textarea",
      "id": "testimonial",
      "label": "Author testimonial",
      "default": "My eyes have been opened to methylene blue. I honestly was skeptical at first. That's the honest truth."
    },
    {
      "type": "image_picker",
      "id": "thumbnail",
      "label": "Video thumbnail"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show video controls",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Video testimonial"
    }
  ]
}
{% endschema %}
