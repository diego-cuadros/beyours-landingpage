{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}
{{ 'section-professional-endorsements.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>
<script src="{{ 'section-multicolumn-review.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --professional-endorsements-background: {{ section.settings.background_color.red }}, {{ section.settings.background_color.green }}, {{ section.settings.background_color.blue }};
    --professional-endorsements-card-surface: {{ section.settings.card_surface.red }}, {{ section.settings.card_surface.green }}, {{ section.settings.card_surface.blue }};
    --professional-endorsements-card-border: {{ section.settings.card_border_color.red }}, {{ section.settings.card_border_color.green }}, {{ section.settings.card_border_color.blue }};
    --professional-endorsements-heading: {{ section.settings.heading_color.red }}, {{ section.settings.heading_color.green }}, {{ section.settings.heading_color.blue }};
    --professional-endorsements-eyebrow: {{ section.settings.eyebrow_color.red }}, {{ section.settings.eyebrow_color.green }}, {{ section.settings.eyebrow_color.blue }};
    --professional-endorsements-name: {{ section.settings.name_color.red }}, {{ section.settings.name_color.green }}, {{ section.settings.name_color.blue }};
    --professional-endorsements-role: {{ section.settings.role_color.red }}, {{ section.settings.role_color.green }}, {{ section.settings.role_color.blue }};
    --professional-endorsements-text: {{ section.settings.text_color.red }}, {{ section.settings.text_color.green }}, {{ section.settings.text_color.blue }};
    --professional-endorsements-max-width: {{ section.settings.max_content_width }}px;
    --professional-endorsements-card-gap: {{ section.settings.card_gap }}px;
    --professional-endorsements-card-radius: {{ section.settings.card_radius }}px;
    --professional-endorsements-image-radius: {{ section.settings.image_radius }}px;
    --professional-endorsements-card-padding: {{ section.settings.card_padding }}px;
    --professional-endorsements-subheading-font-size: {{ section.settings.subheading_font_size | default: 20 }}px;
    --professional-endorsements-subheading-color: {{ section.settings.subheading_color | default: '#6b7280' }};
    --card-border-radius: {{ section.settings.card_radius }}px;
    --image-position: {{ section.settings.image_position }};
    --professional-endorsements-dots-gap-mobile: {{ section.settings.mobile_indicator_gap | default: 12 }}px;
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
  }
{%- endstyle -%}

{%- liquid
  assign enable_mobile_carousel = false
  if section.blocks.size > 1
    assign enable_mobile_carousel = true
  endif

  if section.settings.image_ratio == 'adapt'
    assign highest_ratio = 0
    for block in section.blocks
      if block.settings.image != blank and block.settings.image.aspect_ratio > highest_ratio
        assign highest_ratio = block.settings.image.aspect_ratio
      endif
    endfor
  endif
-%}

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <section
    class="multicolumn professional-endorsements page-width"
    aria-label="{{ section.settings.accessibility_label | default: section.settings.heading | strip_html | escape }}"
  >
    <div class="professional-endorsements__inner">
      {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
        <div class="title-wrapper professional-endorsements__header{% if section.settings.heading == blank %} title-wrapper--no-heading{% endif %} mobile-{{ section.settings.mobile_text_alignment }} {{ section.settings.heading_alignment }}">
          {%- if section.settings.eyebrow != blank -%}
            <p class="professional-endorsements__eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <{{ section.settings.heading_tag }} class="title {{ section.settings.heading_size }} professional-endorsements__heading">
              {%- render 'highlight-text',
                hl_input: section.settings.heading,
                hl_style: section.settings.highlight_style,
                hl_enable: section.settings.enable_highlight,
                hl_animateWrap: true
              -%}
            </{{ section.settings.heading_tag }}>
          {%- endif -%}

          {%- if section.settings.subheading != blank -%}
            <{{ section.settings.subheading_tag }} class="professional-endorsements__subheading {{ section.settings.subheading_size }}">
              {{ section.settings.subheading }}
            </{{ section.settings.subheading_tag }}>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <multicolumn-review-component class="slider-mobile-gutter professional-endorsements__component" data-match-card-heights-mobile="{{ section.settings.match_card_heights_mobile }}">
          <div class="professional-endorsements__track-wrapper">
            <ul
              id="Slider-{{ section.id }}"
              class="multicolumn-list professional-endorsements__grid flex-grid flex-grid--2-col{% if section.settings.columns_mobile == '1' %} flex-grid--1-col-mobile{% endif %} flex-grid--rigid flex-grid--{{ section.settings.columns_desktop }}-col-desktop{% if enable_mobile_carousel %} slider slider--mobile{% endif %}"
              role="list"
            >
              {%- for block in section.blocks -%}
                {%- liquid
                  assign number_of_columns = section.settings.columns_desktop
                  assign number_of_columns_mobile = section.settings.columns_mobile
                  assign desktop_gap_space = number_of_columns | minus: 1 | times: section.settings.card_gap
                  assign tablet_gap_space = number_of_columns_mobile | minus: 1 | times: section.settings.card_gap
                  assign grid_space_desktop = desktop_gap_space | plus: 100 | append: 'px'
                  assign grid_space_tablet = tablet_gap_space | plus: 100 | append: 'px'
                  assign grid_space_mobile = 30 | append: 'px'
                -%}
                {% capture sizes %}
                  (min-width: {{ settings.page_width }}px) calc(({{ settings.page_width }}px - {{ grid_space_desktop }}) / {{ number_of_columns }}),
                  (min-width: 990px) calc((100vw - {{ grid_space_desktop }}) / {{ number_of_columns }}),
                  (min-width: 750px) calc((100vw - {{ grid_space_tablet }}) / {{ number_of_columns_mobile }}),
                  calc(100vw - {{ grid_space_mobile }})
                {% endcapture %}
                <li
                  id="Slide-{{ section.id }}-{{ forloop.index }}"
                  class="multicolumn-list__item professional-endorsements__item flex-grid__item left{% if enable_mobile_carousel %} slider__slide{% endif %}{% if forloop.first %} is-selected{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  <article
                    class="multicolumn-card professional-endorsements__card"
                    {% if block.settings.background_color != blank %}style="background-color: {{ block.settings.background_color }};"{% endif %}
                  >
                    <use-animate
                      data-animate="zoom-fade"
                      class="media-wrapper multicolumn-card__image-wrapper multicolumn-card__image-wrapper--full-width professional-endorsements__media-wrapper"
                    >
                      <div
                        class="image-animate media media--{{ section.settings.image_ratio }} professional-endorsements__media"
                        {%- if section.settings.image_ratio == 'adapt' and highest_ratio > 0 %} style="--image-ratio-percent: {{ 1 | divided_by: highest_ratio | times: 100 }}%;"{% endif -%}
                      >
                        {%- if block.settings.image != blank -%}
                          {%- liquid
                            if forloop.first
                              assign img_loading = 'eager'
                              assign img_fetchpriority = 'auto'
                            else
                              assign img_loading = 'lazy'
                              assign img_fetchpriority = nil
                            endif
                          -%}
                          {{
                            block.settings.image
                            | image_url: width: 1600
                            | image_tag:
                              loading: img_loading,
                              fetchpriority: img_fetchpriority,
                              widths: '240, 320, 400, 520, 640, 760, 900, 1100, 1400, 1600',
                              sizes: sizes,
                              class: 'multicolumn-card__image professional-endorsements__image',
                              is: 'lazy-image',
                              alt: block.settings.image.alt | default: block.settings.name | escape
                          }}
                        {%- else -%}
                          {{ 'image' | placeholder_svg_tag: 'multicolumn-card__image professional-endorsements__image professional-endorsements__image--placeholder placeholder-svg' }}
                        {%- endif -%}
                      </div>
                    </use-animate>

                    <div class="multicolumn-card__info professional-endorsements__content">
                      {%- if block.settings.name != blank -%}
                        <p class="multicolumn-card__title professional-endorsements__name h4">{{ block.settings.name | escape }}</p>
                      {%- endif -%}

                      {%- if block.settings.role != blank -%}
                        <div class="professional-endorsements__role">{{ block.settings.role | escape | newline_to_br }}</div>
                      {%- endif -%}

                      {%- if block.settings.quote != blank -%}
                        <blockquote class="professional-endorsements__quote">{{ block.settings.quote | escape | newline_to_br }}</blockquote>
                      {%- endif -%}
                    </div>
                  </article>
                </li>
              {%- endfor -%}
            </ul>
          </div>

          {%- if enable_mobile_carousel -%}
            <div
              class="professional-endorsements__dots no-js-hidden medium-hide large-up-hide"
              role="tablist"
              aria-label="{{ section.settings.accessibility_label | default: section.settings.heading | strip_html | escape }}"
            >
              {%- for block in section.blocks -%}
                <button
                  type="button"
                  role="tab"
                  class="multicolumn-review__dot{% if forloop.first %} is-active{% endif %}"
                  data-slide-index="{{ forloop.index }}"
                  aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ section.blocks.size }}"
                  aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
                ></button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </multicolumn-review-component>
      {%- elsif request.design_mode -%}
        <div class="professional-endorsements__empty">
          Add endorsement blocks to populate this section.
        </div>
      {%- endif -%}
    </div>
  </section>
</div>

{% schema %}
{
