        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "div",
          "label": "Div"
        },
        {
          "value": "p",
          "label": "Paragraph"
        }
      ],
      "default": "h2"
