      "default": "p",
      "label": "Subheading tag"
    },
    {
      "type": "select",
      "id": "subheading_size",
      "options": [
        {
          "value": "typeset",
          "label": "Small"
        },
        {
          "value": "typeset2",
          "label": "Medium"
        },
        {
          "value": "typeset3",
          "label": "Large"
        }
      ],
      "default": "typeset2",
      "label": "Subheading size"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
