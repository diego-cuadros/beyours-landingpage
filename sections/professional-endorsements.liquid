          "label": "Center top"
        },
        {
          "value": "80% 0",
          "label": "Right top"
        },
        {
          "value": "20% 50%",
          "label": "Left center"
        },
        {
          "value": "center center",
          "label": "Center"
        },
        {
          "value": "80% 50%",
          "label": "Right center"
        },
        {
          "value": "20% 100%",
          "label": "Left bottom"
        },
        {
          "value": "bottom center",
          "label": "Center bottom"
