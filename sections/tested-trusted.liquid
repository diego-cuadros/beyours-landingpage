{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --tested-trusted-background: {{ section.settings.background_color }};
    --tested-trusted-heading-color: {{ section.settings.heading_color }};
    --tested-trusted-text-color: {{ section.settings.text_color }};
    --tested-trusted-subheading-color: {{ section.settings.subheading_color }};
    --color-highlight: {{ section.settings.accent_color.red }}, {{ section.settings.accent_color.green }}, {{ section.settings.accent_color.blue }};
    --tested-trusted-icon-color: {{ section.settings.icon_color }};
    --tested-trusted-content-width: {{ section.settings.content_max_width }}px;
    --tested-trusted-media-width: {{ section.settings.image_max_width }}px;
    --tested-trusted-full-width-max-content: {{ section.settings.full_width_max_content_width }}px;
    --tested-trusted-media-height-mobile: {{ section.settings.image_height_mobile }}px;
    --tested-trusted-media-height-desktop: {{ section.settings.image_height_desktop }}px;
    --tested-trusted-image-radius: {{ section.settings.image_radius }}px;
    --tested-trusted-image-fit: {{ section.settings.image_fit }};
    --tested-trusted-image-position: {{ section.settings.image_position }};
  }
{%- endstyle -%}

{{ 'section-tested-trusted.css' | asset_url | stylesheet_tag }}

{%- capture sizes -%}
  (min-width: {{ settings.page_width }}px) {{ section.settings.image_max_width }}px,
  (min-width: 990px) 44vw,
  100vw
{%- endcapture -%}

<div class="tested-trusted{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full-width{% endif %}">
    <div class="tested-trusted__inner tested-trusted__inner--image-{{ section.settings.image_side }} section--padding">
      <div class="tested-trusted__content">
        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="tested-trusted__heading">
            {%- render 'highlight-text',
              hl_input: section.settings.heading,
              hl_style: section.settings.highlight_style,
              hl_enable: section.settings.enable_highlight,
              hl_animateWrap: true
            -%}
          </{{ section.settings.heading_tag }}>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="tested-trusted__body rte">
            {{ section.settings.body }}
          </div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul class="tested-trusted__list" role="list">
            {%- for block in section.blocks -%}
              <li
                class="tested-trusted__item"
                style="--tested-trusted-icon-width: {{ block.settings.icon_width }}px; --tested-trusted-icon-width-mobile: {{ block.settings.icon_width_mobile }}px;"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.custom_svg != blank or block.settings.custom_icon != blank or block.settings.icon != 'none' -%}
                  <span class="tested-trusted__icon" aria-hidden="true">
                    {%- if block.settings.custom_svg != blank -%}
                      {{ block.settings.custom_svg }}
                    {%- elsif block.settings.custom_icon != blank -%}
                    {{
                        block.settings.custom_icon
                        | image_url: width: 240
                        | image_tag:
                          loading: 'lazy',
                          widths: '80, 120, 160, 240',
                          sizes: '80px',
                          alt: ''
                      }}
                    {%- else -%}
                      {%- render 'product-trust-point-icon', icon: block.settings.icon -%}
                    {%- endif -%}
                  </span>
                {%- endif -%}

                <div class="tested-trusted__copy rte">
                  {{ block.settings.text }}
                </div>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <div class="tested-trusted__media">
        <div class="tested-trusted__media-frame">
          {%- if section.settings.image != blank -%}
            {%- if section.settings.image_mobile != blank -%}
              {{
                section.settings.image_mobile
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  class: 'tested-trusted__image medium-hide large-up-hide',
                  sizes: sizes,
                  widths: '360, 540, 720, 960, 1200',
                  is: 'lazy-image'
              }}
              {{
                section.settings.image
                | image_url: width: 1800
                | image_tag:
                  loading: 'lazy',
                  class: 'tested-trusted__image small-hide',
                  sizes: sizes,
                  widths: '540, 720, 960, 1200, 1500, 1800',
                  is: 'lazy-image'
              }}
            {%- else -%}
              {{
                section.settings.image
                | image_url: width: 1800
                | image_tag:
                  loading: 'lazy',
                  class: 'tested-trusted__image',
                  sizes: sizes,
                  widths: '540, 720, 960, 1200, 1500, 1800',
                  is: 'lazy-image'
              }}
            {%- endif -%}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>

