{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --image-trust-points-heading-color: {{ section.settings.heading_color }};
    --image-trust-points-text-color: {{ section.settings.text_color }};
    --image-trust-points-icon-background: {{ section.settings.icon_background_color }};
    --image-trust-points-icon-foreground: {{ section.settings.icon_foreground_color }};
    --image-trust-points-image-position: {{ section.settings.image_position }};
    --color-highlight: {{ section.settings.accent_color.red }}, {{ section.settings.accent_color.green }}, {{ section.settings.accent_color.blue }};
    {%- case section.settings.heading_size -%}
      {%- when 'small' -%}
        --image-trust-points-heading-size: clamp(2.8rem, 3vw, 4rem);
        --image-trust-points-heading-size-mobile: clamp(2.4rem, 6vw, 3.4rem);
      {%- when 'large' -%}
        --image-trust-points-heading-size: clamp(4rem, 4.8vw, 6rem);
        --image-trust-points-heading-size-mobile: clamp(3.2rem, 8.5vw, 4.8rem);
      {%- else -%}
        --image-trust-points-heading-size: clamp(3.4rem, 4vw, 5rem);
        --image-trust-points-heading-size-mobile: clamp(2.8rem, 7.8vw, 4.2rem);
    {%- endcase -%}
  }
{%- endstyle -%}

{{ 'section-image-trust-points.css' | asset_url | stylesheet_tag }}

{%- capture sizes -%}
  (min-width: {{ settings.page_width }}px) 420px,
  (min-width: 750px) calc((100vw - 10rem) * 0.38),
  calc(100vw - 3rem)
{%- endcapture -%}

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="image-trust-points page-width">
    <div class="image-trust-points__inner">
      <div class="image-trust-points__media">
        {%- liquid
          assign image_class = 'image-trust-points__image-frame image-trust-points__image-frame--' | append: section.settings.image_ratio
          assign image_style = ''
          if section.settings.image_ratio == 'adapt' and section.settings.image != blank
            assign image_style = '--image-trust-points-media-ratio: ' | append: section.settings.image.aspect_ratio | append: ';'
          endif
        -%}
        <div class="{{ image_class }}"{% if image_style != blank %} style="{{ image_style }}"{% endif %}>
          {%- if section.settings.image != blank -%}
            {%- if section.settings.image_mobile != blank -%}
              {{ section.settings.image_mobile | image_url: width: 1200 | image_tag:
                loading: 'lazy',
                class: 'image-trust-points__image image-fit medium-hide large-up-hide',
                sizes: sizes,
                widths: '360, 540, 720, 960, 1200',
                is: 'lazy-image'
              }}
              {{ section.settings.image | image_url: width: 1600 | image_tag:
                loading: 'lazy',
                class: 'image-trust-points__image image-fit small-hide',
                sizes: sizes,
                widths: '420, 640, 860, 1100, 1400, 1600',
                is: 'lazy-image'
              }}
            {%- else -%}
              {{ section.settings.image | image_url: width: 1600 | image_tag:
                loading: 'lazy',
                class: 'image-trust-points__image image-fit',
                sizes: sizes,
                widths: '420, 640, 860, 1100, 1400, 1600',
                is: 'lazy-image'
              }}
            {%- endif -%}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>

      <div class="image-trust-points__content">
        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="image-trust-points__heading">
            {%- render 'highlight-text',
              hl_input: section.settings.heading,
              hl_style: section.settings.highlight_style,
              hl_enable: section.settings.enable_highlight,
              hl_animateWrap: true
            -%}
          </{{ section.settings.heading_tag }}>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul class="image-trust-points__list" role="list">
            {%- for block in section.blocks -%}
              <li class="image-trust-points__item" {{ block.shopify_attributes }}>
                {%- if block.settings.custom_svg != blank or block.settings.custom_icon != blank or block.settings.icon != 'none' -%}
                  <span class="image-trust-points__icon" aria-hidden="true">
                    {%- if block.settings.custom_svg != blank -%}
                      {{ block.settings.custom_svg }}
                    {%- elsif block.settings.custom_icon != blank -%}
                      {{
                        block.settings.custom_icon
                        | image_url: width: 72
                        | image_tag:
                          loading: 'lazy',
                          widths: '36, 48, 72',
                          class: 'image-trust-points__icon-image',
                          alt: ''
                      }}
                    {%- else -%}
                      {%- case block.settings.icon -%}
                        {%- when 'doctor' -%}
                          <svg viewBox="0 0 24 24" fill="none">
                            <path d="M14.5 4.5h-5A2.5 2.5 0 0 0 7 7v10a2.5 2.5 0 0 0 2.5 2.5h5A2.5 2.5 0 0 0 17 17V7a2.5 2.5 0 0 0-2.5-2.5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                            <path d="M10 2.5h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                            <path d="M12 9v5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                            <path d="M9.5 11.5H14.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                          </svg>
                        {%- when 'performance' -%}
                          <svg viewBox="0 0 24 24" fill="none">
                            <path d="M2.75 12s3.5-5 9.25-5 9.25 5 9.25 5-3.5 5-9.25 5-9.25-5-9.25-5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                            <circle cx="12" cy="12" r="2.75" stroke="currentColor" stroke-width="1.6"/>
                          </svg>
                        {%- when 'clinic' -%}
                          <svg viewBox="0 0 24 24" fill="none">
                            <rect x="5" y="4.5" width="14" height="15" rx="2" stroke="currentColor" stroke-width="1.6"/>
                            <path d="M12 4.5v15" stroke="currentColor" stroke-width="1.6"/>
                            <path d="M5 10.5h14" stroke="currentColor" stroke-width="1.6"/>
                          </svg>
                        {%- when 'check' -%}
                          <svg viewBox="0 0 24 24" fill="none">
                            <circle cx="12" cy="12" r="8.25" stroke="currentColor" stroke-width="1.6"/>
                            <path d="m8.75 12 2.2 2.2 4.3-4.45" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        {%- else -%}
                          {%- render 'product-trust-point-icon', icon: block.settings.icon -%}
                      {%- endcase -%}
                    {%- endif -%}
                  </span>
                {%- endif -%}

                <div class="image-trust-points__item-text rte">{{ block.settings.text }}</div>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

