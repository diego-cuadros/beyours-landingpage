{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
    --faq-v2-icon-corner-radius: {{ section.settings.icon_corner_radius }}px;
    --faq-v2-question-font-style: {{ section.settings.question_font_style }};
  }
{%- endstyle -%}

{{ 'section-faq.css' | asset_url | stylesheet_tag }}
{{ 'section-faq-v2.css' | asset_url | stylesheet_tag }}

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  {%- if section.settings.secondary_background -%}
    <div class="faq--colored">
  {%- endif -%}
    <div class="faq faq--v2{% if section.settings.use_custom_question_typography %} faq--v2-custom-question-typography{% endif %} page-width{% if section.settings.narrow %} page-width--inner{% endif %}">
      <div class="title-wrapper{% if section.settings.heading == blank %} title-wrapper--no-heading{% endif %} {{ section.settings.heading_alignment }}">
        <{{ section.settings.heading_tag }} class="title {{ section.settings.heading_size }}">
          {%- render 'highlight-text', 
            hl_input: section.settings.heading, 
            hl_style: section.settings.highlight_style,
            hl_enable: section.settings.enable_highlight,
            hl_animateWrap: true -%}
        </{{ section.settings.heading_tag }}>
      </div>

      {%- liquid
        assign faq_content_source = section.settings.faq_content_source | default: 'manual'
        assign render_manual_faq = false
        if faq_content_source == 'manual' or faq_content_source == 'both'
          assign render_manual_faq = true
        endif

        assign render_metafield_faq = false
        if faq_content_source == 'metafield' or faq_content_source == 'both'
          assign render_metafield_faq = true
        endif

        assign faq_metafield_source = section.settings.metafield_source_product
        if faq_metafield_source == blank
          if product != blank
            assign faq_metafield_source = product
          elsif collection != blank
            assign faq_metafield_source = collection
          elsif article != blank
            assign faq_metafield_source = article
          elsif page != blank
            assign faq_metafield_source = page
          endif
        endif

        assign faq_metafield_namespace = section.settings.metafield_namespace | default: 'custom' | strip
        assign faq_metafield_key = section.settings.metafield_key | default: 'faqs' | strip

        assign faq_metafield_items = blank
        if render_metafield_faq and faq_metafield_source != blank and faq_metafield_namespace != blank and faq_metafield_key != blank
          assign faq_metafield_items = faq_metafield_source.metafields[faq_metafield_namespace][faq_metafield_key].value
        endif

        assign faq_metafield_items_count = 0
        if faq_metafield_items != blank
          assign faq_metafield_items_count = faq_metafield_items.count | default: faq_metafield_items.size | default: 0
        endif
      -%}

      {%- if render_manual_faq -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'rich-text' -%}
              <p class="h3" {{ block.shopify_attributes }}>
                {%- render 'highlight-text', 
                  hl_input: block.settings.title, 
                  hl_style: block.settings.highlight_style,
                  hl_enable: block.settings.enable_highlight,
                  hl_animateWrap: true -%}
              </p>
              <div class="rte">
                {%- render 'highlight-text', 
                  hl_input: block.settings.text, 
                  hl_style: block.settings.highlight_style,
                  hl_enable: block.settings.enable_highlight,
                  hl_animateWrap: true -%}
              </div>
            {%- when 'question' -%}
              {%- if block.settings.text != blank -%}
              <accordion-tab {{ block.shopify_attributes }}>
                <details>
                  <summary>
                    <span>
                      <span class="icon icon-plus-alt"></span>
                      <span class="faq-v2__question-text{% if section.settings.use_custom_question_typography %} {{ section.settings.question_heading_size }} faq-v2__question-text--custom{% endif %}">
                        {%- render 'highlight-text', 
                          hl_input: block.settings.title, 
                          hl_style: block.settings.highlight_style,
                          hl_enable: block.settings.enable_highlight,
                          hl_animateWrap: true -%}
                      </span>
                    </span>
                  </summary>
                  <div class="accordion__content rte typeset">
                    {%- render 'highlight-text', 
                      hl_input: block.settings.text, 
                      hl_style: block.settings.highlight_style,
                      hl_enable: block.settings.enable_highlight,
                      hl_animateWrap: true -%}
                  </div>
                </details>
              </accordion-tab>
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if render_metafield_faq and faq_metafield_items_count > 0 -%}
        {%- for faq_item in faq_metafield_items -%}
          {%- liquid
            assign faq_meta_title = faq_item.title.value | default: faq_item.title
            assign faq_meta_richtext_field = faq_item.richtext
            assign faq_meta_text_field = faq_item.text
            assign faq_meta_text_value = faq_item.richtext.value | default: faq_item.text.value | default: faq_item.richtext | default: faq_item.text
          -%}
          {%- if faq_meta_title != blank and faq_meta_text_value != blank -%}
            <accordion-tab>
              <details>
                <summary>
                  <span>
                    <span class="icon icon-plus-alt"></span>
                    <span class="faq-v2__question-text{% if section.settings.use_custom_question_typography %} {{ section.settings.question_heading_size }} faq-v2__question-text--custom{% endif %}">
                      {{ faq_meta_title | escape }}
                    </span>
                  </span>
                </summary>
                <div class="accordion__content rte typeset">
                  {%- if faq_meta_richtext_field != blank -%}
                    {{ faq_meta_richtext_field | metafield_tag }}
                  {%- elsif faq_meta_text_field != blank and faq_meta_text_field.value != blank -%}
                    {{ faq_meta_text_field | metafield_tag }}
                  {%- else -%}
                    {{ faq_meta_text_value }}
                  {%- endif -%}
                </div>
              </details>
            </accordion-tab>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  {%- if section.settings.secondary_background -%}
    </div>
  {%- endif -%}
</div>

{%- assign question_blocks = section.blocks | where: 'type', 'question' -%}
{%- assign has_manual_questions = false -%}
{%- if render_manual_faq and question_blocks.size > 0 -%}
  {%- for block in question_blocks -%}
    {%- if block.settings.title != blank and block.settings.text != blank -%}
      {%- assign has_manual_questions = true -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}
{%- assign has_metafield_questions = false -%}
{%- if render_metafield_faq and faq_metafield_items_count > 0 -%}
  {%- for faq_item in faq_metafield_items -%}
    {%- liquid
      assign faq_meta_title = faq_item.title.value | default: faq_item.title
      assign faq_meta_text_value = faq_item.richtext.value | default: faq_item.text.value | default: faq_item.richtext | default: faq_item.text
    -%}
    {%- if faq_meta_title != blank and faq_meta_text_value != blank -%}
      {%- assign has_metafield_questions = true -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- if has_manual_questions or has_metafield_questions -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- assign faq_schema_item_emitted = false -%}
        {%- if render_manual_faq and question_blocks.size > 0 -%}
          {%- for block in question_blocks -%}
            {%- if block.settings.title != blank and block.settings.text != blank -%}
              {%- if faq_schema_item_emitted -%},{%- endif -%}
              {
                "@type": "Question",
                "name": {{ block.settings.title | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ block.settings.text | strip_html | json }}
                }
              }
              {%- assign faq_schema_item_emitted = true -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
        {%- if render_metafield_faq and faq_metafield_items_count > 0 -%}
          {%- for faq_item in faq_metafield_items -%}
            {%- liquid
              assign faq_meta_title = faq_item.title.value | default: faq_item.title
              assign faq_meta_text_value = faq_item.richtext.value | default: faq_item.text.value | default: faq_item.richtext | default: faq_item.text
            -%}
            {%- if faq_meta_title != blank and faq_meta_text_value != blank -%}
              {%- if faq_schema_item_emitted -%},{%- endif -%}
              {
                "@type": "Question",
                "name": {{ faq_meta_title | strip_html | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ faq_meta_text_value | strip_html | json }}
                }
              }
              {%- assign faq_schema_item_emitted = true -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      ]
    }
  </script>
{%- endif -%}

