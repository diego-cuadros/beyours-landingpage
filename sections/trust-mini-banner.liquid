{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --trust-mini-banner-background: {{ section.settings.background_color.red }}, {{ section.settings.background_color.green }}, {{ section.settings.background_color.blue }};
    --trust-mini-banner-text: {{ section.settings.text_color.red }}, {{ section.settings.text_color.green }}, {{ section.settings.text_color.blue }};
    --color-background: var(--trust-mini-banner-background);
    --color-foreground: var(--trust-mini-banner-text);
    --gradient-background: rgb(var(--trust-mini-banner-background));
    --trust-mini-banner-image-height-desktop: {{ section.settings.desktop_image_height }}px;
    --trust-mini-banner-image-height-mobile: {{ section.settings.mobile_image_height }}px;
    --trust-mini-banner-item-gap: {{ section.settings.item_gap }}px;
    --trust-mini-banner-mobile-item-gap: {{ section.settings.mobile_item_gap }}px;
    --trust-mini-banner-max-content-height: {{ section.settings.max_content_height }}px;
    --trust-mini-banner-mobile-max-content-height: {{ section.settings.mobile_max_content_height }}px;
    --trust-mini-banner-mobile-padding-x: {{ section.settings.mobile_padding_x }}px;
    --trust-mini-banner-mobile-padding-y: {{ section.settings.mobile_padding_y }}px;
    --trust-mini-banner-mobile-item-justify: {% if section.settings.mobile_left_align %}flex-start{% else %}center{% endif %};
    --trust-mini-banner-mobile-item-text-align: {% if section.settings.mobile_left_align %}left{% else %}center{% endif %};
    --trust-mini-banner-columns: {{ section.blocks.size | at_least: 1 }};
  }
{%- endstyle -%}

{{ 'section-trust-mini-banner.css' | asset_url | stylesheet_tag }}

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <section class="trust-mini-banner" aria-label="Trust mini banner">
    <div class="trust-mini-banner__inner page-width page-width--full-width">
      {%- if section.blocks.size > 0 -%}
        <div class="trust-mini-banner__list" role="list">
          {%- for block in section.blocks -%}
            {%- liquid
              assign desktop_image = block.settings.image | default: block.settings.mobile_image
              assign mobile_image = block.settings.mobile_image | default: desktop_image
              assign custom_icon = block.settings.custom_icon
              assign selected_icon = block.settings.icon
              assign desktop_height = section.settings.desktop_image_height
              assign mobile_height = section.settings.mobile_image_height
              assign desktop_icon_height = section.settings.desktop_image_height
              assign desktop_height_2x = desktop_height | times: 2
              assign desktop_width = desktop_height
              assign mobile_height_2x = mobile_height | times: 2
              assign mobile_icon_height = section.settings.mobile_image_height

              if block.settings.desktop_icon_height > 0
                assign desktop_icon_height = block.settings.desktop_icon_height
              endif

              if block.settings.mobile_icon_height > 0
                assign mobile_icon_height = block.settings.mobile_icon_height
              endif

              if desktop_image != blank
                assign desktop_width = desktop_height | times: desktop_image.aspect_ratio | round
              endif
            -%}
            <div
              class="trust-mini-banner__item"
              role="listitem"
              style="--trust-mini-banner-item-icon-height-desktop: {{ desktop_icon_height }}px; --trust-mini-banner-item-icon-height-mobile: {{ mobile_icon_height }}px;"
              {{ block.shopify_attributes }}
            >
              <span class="trust-mini-banner__media" aria-hidden="true">
                {%- if desktop_image != blank -%}
                  <picture>
                    {%- if mobile_image != blank -%}
                      <source
                        media="(max-width: 989px)"
                        srcset="{{ mobile_image | image_url: height: mobile_height }} 1x, {{ mobile_image | image_url: height: mobile_height_2x }} 2x"
                      >
                    {%- endif -%}
                    <img
                      srcset="{{ desktop_image | image_url: height: desktop_height }} 1x, {{ desktop_image | image_url: height: desktop_height_2x }} 2x"
                      src="{{ desktop_image | image_url: height: desktop_height }}"
                      alt=""
                      loading="lazy"
                      width="{{ desktop_width }}"
                      height="{{ desktop_height }}"
                      class="trust-mini-banner__image"
                    >
                  </picture>
                {%- elsif custom_icon != blank -%}
                  <span class="trust-mini-banner__icon">{{ custom_icon }}</span>
                {%- elsif selected_icon != blank and selected_icon != 'none' -%}
                  <span class="trust-mini-banner__icon">
                    {% render 'icon-guarantee', icon: selected_icon %}
                  </span>
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'trust-mini-banner__placeholder placeholder-svg' }}
                {%- endif -%}
              </span>

              {%- if block.settings.text != blank -%}
                <span class="trust-mini-banner__text">{{ block.settings.text | escape }}</span>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

      {%- endif -%}
    </div>
  </section>
</div>

