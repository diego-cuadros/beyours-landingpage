{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --rich-text-v2-max-width: {{ section.settings.content_max_width }}px;
    --rich-text-v2-horizontal-columns: {{ section.settings.horizontal_columns }};
    --rich-text-v2-horizontal-gap: {{ section.settings.horizontal_gap }}px;
    --rich-text-v2-vertical-gap: {{ section.settings.vertical_gap }}px;
    --rich-text-v2-min-height: {{ section.settings.section_min_height }}px;
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
    {%- if section.settings.use_custom_colors %}
      --gradient-background: {% if section.settings.gradient_background != blank %}{{ section.settings.gradient_background }}{% else %}{{ section.settings.colors_background }}{% endif %};
      --color-background: {{ section.settings.colors_background.red }}, {{ section.settings.colors_background.green }}, {{ section.settings.colors_background.blue }};
      --color-foreground: {{ section.settings.colors_text.red }}, {{ section.settings.colors_text.green }}, {{ section.settings.colors_text.blue }};
      --color-link: var(--color-foreground);
      --color-border: var(--color-foreground);
      --color-heading: var(--color-foreground);
      --color-button-background: {{ section.settings.colors_button_background.red }}, {{ section.settings.colors_button_background.green }}, {{ section.settings.colors_button_background.blue }};
      --color-button-text: {{ section.settings.colors_button_label.red }}, {{ section.settings.colors_button_label.green }}, {{ section.settings.colors_button_label.blue }};
      --color-button-border: var(--color-button-background);
    {% endif -%}
  }
{%- endstyle -%}

{{ 'section-rich-text-v2.css' | asset_url | stylesheet_tag }}

<link rel="stylesheet" href="{{ 'component-rte.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>

{%- liquid
  assign page_width_class = ''
  assign content_position = section.settings.content_horizontal_position

  if section.settings.full_width
    assign page_width_class = ' page-width--full-width'
  elsif section.settings.narrow
    assign page_width_class = ' page-width--inner'
  endif

  assign section_class = 'rich-text-v2 section--padding'
  if section.settings.use_custom_colors
    assign section_class = section_class | append: ' rich-text-v2--colored'
  endif

  if section.settings.layout == 'horizontal'
    assign section_class = section_class | append: ' rich-text-v2--horizontal'
  endif

  if section.settings.fill_content_width
    assign section_class = section_class | append: ' rich-text-v2--fill-width'
  endif

  if content_position == 'match_alignment'
    assign content_position = section.settings.text_alignment
  endif

  assign section_class = section_class | append: ' rich-text-v2--position-' | append: content_position
  assign section_class = section_class | append: ' rich-text-v2--content-' | append: section.settings.content_vertical_position
-%}

{%- if section.settings.show_divider %}<div class="section--divider">{% endif -%}
  <div class="page-width{{ page_width_class }}">
    <div class="{{ section_class }}">
      <div class="rich-text-v2__content-shell">
        <div class="rich-text-v2__blocks rich-text-v2__blocks--align-{{ section.settings.text_alignment }} rich-text-v2__blocks--mobile-align-{{ section.settings.mobile_text_alignment }}">
          {%- for block in section.blocks -%}
            {% render 'rich-text-v2-block', block: block, section: section %}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
{%- if section.settings.show_divider %}</div>{% endif -%}

