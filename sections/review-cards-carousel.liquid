      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 52
    },
    {
      "type": "header",
      "content": "Highlight"
    },
    {
      "type": "textarea",
      "id": "highlight_phrases",
      "label": "Heading highlight text",
      "info": "Add one phrase per line.",
      "default": "most-loved formulas"
    },
    {
      "type": "checkbox",
      "id": "enable_highlight",
      "label": "Enable heading highlight",
      "default": false
    },
    {
      "type": "select",
      "id": "highlight_style",
      "label": "Highlight style",
      "options": [
        {
          "value": "marker",
          "label": "Marker"
        },
        {
          "value": "circle",
