<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>

<style>
  #shopify-section-{{ section.id }} .dc_ymal-wrapper {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .dc_ymal-wrapper {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  #shopify-section-{{ section.id }} .dc_ymal-heading {
    text-align: center;
    font-size: 37px;
    font-weight: 500;
    margin: 0 0 3rem 0;
    line-height: 1.2;
  }

  @media only screen and (max-width:769px){
    #shopify-section-{{ section.id }} .dc_ymal-heading {
      font-size: 30px;
    }
  }


  /* ── Card ── */
  #shopify-section-{{ section.id }} .dc_ymal-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 10px;
    border: 1px solid #e1e1e1;
    overflow: hidden;
    background: #fff;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .dc_ymal-card__image-wrap {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 10px 10px 0 0;
  }

  #shopify-section-{{ section.id }} .dc_ymal-card__image-wrap img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .dc_ymal-card__body {
    padding: 16px;
  }

  #shopify-section-{{ section.id }} .dc_ymal-card__title {
    font-size: 17px;
    font-weight: 500;
    margin: 0;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .dc_ymal-card__price {
    font-size: 17px;
    font-weight: 400;
    color: #444;
    margin: 4px 0 0 0;
  }

  /* ── Desktop grid ── */
  #shopify-section-{{ section.id }} .dc_ymal-grid {
    display: none;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .dc_ymal-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }

    #shopify-section-{{ section.id }} .dc_ymal-card__title {
      font-size: 26px;
    }

    #shopify-section-{{ section.id }} .dc_ymal-card__price {
      font-size: 19px;
    }

    #shopify-section-{{ section.id }} .dc_ymal-slider-wrap {
      display: none;
    }
  }

  /* ── Mobile slider ── */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .dc_ymal-grid {
      display: none;
    }

    /* Clip horizontally only — overflow-x: clip doesn't create a scroll container
       so box-shadows below are not clipped */
    #shopify-section-{{ section.id }} .dc_ymal-slider-wrap {
      overflow-x: clip;
      padding-bottom: 6px;
    }

    /* Force each card to exactly 50% — overrides the theme's slider-mobile-gutter
       rule that sets flex-grid--2-col items to 42% to show a peek of the next card */
    #shopify-section-{{ section.id }} .dc_ymal-slider-wrap .flex-grid__item {
      width: calc(50% - var(--grid-horizontal-spacing) / 2);
      min-width: calc(50% - var(--grid-horizontal-spacing) / 2);
    }

    /* Hide the native scrollbar */
    #shopify-section-{{ section.id }} .dc_ymal-slider-wrap .flex-grid {
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    #shopify-section-{{ section.id }} .dc_ymal-slider-wrap .flex-grid::-webkit-scrollbar {
      display: none;
    }
  }

  /* ── Nav (mobile only) ── */
  #shopify-section-{{ section.id }} .dc_ymal-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.2rem;
    margin-top: 2rem;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .dc_ymal-nav {
      display: none;
    }
  }

  #shopify-section-{{ section.id }} .dc_ymal-nav__btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.2s;
  }

  #shopify-section-{{ section.id }} .dc_ymal-nav__btn[disabled] {
    opacity: 0.3;
    cursor: default;
  }

  #shopify-section-{{ section.id }} .dc_ymal-dots {
    display: flex;
    gap: 0.6rem;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .dc_ymal-dot {
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: #d1d5db;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s, width 0.2s;
  }

  #shopify-section-{{ section.id }} .dc_ymal-dot.is-active {
    background: #111;
    width: 2.2rem;
    border-radius: 0.5rem;
  }
</style>

<div class="dc_ymal-wrapper page-width">
  {%- if section.settings.heading != blank -%}
    <h2 class="dc_ymal-heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    {%- comment -%} Desktop grid {%- endcomment -%}
    <ul class="dc_ymal-grid" role="list">
      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}
        <li {{ block.shopify_attributes }}>
          <a
            class="dc_ymal-card"
            href="{{ product.url }}"
            aria-label="{{ product.title | escape }}"
          >
            <div class="dc_ymal-card__image-wrap">
              {%- if product.featured_image != blank -%}
                {{
                  product.featured_image
                  | image_url: width: 600
                  | image_tag: loading: 'lazy', alt: product.featured_image.alt
                }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'dc_ymal-card__placeholder' }}
              {%- endif -%}
            </div>
            <div class="dc_ymal-card__body">
              <p class="dc_ymal-card__title">{{ product.title | escape }}</p>
              <p class="dc_ymal-card__price">
                {%- if product.price_varies -%}
                  From {{ product.price_min | money }}
                {%- else -%}
                  {{ product.price_min | money }}
                {%- endif -%}
              </p>
            </div>
          </a>
        </li>
      {%- endfor -%}
    </ul>

    {%- comment -%} Mobile slider {%- endcomment -%}
    <div class="dc_ymal-slider-wrap">
      <slider-component class="slider-mobile-gutter">
        <ul
          id="Slider-{{ section.id }}"
          class="flex-grid flex-grid--2-col slider slider--mobile"
          role="list"
        >
          {%- for block in section.blocks -%}
            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="flex-grid__item slider__slide"
              {{ block.shopify_attributes }}
            >
              {%- assign product = block.settings.product -%}
              <a
                class="dc_ymal-card"
                href="{{ product.url }}"
                aria-label="{{ product.title | escape }}"
              >
                <div class="dc_ymal-card__image-wrap">
                  {%- if product.featured_image != blank -%}
                    {{
                      product.featured_image
                      | image_url: width: 400
                      | image_tag: loading: 'lazy', alt: product.featured_image.alt
                    }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'dc_ymal-card__placeholder' }}
                  {%- endif -%}
                </div>
                <div class="dc_ymal-card__body">
                  <p class="dc_ymal-card__title">{{ product.title | escape }}</p>
                  <p class="dc_ymal-card__price">
                    {%- if product.price_varies -%}
                      {{ 'products.product.price.from_price_html' | t: price: product.price_min | money }}
                    {%- else -%}
                      {{ product.price_min | money }}
                    {%- endif -%}
                  </p>
                </div>
              </a>
            </li>
          {%- endfor -%}
        </ul>

        {%- if section.blocks.size > 1 -%}
          <div class="dc_ymal-nav no-js-hidden">
            <button
              type="button"
              class="dc_ymal-nav__btn"
              name="previous"
              aria-label="{{ 'general.slider.previous_slide' | t }}"
            >
              <svg fill="none" height="13" viewBox="0 0 8 13" width="8" xmlns="http://www.w3.org/2000/svg">
                <g fill="currentColor"><path d="m7.91419 1.41431-6.48529 6.48528-1.4142102-1.41422 6.4852802-6.48527702z"/><path d="m6.48528 12.9849-6.48528027-6.48532 1.41421027-1.41421 6.48528 6.48523z"/></g>
              </svg>
            </button>

            <div class="dc_ymal-dots" role="tablist">
              {%- for block in section.blocks -%}
                <button
                  type="button"
                  class="dc_ymal-dot{% if forloop.first %} is-active{% endif %}"
                  data-index="{{ forloop.index0 }}"
                  aria-label="Slide {{ forloop.index }}"
                  role="tab"
                ></button>
              {%- endfor -%}
            </div>

            <button
              type="button"
              class="dc_ymal-nav__btn"
              name="next"
              aria-label="{{ 'general.slider.next_slide' | t }}"
            >
              <svg width="9" height="13" viewBox="0 0 9 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0.914169 11.5857L7.39945 5.10041L8.81367 6.51463L2.32838 12.9999L0.914169 11.5857Z" fill="currentColor"/><path d="M2.34307 0.0151367L8.82835 6.50042L7.41414 7.91463L0.928857 1.42935L2.34307 0.0151367Z" fill="currentColor"/>
              </svg>
            </button>
          </div>
        {%- endif -%}
      </slider-component>
    </div>
  {%- endif -%}
</div>

<script>
  (function () {
    const section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    const slider = section.querySelector('#Slider-{{ section.id }}');
    const dots = section.querySelectorAll('.dc_ymal-dot');
    const sliderComponent = section.querySelector('slider-component');

    if (!slider || !sliderComponent || !dots.length) return;

    sliderComponent.addEventListener('slideChanged', (e) => {
      const current = e.detail.currentPage - 1;
      dots.forEach((dot, i) => dot.classList.toggle('is-active', i === current));
    });

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.dataset.index, 10);
        const slides = slider.querySelectorAll('[id^="Slide-"]');
        if (slides[index]) {
          slider.scrollTo({ left: slides[index].offsetLeft, behavior: 'smooth' });
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "📼 You May Also Like",
  "tag": "section",
  "class": "dc_ymal-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "📼 You May Also Like",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
