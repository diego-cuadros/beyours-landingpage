      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "surface_color_mobile",
      "label": "Mobile section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Desktop heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color_mobile",
      "label": "Mobile heading color",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "panel_background",
      "label": "Desktop card background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "panel_opacity",
