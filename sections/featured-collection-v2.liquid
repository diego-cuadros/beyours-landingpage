{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --image-position: {{ section.settings.image_position }};
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
    --collection-product-title-size: {{ section.settings.product_title_size }}px;
  }
{%- endstyle -%}

<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.quick_view_enabled and section.settings.enable_quick_view -%}
  <link rel="stylesheet" href="{{ 'section-main-product.css' | asset_url }}" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}
<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-price.css' | asset_url | stylesheet_tag }}</noscript>

{{ 'component-product-grid.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="page-width">
    <div class="title-wrapper{% if section.settings.heading == blank %} title-wrapper--no-heading{% endif %} {{ section.settings.heading_alignment }}">
      <{{ section.settings.heading_tag }} class="title {{ section.settings.heading_size }}">
        {%- render 'highlight-text', 
          hl_input: section.settings.heading, 
          hl_style: section.settings.highlight_style,
          hl_enable: section.settings.enable_highlight,
          hl_animateWrap: true -%}
      </{{ section.settings.heading_tag }}>
    </div>

    {%- liquid
      assign products_to_display = section.settings.collection.all_products_count

      if section.settings.collection.all_products_count > section.settings.products_to_show
        assign products_to_display = section.settings.products_to_show
      endif

      assign class_slider = 'slider'
      if section.settings.swipe_on_mobile
        assign class_slider = class_slider | append: ' slider--tablet'
      endif
      assign class_grid_2_col_tablet = 'flex-grid--2-col-tablet'
      assign class_grid_3_col_tablet = 'flex-grid--3-col-tablet'
      assign class_grid_3_col_desktop = 'flex-grid--3-col-desktop'
      assign class_grid_4_col_desktop = 'flex-grid--4-col-desktop'
      assign disable_image_click = false

      if section.settings.horizontal_scroll
        assign class_grid_2_col_tablet = 'flex-grid--2p3-col-tablet'
        assign class_grid_3_col_tablet = 'flex-grid--3p3-col-tablet'
        assign class_grid_3_col_desktop = 'flex-grid--3p3-col-desktop'
        assign class_grid_4_col_desktop = 'flex-grid--4p3-col-desktop'
        assign class_slider = class_slider | append: ' slider--tablet-up'
        if section.settings.products_to_show > 4 and section.settings.enable_drag
          assign class_slider = class_slider | append: ' cursor--drag'
        endif
      endif
    %}

    <div class="slider-mobile-gutter">
      <ul id="Slider-{{ section.id }}"
        class="product-grid flex-grid flex-grid--rigid{% if section.settings.columns_mobile == '1' %} flex-grid--1-col-mobile{% endif %} flex-grid--2-col{% if section.settings.collection == blank or products_to_display == 4 and section.settings.swipe_on_mobile == false %} {{ class_grid_2_col_tablet }} {{ class_grid_4_col_desktop }}{% else %} {{ class_grid_3_col_tablet }}{% if products_to_display == 6 %} {{ class_grid_3_col_desktop }}{% else %} {{ class_grid_4_col_desktop }}{% endif %}{% endif %}{% if section.settings.collection.all_products_count > 2 and section.settings.products_to_show > 2 %} {{ class_slider }}{% endif %}{% if section.settings.collection == blank %} {{ class_slider }}{% endif %}"
        role="list"{% if section.settings.horizontal_scroll %} is="scroll-snap-slider" data-draggable="{{ section.settings.enable_drag }}"{% endif %}
      >
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          {%- liquid
            assign practitioner_only = false
            assign practitioner_badge_text = blank
            assign card_enable_quick_view = section.settings.enable_quick_view
            assign first_selling_plan_id = blank
            assign custom_price = blank
            assign custom_compare_at_price = blank
            assign custom_price_min = blank
            assign custom_price_max = blank
            assign custom_compare_at_price_min = blank
            assign custom_compare_at_price_max = blank
            assign pricing_exempt = false
            assign show_from_lowest_price_card = true
            assign has_subscription_pricing = false
            assign subscription_price_min_cents = blank
            assign subscription_price_max_cents = blank
            assign discount_multiplier = blank
            assign is_bundle_product = false
            assign base_price_min_cents = product.price_min
            assign base_price_max_cents = product.price_max

            if product.gift_card?
              assign pricing_exempt = true
              assign show_from_lowest_price_card = false
            endif

            if product.tags contains 'plusline'
              assign practitioner_only = true
              assign practitioner_badge_text = 'For practitioners only'
              assign card_enable_quick_view = false
            endif

            if product.variants.size == 1 and product.selling_plan_groups != blank
              assign first_group = product.selling_plan_groups.first
              if first_group and first_group.selling_plans != blank
                assign first_plan = first_group.selling_plans.first
                if first_plan
                  assign first_selling_plan_id = first_plan.id
                endif
              endif
            endif

            for product_collection in product.collections
              if product_collection.handle == 'bundles'
                assign is_bundle_product = true
                break
              endif
            endfor

            if pricing_exempt == false
              for variant in product.variants
                assign first_subscription_allocation = variant.selling_plan_allocations | first
                if first_subscription_allocation
                  assign has_subscription_pricing = true
                  if subscription_price_min_cents == blank or first_subscription_allocation.price < subscription_price_min_cents
                    assign subscription_price_min_cents = first_subscription_allocation.price
                  endif
                  if subscription_price_max_cents == blank or first_subscription_allocation.price > subscription_price_max_cents
                    assign subscription_price_max_cents = first_subscription_allocation.price
                  endif
                endif
              endfor
            endif

            if pricing_exempt == false and is_bundle_product
              if section.settings.show_bundle_discount_price and base_price_min_cents != blank and practitioner_only == false
                assign discount_multiplier = 100 | minus: section.settings.bundle_discount_percentage
                assign custom_compare_at_price = base_price_min_cents
                assign custom_price = custom_compare_at_price | times: discount_multiplier | divided_by: 100
                assign custom_compare_at_price_min = base_price_min_cents
                assign custom_compare_at_price_max = base_price_max_cents
                assign custom_price_min = custom_compare_at_price_min | times: discount_multiplier | divided_by: 100
                assign custom_price_max = custom_compare_at_price_max | times: discount_multiplier | divided_by: 100
              endif
            elsif pricing_exempt == false and section.settings.show_dtc_discount_price and practitioner_only == false
              if has_subscription_pricing
                assign custom_price = subscription_price_min_cents
                assign custom_compare_at_price = subscription_price_min_cents
                assign custom_price_min = subscription_price_min_cents
                assign custom_price_max = subscription_price_max_cents
                assign custom_compare_at_price_min = subscription_price_min_cents
                assign custom_compare_at_price_max = subscription_price_max_cents
              elsif base_price_min_cents != blank
                assign discount_multiplier = 100 | minus: section.settings.dtc_discount_percentage
                assign custom_price = base_price_min_cents | times: discount_multiplier | divided_by: 100
                assign custom_compare_at_price = custom_price
                assign custom_price_min = base_price_min_cents | times: discount_multiplier | divided_by: 100
                assign custom_price_max = base_price_max_cents | times: discount_multiplier | divided_by: 100
                assign custom_compare_at_price_min = custom_price_min
                assign custom_compare_at_price_max = custom_price_max
              endif
            endif
          -%}
          <li id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="flex-grid__item{% if section.settings.collection.all_products_count > 2 and section.settings.swipe_on_mobile and section.settings.products_to_show > 2 %} slider__slide{% endif %}"
          >
            {% render 'card-product-v2',
              card_product: product,
              card_collection: section.settings.collection,
              media_size: section.settings.image_ratio,
              show_secondary_image: section.settings.show_secondary_image,
              show_quick_buy: section.settings.show_quick_buy,
              show_vendor: section.settings.show_vendor,
              show_rating: section.settings.show_rating,
              show_loox_rating: section.settings.show_rating,
              enable_quick_view: card_enable_quick_view,
              enable_color_swatches: section.settings.enable_color_swatches,
              enable_countdown: section.settings.enable_countdown,
              enable_image_fill: section.settings.enable_image_fill,
              disable_image_click: disable_image_click,
              custom_badge_text: practitioner_badge_text,
              disable_add_to_cart: practitioner_only,
              custom_price: custom_price,
              custom_compare_at_price: custom_compare_at_price,
              custom_price_min: custom_price_min,
              custom_price_max: custom_price_max,
              custom_compare_at_price_min: custom_compare_at_price_min,
              custom_compare_at_price_max: custom_compare_at_price_max,
              show_from_lowest_price: show_from_lowest_price_card,
              first_selling_plan_id: first_selling_plan_id
            %}
          </li>
        {%- else -%}
          {%- for i in (1..4) -%}
            <li class="flex-grid__item{% if section.settings.swipe_on_mobile %} slider__slide{% endif %}">
              {% render 'card-product-placeholder', media_size: section.settings.image_ratio %}
            </li>
          {%- endfor -%}
        {%- endfor -%}
      </ul>
      {% if section.settings.horizontal_scroll %}
        <div class="slider-buttons no-js-hidden small-hide{% if section.settings.products_to_show <= 4 %} large-up-hide{% if section.settings.products_to_show <= 3 %} medium-hide{% endif %}{% endif %}">
          <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}" disabled="disabled">
            {% render 'icon', icon: 'arrow' %}
          </button>
          <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
            {% render 'icon', icon: 'arrow' %}
          </button>
        </div>
      {% endif %}
    </div>

    {%- if section.settings.show_view_all and section.settings.collection.all_products_count > section.settings.products_to_show -%}
      <div class="view-all center">
        <a href="{{ section.settings.collection.url }}"
          class="button"
          aria-label="{{ 'sections.featured_collection.view_all_label' | t: collection_name: section.settings.collection.title }}"
        >
          {{ 'sections.featured_collection.view_all' | t }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured Collection V2",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured-collection.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "t:sections.featured-collection.settings.products_to_show.label"
    },
    {
      "type": "checkbox",
      "id": "horizontal_scroll",
      "default": false,
      "label": "t:sections.all.horizontal_scroll_on_desktop.label"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "t:sections.featured-collection.settings.show_view_all.label"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "default": false,
      "label": "t:sections.all.show_divider.label"
    },
    {
      "type": "checkbox",
      "id": "enable_drag",
      "default": false,
      "label": "t:sections.featured-collection.settings.enable_drag.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.heading.label"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Featured collection",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:sections.all.heading_alignment.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.all.heading_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.all.heading_alignment.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.all.heading_alignment.options__3.label"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        },
        {
          "value": "span",
          "label": "t:sections.all.heading_tag.options__8.label"
        },
        {
          "value": "p",
          "label": "t:sections.all.heading_tag.options__9.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.mobile_layout.header.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "t:sections.all.mobile_layout.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.all.mobile_layout.columns_mobile.options__2.label"
        }
      ],
      "default": "2",
      "label": "t:sections.all.mobile_layout.columns_mobile.label"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "t:sections.all.mobile_layout.swipe_on_mobile.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.product_card.header.content"
    },
    {
      "type": "header",
      "content": "Pricing"
    },
    {
      "type": "checkbox",
      "id": "show_dtc_discount_price",
      "default": true,
      "label": "Show DTC price at 15% off",
      "info": "Applies to products that are not in the bundles collection."
    },
    {
      "type": "range",
      "id": "dtc_discount_percentage",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "DTC discount percentage",
      "default": 15
    },
    {
      "type": "checkbox",
      "id": "show_bundle_discount_price",
      "default": true,
      "label": "Show bundles price at 10% off",
      "info": "Applies only to products that belong to the bundles collection."
    },
    {
      "type": "range",
      "id": "bundle_discount_percentage",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Bundle discount percentage",
      "default": 10
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.all.card_image_ratio.options__1.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.card_image_ratio.options__2.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.card_image_ratio.options__3.label"
        },
        {
          "value": "landscape",
          "label": "t:sections.all.card_image_ratio.options__4.label"
        },
        {
          "value": "wide",
          "label": "t:sections.all.card_image_ratio.options__5.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.all.card_image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_position",
      "options": [
        {
          "value": "20% 0",
          "label": "t:sections.all.image_position.options__1.label"
        },
        {
          "value": "top center",
          "label": "t:sections.all.image_position.options__2.label"
        },
        {
          "value": "80% 0",
          "label": "t:sections.all.image_position.options__3.label"
        },
        {
          "value": "20% 50%",
          "label": "t:sections.all.image_position.options__4.label"
        },
        {
          "value": "center center",
          "label": "t:sections.all.image_position.options__5.label"
        },
        {
          "value": "80% 50%",
          "label": "t:sections.all.image_position.options__6.label"
        },
        {
          "value": "20% 100%",
          "label": "t:sections.all.image_position.options__7.label"
        },
        {
          "value": "bottom center",
          "label": "t:sections.all.image_position.options__8.label"
        },
        {
          "value": "80% 100%",
          "label": "t:sections.all.image_position.options__9.label"
        }
      ],
      "default": "center center",
      "label": "t:sections.all.image_position.label",
      "info": "t:sections.all.image_position.info"
    },
    {
      "type": "checkbox",
      "id": "enable_image_fill",
      "default": true,
      "label": "t:sections.all.product_card.enable_image_fill.label",
      "info": "t:sections.all.product_card.enable_image_fill.info"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "t:sections.all.product_card.show_secondary_image.label"
    },
    {
      "type": "range",
      "id": "secondary_image_max",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Maxium images on hover",
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:sections.all.product_card.show_vendor.label"
    },
    {
      "type": "range",
      "id": "product_title_size",
      "min": 16,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 16,
      "label": "Product title size"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "t:sections.all.product_card.show_rating.label",
      "info": "t:sections.all.product_card.show_rating.info"
    },
    {
      "type": "checkbox",
      "id": "show_quick_buy",
      "default": true,
      "label": "t:sections.all.product_card.show_quick_buy.label"
    },
    {
      "type": "checkbox",
      "id": "enable_quick_view",
      "default": true,
      "label": "t:sections.all.product_card.enable_quick_view.label"
    },
    {
      "type": "checkbox",
      "id": "enable_color_swatches",
      "default": true,
      "label": "t:sections.all.product_card.enable_color_swatches.label"
    },
    {
      "type": "checkbox",
      "id": "enable_countdown",
      "default": true,
      "label": "t:sections.all.product_card.enable_countdown.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.colors.header.content"
    },
    {
      "type": "color",
      "id": "colors_highlight",
      "label": "t:sections.all.colors.colors_highlight.label",
      "default": "#ffb503"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.header.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "t:sections.all.padding.padding_top.unit",
      "label": "t:sections.all.padding.padding_top.label",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "t:sections.all.padding.padding_bottom.unit",
      "label": "t:sections.all.padding.padding_bottom.label",
      "default": 36
    },
    {
      "type": "header",
      "content": "t:sections.all.highlight.header.content"
    },
    {
      "type": "checkbox",
      "id": "enable_highlight",
      "label": "t:sections.all.highlight.enable.label",
      "info": "t:sections.all.highlight.enable.info",
      "default": false
    },
    {
      "type": "select",
      "id": "highlight_style",
      "options": [
        {
          "value": "marker",
          "label": "t:sections.all.highlight.style.options__1.label"
        },
        {
          "value": "circle",
          "label": "t:sections.all.highlight.style.options__2.label"
        },
        {
          "value": "underline",
          "label": "t:sections.all.highlight.style.options__3.label"
        },
        {
          "value": "bold-underline",
          "label": "t:sections.all.highlight.style.options__4.label"
        },
        {
          "value": "modern-underline",
          "label": "t:sections.all.highlight.style.options__5.label"
        },
        {
          "value": "sketch-underline",
          "label": "t:sections.all.highlight.style.options__6.label"
        },
        {
          "value": "squiggle",
          "label": "t:sections.all.highlight.style.options__7.label"
        },
        {
          "value": "heavy-squiggle",
          "label": "t:sections.all.highlight.style.options__8.label"
        },
        {
          "value": "solid-color",
          "label": "t:sections.all.highlight.style.options__9.label"
        }
      ],
      "default": "marker",
      "label": "t:sections.all.highlight.style.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured-collection.presets.name"
    }
  ],
  "enabled_on": {
    "templates": ["404", "article", "blog", "cart", "collection", "list-collections", "index", "metaobject", "page", "product", "search"]
  }
}
{% endschema %}
