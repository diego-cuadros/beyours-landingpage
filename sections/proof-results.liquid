    {
      "type": "range",
      "id": "card_radius",
      "min": 8,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Card corner radius",
      "default": 10
    },
    {
      "type": "range",
      "id": "award_logo_width",
      "min": 80,
      "max": 220,
      "step": 4,
      "unit": "px",
      "label": "Award logo width",
      "default": 124
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show top divider",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Proof results",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "metric": "1.5 million hours",
            "caption": "of additional focus"
          }
        },
        {
          "type": "stat",
          "settings": {
            "metric": "700,000 hours",
            "caption": "of \"no stress\""
          }
        },
        {
          "type": "stat",
          "settings": {
            "metric": "3.63 million hours",
            "caption": "of increased energy"
          }
        },
        {
          "type": "stat",
          "settings": {
            "metric": "2.4 million hours",
            "caption": "of better sleep"
          }
        },
        {
          "type": "award",
          "settings": {
            "title": "Inc. 5000 Fastest Growing Companies",
            "text": "<p>#99 Fastest Growing Healthcare &amp; Medical Company (U.S.)</p>"
          }
