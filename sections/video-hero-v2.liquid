{%- liquid
  assign external_video_type = blank
  assign external_video_id = blank
  assign external_video_thumbnail_url = blank
  assign has_desktop_video = false
  assign has_any_video = false
  assign dynamic_video_url = section.settings.dynamic_video_url.value | default: section.settings.dynamic_video_url | append: '' | strip
  assign dynamic_video_url_digits_only = dynamic_video_url

  assign dynamic_video_url_digits_only = dynamic_video_url_digits_only | remove: '0' | remove: '1' | remove: '2' | remove: '3' | remove: '4' | remove: '5' | remove: '6' | remove: '7' | remove: '8' | remove: '9'

  if dynamic_video_url != blank
    if dynamic_video_url contains 'youtu.be/'
      assign external_video_type = 'youtube'
      assign external_video_id = dynamic_video_url | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first
    elsif dynamic_video_url contains 'youtube.com/watch'
      assign external_video_type = 'youtube'
      assign external_video_id = dynamic_video_url | split: 'v=' | last | split: '&' | first
    elsif dynamic_video_url contains 'youtube.com/embed/'
      assign external_video_type = 'youtube'
      assign external_video_id = dynamic_video_url | split: 'youtube.com/embed/' | last | split: '?' | first | split: '&' | first
    elsif dynamic_video_url contains 'player.vimeo.com/video/'
      assign external_video_type = 'vimeo'
      assign external_video_id = dynamic_video_url | split: 'player.vimeo.com/video/' | last | split: '?' | first | split: '&' | first
    elsif dynamic_video_url contains 'vimeo.com/'
      assign external_video_type = 'vimeo'
      assign external_video_id = dynamic_video_url | split: 'vimeo.com/' | last | split: '?' | first | split: '/' | last
    elsif dynamic_video_url_digits_only == blank
      assign external_video_type = 'vimeo'
      assign external_video_id = dynamic_video_url
    else
      assign external_video_type = 'youtube'
      assign external_video_id = dynamic_video_url
    endif
  endif

  if external_video_id == blank and section.settings.video_url != blank
    assign external_video_type = section.settings.video_url.type
    assign external_video_id = section.settings.video_url.id
  endif

  if section.settings.video != blank or external_video_id != blank
    assign has_desktop_video = true
  endif

  if has_desktop_video or section.settings.mobile_video != blank
    assign has_any_video = true
  endif

  if external_video_id != blank
    if external_video_type == 'youtube'
      assign external_video_thumbnail_url = 'https://i.ytimg.com/vi/' | append: external_video_id | append: '/maxresdefault.jpg'
    elsif external_video_type == 'vimeo'
      assign external_video_thumbnail_url = 'https://vumbnail.com/' | append: external_video_id | append: '.jpg'
    endif
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --video-hero-v2-overlay-border-radius: {{ section.settings.overlay_border_radius }}px;
    {%- if section.settings.video != blank -%}
      --image-ratio-percent: {{ 1 | divided_by: section.settings.video.aspect_ratio | times: 100 }}%;
    {%- elsif section.settings.mobile_video != blank -%}
      --image-ratio-percent: {{ 1 | divided_by: section.settings.mobile_video.aspect_ratio | times: 100 }}%;
    {%- else -%}
      --image-ratio-percent: 56.25%;
    {% endif -%}
    --color-overlay-opacity: {{ section.settings.colors_overlay_opacity | divided_by: 100.0 }};
    --color-overlay: {{ section.settings.colors_overlay.red }}, {{ section.settings.colors_overlay.green }}, {{ section.settings.colors_overlay.blue }};
    --color-foreground: {{ section.settings.colors_text.red }}, {{ section.settings.colors_text.green }}, {{ section.settings.colors_text.blue }};
    --color-link: var(--color-foreground);
    --color-border: var(--color-foreground);
    --color-heading: var(--color-foreground);
    --color-button-background: {{ section.settings.colors_button_background.red }}, {{ section.settings.colors_button_background.green }}, {{ section.settings.colors_button_background.blue }};
    --color-button-text: {{ section.settings.colors_button_label.red }}, {{ section.settings.colors_button_label.green }}, {{ section.settings.colors_button_label.blue }};
    --color-button-border: var(--color-button-background);
    --color-shadow: var(--color-foreground);
    --shadow-opacity: 0.3;
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
  }

  #shopify-section-{{ section.id }} #Banner-{{ section.id }} .banner__box {
    border-radius: var(--video-hero-v2-overlay-border-radius);
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} #Banner-{{ section.id }} .banner__box {
      width: 100%;
      max-width: {% if section.settings.restrict_overlay_max_width %}{{ section.settings.overlay_max_width }}%{% else %}none{% endif %};
    }
  }

  #shopify-section-{{ section.id }} .video-hero-v2__source--mobile-only {
    display: none;
  }

  @media screen and (max-width: 749px) {
    {%- unless section.settings.show_color_overlay_on_mobile -%}
      #shopify-section-{{ section.id }} {
        --color-overlay-opacity: 0;
      }
    {%- endunless -%}

    {%- if section.settings.mobile_video != blank and section.settings.mobile_image_ratio == 'adapt' -%}
      #shopify-section-{{ section.id }} {
        --image-ratio-percent: {{ 1 | divided_by: section.settings.mobile_video.aspect_ratio | times: 100 }}%;
      }
    {%- endif -%}

    #shopify-section-{{ section.id }} .video-hero-v2__source--desktop-only {
      display: none;
    }

    #shopify-section-{{ section.id }} .video-hero-v2__source--mobile-only {
      display: block;
    }

    #shopify-section-{{ section.id }} .banner__content--mobile-top {
      align-items: flex-start;
    }

    #shopify-section-{{ section.id }} .banner__content--mobile-middle {
      align-items: center;
    }

    #shopify-section-{{ section.id }} .banner__content--mobile-bottom {
      align-items: flex-end;
    }
  }
{%- endstyle -%}

{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full-width{% endif %}">
    <div id="Banner-{{ section.id }}" class="banner{% if section.settings.show_text_box %} banner--container{% endif %}{% if section.settings.show_text_below %} banner--mobile-bottom{% endif %}">
      {%- if has_any_video == false -%}
        <div class="banner__media">
          <use-animate data-animate="zoom-fade" class="media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}">
            {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder image-animate' }}
          </use-animate>
        </div>
      {%- else -%}
        <div class="banner__media">
          <use-animate data-animate="zoom-fade" class="media-wrapper media-wrapper--large">
            <div class="image-animate media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}">
              {%- if has_desktop_video -%}
                <div{% if section.settings.mobile_video != blank %} class="video-hero-v2__source--desktop-only"{% endif %}>
                  {%- if section.settings.video != blank -%}
                    <video-section data-video-hero data-type="mp4">
                      {{ section.settings.video | video_tag:
                        image_size: "3840px",
                        autoplay: true,
                        loop: true,
                        controls: false,
                        muted: true,
                        playsinline: true
                      }}
                    </video-section>
                  {% elsif external_video_id != blank %}
                    {%- if external_video_thumbnail_url != blank -%}
                      <img
                        src="{{ external_video_thumbnail_url }}"
                        alt=""
                        class="image-fit"
                        loading="eager"
                        fetchpriority="high"
                        {% if external_video_type == 'youtube' %}onerror="this.onerror=null;this.src='https://i.ytimg.com/vi/{{ external_video_id }}/hqdefault.jpg';"{% endif %}
                      >
                    {%- endif -%}
                    <video-section data-video-hero
                      data-type="{{ external_video_type }}"
                      data-loop="1"
                      data-video-id="{{ external_video_id }}"></video-section>
                  {% endif %}
                </div>
              {%- endif -%}

              {%- if section.settings.mobile_video != blank -%}
                <div{% if has_desktop_video %} class="video-hero-v2__source--mobile-only"{% endif %}>
                  <video-section data-video-hero data-type="mp4">
                    {{ section.settings.mobile_video | video_tag:
                      image_size: "2000px",
                      autoplay: true,
                      loop: true,
                      controls: false,
                      muted: true,
                      playsinline: true
                    }}
                  </video-section>
                </div>
              {%- endif -%}
            </div>
          </use-animate>
        </div>
      {%- endif -%}
      {%- if section.blocks.size > 0 -%}
        <div class="banner__content banner__content--{{ section.settings.text_box_position }} banner__content--mobile-{{ section.settings.mobile_content_position }} page-width">
          <div class="banner__box {{ section.settings.text_alignment }} mobile-{{ section.settings.mobile_text_alignment }}">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'heading' -%}
                  <{{ block.settings.heading_tag }} class="banner__heading {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                    {%- render 'highlight-text', 
                      hl_input: block.settings.heading, 
                      hl_style: block.settings.highlight_style,
                      hl_enable: block.settings.enable_highlight,
                      hl_animateWrap: true -%}
                  </{{ block.settings.heading_tag }}>
                {%- when 'subheading' -%}
                  <p class="banner__subheading{% if block.settings.secondary_color %} banner__subheading--colored{% endif %} {{ block.settings.subheading_size }}" {{ block.shopify_attributes }}>
                    {%- render 'highlight-text', 
                      hl_input: block.settings.subheading, 
                      hl_style: block.settings.highlight_style,
                      hl_enable: block.settings.enable_highlight,
                      hl_animateWrap: true -%}
                  </p>
                {%- when 'text' -%}
                  <div class="banner__text{% if block.settings.secondary_color %} banner__text--colored{% endif %} {{ block.settings.text_size }} rte" {{ block.shopify_attributes }}>
                    {%- render 'highlight-text', 
                      hl_input: block.settings.text, 
                      hl_style: block.settings.highlight_style,
                      hl_enable: block.settings.enable_highlight,
                      hl_animateWrap: true -%}
                  </div>
                {%- when 'custom_liquid' -%}
                  <div class="banner__text rte" {{ block.shopify_attributes }}>{{ block.settings.custom_liquid }}</div>
                {%- when 'button' -%}
                  <div class="button-group">
                    {%- if block.settings.button_label != blank or block.settings.button_alt_label != blank -%}
                      {%- if block.settings.button_label != blank -%}
                        {%- if block.settings.button_style_secondary -%}
                          <a class="button button--cta button--{{ block.settings.button_size }}"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                            <span class="label">{{ block.settings.button_label | escape }}</span>
                            {% render 'icon', icon: 'arrow' %}
                          </a>
                        {%- else -%}
                          <a class="button button--{{ block.settings.button_size }}"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                            {{ block.settings.button_label | escape }}
                          </a>
                        {%- endif -%}
                      {%- endif -%}
                      {%- if block.settings.button_alt_label != blank -%}
                        {%- if block.settings.button_alt_style_secondary -%}
                          <a class="button button--cta button--{{ block.settings.button_size }}"{% if block.settings.button_alt_link != blank %} href="{{ block.settings.button_alt_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                            <span class="label">{{ block.settings.button_alt_label | escape }}</span>
                            {% render 'icon', icon: 'arrow' %}
                          </a>
                        {%- else -%}
                          <a class="button button--secondary button--{{ block.settings.button_size }}"{% if block.settings.button_alt_link != blank %} href="{{ block.settings.button_alt_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                            {{ block.settings.button_alt_label | escape }}
                          </a>
                        {%- endif -%}
                      {%- endif -%}
                    {%- elsif section.blocks.size == 1 and block.settings.button_link != blank -%}
                      <a class="full-unstyled-link" href="{{ block.settings.button_link }}" {{ block.shopify_attributes }}></a>
                    {%- endif -%}
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Video hero v2",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.video-hero.settings.header__1.content"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.video-hero.settings.video.label"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile video",
      "info": "Shown on screens below 750px. Falls back to the main video when left empty."
    },
    {
      "type": "header",
      "content": "t:sections.video-hero.settings.header__2.content"
    },
    {
      "type": "paragraph",
