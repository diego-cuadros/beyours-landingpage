{%- liquid
  assign grid_class = 'image-with-text__grid video-with-text__grid'
  assign video_id = section.settings.video.id | default: section.settings.video_url.id | default: section.id
  assign video_alt = section.settings.video.alt | default: section.settings.description
  assign alt = 'sections.video.load_video' | t: description: video_alt | escape
  assign media_width_percent = 65
  assign text_width_percent = 35
  assign use_hosted_video_preview_image = section.settings.use_hosted_video_preview_image
  assign hosted_video_preview = blank

  if section.settings.desktop_media_ratio == 'half'
    assign media_width_percent = 50
    assign text_width_percent = 50
  endif

  if section.settings.video != blank and use_hosted_video_preview_image
    assign hosted_video_preview = section.settings.video.preview_image
  endif

  assign poster = hosted_video_preview | default: section.settings.cover_image | default: section.settings.video.preview_image
  assign poster_mobile = section.settings.cover_image_mobile | default: poster
  assign autoplay_hosted_video = false
  assign autoplay_hosted_video_muted = true

  if section.settings.video != blank and section.settings.enable_hosted_video_autoplay
    assign autoplay_hosted_video = true
  endif

  if section.settings.enable_hosted_video_autoplay_audio
    assign autoplay_hosted_video_muted = false
  endif

  if section.settings.layout == 'text_first'
    assign grid_class = grid_class | append: ' image-with-text__grid--reverse'
  endif

  if section.settings.mobile_layout == 'text_first'
    assign grid_class = grid_class | append: ' image-with-text__grid-mobile--reverse'
  endif

  if section.settings.video != null and poster != blank
    assign ratio_diff = section.settings.video.aspect_ratio | minus: poster.aspect_ratio | abs
    if ratio_diff < 0.01 and ratio_diff > 0
      assign fix_ratio = true
    endif
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --video-with-text-media-width: {{ media_width_percent }}%;
    --video-with-text-text-width: {{ text_width_percent }}%;
    --video-with-text-media-radius: {{ section.settings.media_corner_radius }}px;
    --video-with-text-heading-text-gap: {{ section.settings.heading_text_gap }}px;
    --video-with-text-hanging-quote-size: 5rem;
    --video-with-text-hanging-quote-offset: clamp(1.4rem, 2vw, 2.4rem);
    --video-with-text-hanging-quote-color: {{ section.settings.hanging_quote_color | default: '#9ca3af' }};
    --video-with-text-full-width-max-content: {{ section.settings.full_width_max_content_width }}px;
    --video-with-text-full-width-media-padding: {{ section.settings.full_width_media_padding }}px;
    --image-position: {{ section.settings.image_position }};
    {%- if section.settings.video != blank %}
      --video-with-text-mobile-ratio-percent: {{ 1 | divided_by: section.settings.video.aspect_ratio | times: 100 }}%;
    {%- elsif poster_mobile != blank %}
      --video-with-text-mobile-ratio-percent: {{ 1 | divided_by: poster_mobile.aspect_ratio | times: 100 }}%;
    {%- elsif poster != blank %}
      --video-with-text-mobile-ratio-percent: {{ 1 | divided_by: poster.aspect_ratio | times: 100 }}%;
    {% else %}
      --video-with-text-mobile-ratio-percent: 56.25%;
    {% endif -%}
    {%- if poster != blank %}
      --image-ratio-percent: {{ 1 | divided_by: poster.aspect_ratio | times: 100 }}%;
    {% else %}
      --image-ratio-percent: 56.25%;
    {% endif -%}
    {%- if section.settings.use_custom_colors %}
      --gradient-background: {% if section.settings.gradient_background != blank %}{{ section.settings.gradient_background }}{% else %}{{ section.settings.colors_background }}{% endif %};
      --color-background: {{ section.settings.colors_background.red }}, {{ section.settings.colors_background.green }}, {{ section.settings.colors_background.blue }};
      --color-foreground: {{ section.settings.colors_text.red }}, {{ section.settings.colors_text.green }}, {{ section.settings.colors_text.blue }};
      --color-link: var(--color-foreground);
      --color-border: var(--color-foreground);
      --color-heading: var(--color-foreground);
      --color-button-background: {{ section.settings.colors_button_background.red }}, {{ section.settings.colors_button_background.green }}, {{ section.settings.colors_button_background.blue }};
      --color-button-text: {{ section.settings.colors_button_label.red }}, {{ section.settings.colors_button_label.green }}, {{ section.settings.colors_button_label.blue }};
      --color-button-border: var(--color-button-background);
      --color-shadow: var(--color-foreground);
    {% endif -%}
    --shadow-opacity: 0.3;
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
  }

  #shopify-section-{{ section.id }} .video-with-text.page-width--full-width .image-with-text__media-item {
    padding: var(--video-with-text-full-width-media-padding);
  }

  #shopify-section-{{ section.id }} .video-with-text__media-item .media-wrapper,
  #shopify-section-{{ section.id }} .video-with-text__media-item .media {
    background: transparent;
    background-color: transparent;
  }

  #shopify-section-{{ section.id }} .video-with-text video,
  #shopify-section-{{ section.id }} .video-with-text iframe {
    background: transparent;
    background-color: transparent;
  }

  #shopify-section-{{ section.id }} .video-with-text__media-item > .media-wrapper,
  #shopify-section-{{ section.id }} .video-with-text__media-item > .image-with-text--video {
    border-radius: var(--video-with-text-media-radius);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .video-with-text .image-with-text__subheading {
    text-transform: none;
    letter-spacing: normal;
  }

  #shopify-section-{{ section.id }} .video-with-text .image-with-text__content > :is(.image-with-text__heading, .image-with-text__subheading) + .image-with-text__text {
    margin-top: var(--video-with-text-heading-text-gap);
  }

  #shopify-section-{{ section.id }} .video-with-text .image-with-text__text--hanging-quotes {
    position: relative;
    padding-inline: var(--video-with-text-hanging-quote-offset);
  }

  #shopify-section-{{ section.id }} .video-with-text .image-with-text__text--hanging-quotes > *:first-child,
  #shopify-section-{{ section.id }} .video-with-text .image-with-text__text--hanging-quotes > *:last-child {
    position: relative;
  }

  #shopify-section-{{ section.id }} .video-with-text .image-with-text__text--hanging-quotes > *:first-child::before {
    content: '“';
    position: absolute;
    left: calc(var(--video-with-text-hanging-quote-offset) * -1);
    top: -0.35em;
    font-size: var(--video-with-text-hanging-quote-size);
    line-height: 1;
    color: var(--video-with-text-hanging-quote-color);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .video-with-text .image-with-text__text--hanging-quotes > *:last-child::after {
    content: '”';
    position: absolute;
    right: calc(var(--video-with-text-hanging-quote-offset) * -0.9);
    bottom: -0.55em;
    font-size: var(--video-with-text-hanging-quote-size);
    line-height: 1;
    color: var(--video-with-text-hanging-quote-color);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .video-with-text .deferred-media__poster,
  #shopify-section-{{ section.id }} .video-with-text .deferred-media,
  #shopify-section-{{ section.id }} .video-with-text .card-wrapper,
  #shopify-section-{{ section.id }} .video-with-text .card {
    width: 100%;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .video-with-text .deferred-media__poster img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center center;
  }

  #shopify-section-{{ section.id }} .video-with-text .deferred-media__poster,
  #shopify-section-{{ section.id }} .video-with-text .deferred-media__poster .media-wrapper,
  #shopify-section-{{ section.id }} .video-with-text .deferred-media__poster .media {
    background: transparent;
    background-color: transparent;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .video-with-text__grid > .flex-grid__item:first-child {
      width: var(--video-with-text-media-width);
      max-width: var(--video-with-text-media-width);
    }

    #shopify-section-{{ section.id }} .video-with-text__grid > .flex-grid__item:last-child {
      width: var(--video-with-text-text-width);
      max-width: var(--video-with-text-text-width);
    }

    #shopify-section-{{ section.id }} .video-with-text .image-with-text__content {
      max-width: none;
      padding: clamp(2.4rem, 4vw, 5rem);
    }
  }

  @media screen and (min-width: 1320px) {
    #shopify-section-{{ section.id }} .video-with-text .image-with-text__content {
      padding-inline: clamp(3.2rem, 4vw, 6rem);
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .section--padding {
      background: var(--gradient-background);
      background-color: rgb(var(--color-background));
    }

    #shopify-section-{{ section.id }} .video-with-text,
    #shopify-section-{{ section.id }} .video-with-text__grid {
      background: transparent;
      background-color: transparent;
    }

    #shopify-section-{{ section.id }} .video-with-text .image-with-text__text--hanging-quotes {
      padding-inline: 1.6rem;
    }

    #shopify-section-{{ section.id }} .video-with-text .image-with-text__text--hanging-quotes > *:first-child::before {
      left: -1.4rem;
      font-size: 4rem;
    }

    #shopify-section-{{ section.id }} .video-with-text .image-with-text__text--hanging-quotes > *:last-child::after {
      right: -1.2rem;
      font-size: 4rem;
    }

    #shopify-section-{{ section.id }} .video-with-text__media-item > .image-with-text--video.media-mobile--auto {
      height: 0;
      padding-bottom: var(--video-with-text-mobile-ratio-percent);
    }
  }

  {%- if section.settings.cover_image_mobile != blank and section.settings.mobile_image_ratio == 'adapt' %}
    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} {
        --image-ratio-percent: {{ 1 | divided_by: section.settings.cover_image_mobile.aspect_ratio | times: 100 }}%;
      }
    }
  {% endif -%}

  @media screen and (min-width: 1600px) {
    #shopify-section-{{ section.id }} .video-with-text.page-width--full-width {
      background: var(--gradient-background);
      background-color: rgb(var(--color-background));
    }

    #shopify-section-{{ section.id }} .video-with-text.page-width--full-width > .video-with-text__grid {
      max-width: min(100%, var(--video-with-text-full-width-max-content));
      margin-inline: auto;
      background: transparent;
      background-color: transparent;
    }
  }
{%- endstyle -%}

{{ 'section-image-with-text.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}</noscript>

{%- capture sizes -%}
  {%- if section.settings.full_width -%}
    (min-width: 1600px) {{ section.settings.full_width_max_content_width | times: media_width_percent | divided_by: 100.0 | round }}px,
  {%- endif -%}
  (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | times: media_width_percent | divided_by: 100.0 | round }}px,
  (min-width: 750px) {{ media_width_percent }}vw,
  100vw
{%- endcapture -%}

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="video-with-text image-with-text{% if section.settings.use_custom_colors and section.settings.colors_background != settings.colors_background %} image-with-text--colored{% else %} image-with-text--alt{% endif %} page-width{% if section.settings.full_width %} page-width--full-width{% endif %}">
    <div class="{{ grid_class }} flex-grid flex-grid--gapless flex-grid--1-col flex-grid--2-col-tablet">
      <div class="flex-grid__item image-with-text__media-item video-with-text__media-item">
        <div class="image-with-text--video image-animate media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}">
          {%- if section.settings.video == blank and section.settings.video_url == blank -%}
            <use-animate data-animate="zoom-fade" class="media-wrapper">
              <div class="image-animate media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}">
                {%- if poster != blank -%}
                  {{ poster | image_url: width: 3840 | image_tag:
                    loading: 'lazy',
                    class: 'image-fit',
                    sizes: sizes,
                    widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                    alt: alt,
                    is: 'lazy-image'
                  }}
                {%- else -%}
                  {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                {%- endif -%}
              </div>
            </use-animate>
          {%- elsif autoplay_hosted_video -%}
            <use-animate data-animate="zoom-fade" class="media-wrapper">
              <div class="image-animate media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}">
                {{ section.settings.video | video_tag:
                  image_size: '2200x',
                  autoplay: true,
                  loop: section.settings.enable_video_looping,
                  controls: false,
                  muted: autoplay_hosted_video_muted,
                  playsinline: true,
                  preload: 'auto'
                }}
              </div>
            </use-animate>
          {%- else -%}
            <noscript>
              <div class="image-with-text-video-section__media">
                {%- if section.settings.video == null and section.settings.video_url != null -%}
                  <a href="{{ section.settings.video_url }}" class="card-wrapper">
                    <div class="card deferred-media__poster">
                      <span class="deferred-media__poster-button motion-reduce">
                        {%- render 'icon', icon: 'play' -%}
                      </span>
                      <div class="media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}">
                        {%- if poster != blank -%}
                          {{ poster_mobile | image_url: width: 3840 | image_tag:
                            loading: 'lazy',
                            class: 'image-fit medium-hide large-up-hide',
                            sizes: sizes,
                            widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                            alt: alt
                          }}
                          {{ poster | image_url: width: 3840 | image_tag:
                            loading: 'lazy',
                            class: 'image-fit small-hide',
                            sizes: sizes,
                            widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                            alt: alt
                          }}
                        {%- else -%}
                          {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder collage-card__image' }}
                        {%- endif -%}
                      </div>
                    </div>
                  </a>
                {%- else -%}
                  {{ section.settings.video | video_tag:
                    image_size: '1100x',
                    loop: section.settings.enable_video_looping,
                    controls: true,
                    muted: false
                  }}
                {%- endif -%}
              </div>
            </noscript>

            <deferred-media class="card-wrapper deferred-media no-js-hidden media-wrapper media-wrapper--large{% if fix_ratio %} media-fit-cover{% endif %}" data-media-id="{{ video_id }}">
              <button
                id="Deferred-Poster-{{ video_id }}"
                class="card deferred-media__poster"
                type="button"
              >
                <span class="deferred-media__poster-button motion-reduce">
                  {%- render 'icon', icon: 'play' -%}
                </span>
                <use-animate data-animate="zoom-fade-small" class="media-wrapper">
                  {%- if poster != blank -%}
                    {{ poster_mobile | image_url: width: 3840 | image_tag:
                      loading: 'lazy',
                      class: 'image-fit medium-hide large-up-hide',
                      sizes: sizes,
                      widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                      alt: alt,
                      is: 'lazy-image'
                    }}
                    {{ poster | image_url: width: 3840 | image_tag:
                      loading: 'lazy',
                      class: 'image-fit small-hide',
                      sizes: sizes,
                      widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                      alt: alt,
                      is: 'lazy-image'
                    }}
                  {%- else -%}
                    {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder collage-card__image' }}
                  {%- endif -%}
                </use-animate>
              </button>
              <template>
                {%- if section.settings.video == null and section.settings.video_url != null -%}
                  <video-section
                    data-init-mode="template"
                    data-parent="deferred-media"
                    data-loop="{% if section.settings.enable_video_looping %}1{% else %}0{% endif %}"
                    data-type="{{ section.settings.video_url.type }}"
                    data-video-id="{{ section.settings.video_url.id }}"
                  ></video-section>
                {%- else -%}
                  {{ section.settings.video | video_tag:
                    image_size: '1100x',
                    autoplay: true,
                    loop: section.settings.enable_video_looping,
                    controls: true,
                    muted: false
                  }}
                {%- endif -%}
              </template>
            </deferred-media>
          {%- endif -%}
        </div>
      </div>

      <div class="flex-grid__item">
        <div class="image-with-text__content {{ section.settings.text_box_position }} {{ section.settings.text_alignment }} mobile-{{ section.settings.mobile_text_alignment }}">
          {%- for block in section.blocks -%}
            {% case block.type %}
              {%- when 'heading' -%}
                <{{ block.settings.heading_tag }} class="image-with-text__heading {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                  {%- render 'highlight-text',
                    hl_input: block.settings.heading,
                    hl_style: block.settings.highlight_style,
                    hl_enable: block.settings.enable_highlight,
                    hl_animateWrap: true
                  -%}
                </{{ block.settings.heading_tag }}>
                {%- if block.settings.heading_subheading != blank -%}
                  <p class="image-with-text__subheading {{ block.settings.heading_subheading_size }}">
                    {%- render 'highlight-text',
                      hl_input: block.settings.heading_subheading,
                      hl_style: block.settings.highlight_style,
                      hl_enable: block.settings.enable_highlight,
                      hl_animateWrap: true
                    -%}
                  </p>
                {%- endif -%}

              {%- when 'subheading' -%}
                <p class="image-with-text__subheading{% if block.settings.secondary_color %} image-with-text__subheading--colored{% endif %} {{ block.settings.subheading_size }}" {{ block.shopify_attributes }}>
                  {%- render 'highlight-text',
                    hl_input: block.settings.subheading,
                    hl_style: block.settings.highlight_style,
                    hl_enable: block.settings.enable_highlight,
                    hl_animateWrap: true
                  -%}
                </p>

              {%- when 'text' -%}
                <div class="image-with-text__text{% if block.settings.show_hanging_quotes %} image-with-text__text--hanging-quotes{% endif %}{% if block.settings.secondary_color %} image-with-text__text--colored{% endif %} {{ block.settings.text_size }} rte" style="margin-top: {{ block.settings.margin_top }}px;" {{ block.shopify_attributes }}>
                  {%- render 'highlight-text',
                    hl_input: block.settings.text,
                    hl_style: block.settings.highlight_style,
                    hl_enable: block.settings.enable_highlight,
                    hl_animateWrap: true
                  -%}
                </div>

              {%- when 'custom_liquid' -%}
                <div class="image-with-text__text rte" {{ block.shopify_attributes }}>{{ block.settings.custom_liquid }}</div>

              {%- when 'button' -%}
                <div class="button-group">
                  {%- if block.settings.button_label != blank or block.settings.button_alt_label != blank -%}
                    {%- if block.settings.button_label != blank -%}
                      {%- if block.settings.button_style_secondary -%}
                        <a class="button button--cta button--{{ block.settings.button_size }}"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                          <span class="label">{{ block.settings.button_label | escape }}</span>
                          {% render 'icon', icon: 'arrow' %}
                        </a>
                      {%- else -%}
                        <a class="button button--{{ block.settings.button_size }}"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                          {{ block.settings.button_label | escape }}
                        </a>
                      {%- endif -%}
                    {%- endif -%}

                    {%- if block.settings.button_alt_label != blank -%}
                      {%- if block.settings.button_alt_style_secondary -%}
                        <a class="button button--cta button--{{ block.settings.button_size }}"{% if block.settings.button_alt_link != blank %} href="{{ block.settings.button_alt_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                          <span class="label">{{ block.settings.button_alt_label | escape }}</span>
                          {% render 'icon', icon: 'arrow' %}
                        </a>
                      {%- else -%}
                        <a class="button button--secondary button--{{ block.settings.button_size }}"{% if block.settings.button_alt_link != blank %} href="{{ block.settings.button_alt_link }}"{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                          {{ block.settings.button_alt_label | escape }}
                        </a>
                      {%- endif -%}
                    {%- endif -%}
                  {%- elsif section.blocks.size == 1 and block.settings.button_link != blank -%}
                    <a class="full-unstyled-link" href="{{ block.settings.button_link }}" {{ block.shopify_attributes }} aria-label="{{ block.settings.button_label | escape }}"></a>
                  {%- endif -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Video with text",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "header",
      "content": "External video"
    },
    {
      "type": "paragraph",
      "content": "Use a YouTube or Vimeo URL when no Shopify-hosted video is selected."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "label": "External video URL"
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "label": "Loop video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_hosted_video_autoplay",
      "label": "Autoplay Shopify-hosted video",
      "info": "When enabled, uploaded Shopify videos render immediately without the poster thumbnail. Videos autoplay inline and stay muted unless audio is enabled below.",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_hosted_video_autoplay_audio",
      "label": "Play audio on autoplayed Shopify video",
      "info": "Turns audio on for autoplayed Shopify-hosted videos. Some browsers may still block autoplay when sound is enabled.",
      "default": false
    },
    {
      "type": "text",
      "id": "description",
      "label": "Video description",
      "info": "Used for accessible poster alt text."
    },
    {
      "type": "header",
      "content": "Poster image"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Poster image"
    },
    {
      "type": "image_picker",
      "id": "cover_image_mobile",
      "label": "Mobile poster image"
    },
    {
      "type": "checkbox",
      "id": "use_hosted_video_preview_image",
      "label": "Use Shopify video thumbnail as poster",
      "info": "When enabled, uploaded Shopify videos use their built-in thumbnail before falling back to the custom cover image.",
      "default": true
    },
