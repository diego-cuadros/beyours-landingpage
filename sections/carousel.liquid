{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --carousel-columns-desktop: {{ section.settings.columns_desktop | default: 4 }};
    --carousel-desktop-side-padding: {{ section.settings.desktop_side_padding | default: 0 }}px;
    --carousel-card-width-mobile: {{ section.settings.card_width_mobile }}%;
    --carousel-testimonial-image-radius: {{ section.settings.testimonial_image_radius | default: 0 }}px;
    --carousel-card-element-gap: {{ section.settings.card_element_gap | default: 12 }}px;
    --carousel-icon-size: {{ section.settings.card_image_size | default: 32 }}px;
    --carousel-side-opacity: {{ section.settings.side_card_opacity | default: 75 | times: 0.01 }};
    --carousel-side-opacity-mobile: {{ section.settings.side_card_opacity_mobile | default: 55 | times: 0.01 }};
    --carousel-card-border-width: {% if section.settings.show_card_border %}1px{% else %}0px{% endif %};
    --subheading-font-size: {{ section.settings.subheading_font_size | default: 20 }}px;
    --subheading-color: {{ section.settings.subheading_color | default: '#6b7280' }};
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
    {%- if section.settings.use_custom_colors -%}
      --color-icon: {{ section.settings.colors_icon.red }}, {{ section.settings.colors_icon.green }}, {{ section.settings.colors_icon.blue }};
      --gradient-background: {% if section.settings.gradient_background != blank %}{{ section.settings.gradient_background }}{% else %}{{ section.settings.colors_background }}{% endif %};
      --color-background: {{ section.settings.colors_background.red }}, {{ section.settings.colors_background.green }}, {{ section.settings.colors_background.blue }};
      --color-foreground: {{ section.settings.colors_text.red }}, {{ section.settings.colors_text.green }}, {{ section.settings.colors_text.blue }};
      --color-heading: var(--color-foreground);
    {%- endif -%}
  }

  {%- if section.settings.show_mobile_dots == false -%}
    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .carousel .carousel__indicators {
        display: none;
      }
    }
  {%- endif -%}
{%- endstyle -%}

{{ 'section-guarantees.css' | asset_url | stylesheet_tag }}
{{ 'section-carousel.css' | asset_url | stylesheet_tag }}

<script type='module'>
  import 'carousel-component';
</script>

{%- liquid
  assign custom_class = ''
  if section.settings.use_custom_colors
    if section.settings.colors_background != settings.colors_background
      assign custom_class = custom_class | append: ' carousel--colored'
    endif

    if section.settings.colors_icon != section.settings.colors_background
      assign custom_class = custom_class | append: ' carousel-icon--colored'
    endif
  endif
-%}

{%- if section.settings.show_divider %}
  <div class='section--divider'>
{%- endif -%}
<div class='page-width{% if section.settings.full_width %} page-width--full-width{% endif %}'>
  <div class='carousel section--padding{{ custom_class }}'>
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class='title-wrapper{% if section.settings.heading == blank %} title-wrapper--no-heading{% endif %} {{ section.settings.heading_alignment }}'>
        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class='title {{ section.settings.heading_size }}'>
            {%- render 'highlight-text',
              hl_input: section.settings.heading,
              hl_style: section.settings.highlight_style,
              hl_enable: section.settings.enable_highlight,
              hl_animateWrap: true
            -%}
          </{{ section.settings.heading_tag }}>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <{{ section.settings.subheading_tag }} class='carousel__subheading {{ section.settings.subheading_size }}'>
            {{ section.settings.subheading }}
          </{{ section.settings.subheading_tag }}>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <carousel-component
        class='carousel__component'
        data-autorotate='{{ section.settings.autorotate }}'
        data-autorotate-speed='{{ section.settings.autorotate_speed | times: 1000 }}'
      >
        <div class='carousel__track-wrapper'>
          <div
            id='Carousel-{{ section.id }}'
            class='carousel__track'
            role='list'
            tabindex='0'
            aria-label='{{ 'accessibility.guarantees_list_scrollable' | t }}'
            aria-roledescription='carousel'
          >
            {%- for block in section.blocks -%}
              <div class='carousel__slide{% if forloop.first %} is-selected{% endif %}' role='listitem' {{ block.shopify_attributes }}>
                <use-animate
                  data-animate='zoom-fade'
                  class='carousel__card guarantee__item {{ section.settings.column_alignment }} guarantee-icon--{{ block.settings.icon_size }}'
                >
                  {%- if block.settings.custom_icon != blank -%}
                    <span class='image-animate guarantee__icon'>
                      {{ block.settings.custom_icon }}
                    </span>
                  {%- elsif block.settings.image != blank -%}
                    <span class='image-animate guarantee__icon'>
                      <img
                        srcset='{{ block.settings.image | image_url: width: 26 }} 1x, {{ block.settings.image | image_url: width: 52 }} 2x'
                        src='{{ block.settings.image | image_url: width: 26 }}'
                        alt='{{ block.settings.image.alt | escape }}'
                        loading='lazy'
                        width='26'
                        height='{{ 26 | divided_by: block.settings.image.aspect_ratio | ceil }}'
                        is='lazy-image'
                      >
                    </span>
                  {%- elsif block.settings.icon != 'none' -%}
                    <span class='image-animate guarantee__icon'>
                      {% render 'icon-guarantee', icon: block.settings.icon %}
                    </span>
                  {%- endif -%}
                  <div>
                    {%- if block.settings.title != blank -%}
                      <p class='{{ block.settings.title_size }}'>
                        {%- render 'highlight-text',
                          hl_input: block.settings.title,
                          hl_style: block.settings.highlight_style,
                          hl_enable: block.settings.enable_highlight,
                          hl_animateWrap: true
                        -%}
                      </p>
                    {%- endif -%}
                    {%- if block.settings.text != blank -%}
                      <div class='rte typeset'>
                        {%- render 'highlight-text',
                          hl_input: block.settings.text,
                          hl_style: block.settings.highlight_style,
                          hl_enable: block.settings.enable_highlight,
                          hl_animateWrap: true
                        -%}
                      </div>
                    {%- endif -%}
                  </div>
                </use-animate>
              </div>
            {%- endfor -%}
          </div>
        </div>
        <p class='carousel__status visually-hidden' aria-live='polite' aria-atomic='true'></p>
        {%- if section.blocks.size > 1 -%}
          <div class='carousel__indicators' role='tablist'>
            {%- for block in section.blocks -%}
              <button
                class='carousel__indicator{% if forloop.first %} is-active{% endif %}'
                data-carousel-indicator='{{ forloop.index0 }}'
                aria-label='Go to slide {{ forloop.index }}'
                role='tab'
                aria-selected='{% if forloop.first %}true{% else %}false{% endif %}'
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </carousel-component>
    {%- endif -%}
  </div>
</div>
{%- if section.settings.show_divider -%}
  </div>
{%- endif -%}

