{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .dc_tcwi-section {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  #shopify-section-{{ section.id }} .dc_tcwi__heading {
    font-size: 63px;
    font-weight: 600;
    margin-bottom: 0;
    text-align: {{ section.settings.heading_alignment }};
  }

  #shopify-section-{{ section.id }} .dc_tcwi__subheading {
    font-size: 17px;
    font-weight: 400;
    margin: 8px 0px 40px 0px;
    text-align: {{ section.settings.heading_alignment }};
  }

  #shopify-section-{{ section.id }} .dc_tcwi__grid,
  #shopify-section-{{ section.id }} .dc_tcwi__track {
    display: flex;
    flex-wrap: wrap;
    gap: 30px;
    justify-content: {{ section.settings.grid_alignment }};
  }

  #shopify-section-{{ section.id }} .dc_tcwi__carousel-track-wrapper {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__carousel .carousel__track {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__carousel .carousel__track::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__block {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 0 1 {% if section.blocks.size == 3 %}calc((100% - 60px) / 3){% elsif section.blocks.size == 4 %}calc((100% - 90px) / 4){% else %}calc((100% - 120px) / 5){% endif %};
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__block-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__block-inner:hover {
    opacity: 0.85;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__image-wrapper {
    max-width: 220px;
    width: 100%;
    margin-bottom: 20px;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__image-wrapper img,
  #shopify-section-{{ section.id }} .dc_tcwi__image-wrapper svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Styles for switching images to icon size */
  .dc_tcwi__turn-to-icon-size__wrapper{
    display:flex;
    max-width: 160px !important;
    justify-content: center;
  }

  .dc_tcwi__turn-to-icon-size__wrapper img{
    width: 80px !important;
    height: auto !important;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__content {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__title {
    font-size: 30px;
    font-weight: 500;
    margin: 0 0 10px;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__text {
    font-size: 18px;
    font-weight: 400;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__dose-grid {
    display: grid;
    grid-template-columns: repeat(2, 22px);
    grid-template-rows: repeat(2, 22px);
    gap: 3px;
    justify-content: center;
    margin-bottom: 20px;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__dose-square {
    width: 22px;
    height: 22px;
    border-radius: 4px;
    box-shadow: inset 0 0 0 1.5px currentColor;
    background: transparent;
    display: inline-block;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__dose-square--filled {
    background: currentColor;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__carousel .carousel__indicators {
    display: none;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__carousel .carousel__indicator {
    width: 8px;
    height: 8px;
    margin: 0;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(var(--color-foreground), 0.25);
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .dc_tcwi__carousel .carousel__indicator.is-active {
    background: rgb(var(--color-foreground));
  }

  {%- if section.blocks.size >= 5 -%}
    #shopify-section-{{ section.id }} .dc_tcwi__title {
      font-size: 25px;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__text {
      font-size: 16px;
    }
  {%- endif -%}

  @media screen and (min-width: 750px) and (max-width: 989px) {
    #shopify-section-{{ section.id }} .dc_tcwi__carousel-component {
      margin-left: -1.5rem;
      margin-right: -1.5rem;
      display: block;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__carousel-track-wrapper {
      padding-inline: 1.5rem;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__carousel .carousel__track {
      flex-wrap: nowrap;
      gap: 0;
      justify-content: flex-start;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__carousel .carousel__slide {
      width: calc(100% / 3);
      flex: 0 0 calc(100% / 3);
      padding: 0 0.75rem;
      box-sizing: border-box;
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__carousel .carousel__indicators {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
      margin-top: 20px;
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .dc_tcwi__heading {
      font-size: 28px;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__subheading {
      font-size: 15px;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__block {
      flex: 0 1 {% if section.settings.columns_mobile == '2' %}calc((100% - 30px) / 2){% else %}100%{% endif %};
    }

    #shopify-section-{{ section.id }} .dc_tcwi__image-wrapper {
      max-width: 120px;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__title {
      font-size: 20px;
      line-height: 1.3;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__text {
      font-size: 14px;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__carousel-component {
      margin-left: -1.5rem;
      margin-right: -1.5rem;
      display: block;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__carousel-track-wrapper {
      padding-inline: 1.5rem;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__carousel .carousel__track {
      flex-wrap: nowrap;
      gap: 0;
      justify-content: flex-start;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__carousel .carousel__slide {
      width: 100%;
      flex: 0 0 100%;
      padding: 0 1.2rem;
      box-sizing: border-box;
      scroll-snap-align: center;
      scroll-snap-stop: always;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__carousel-track-wrapper {
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .dc_tcwi__carousel .carousel__indicators {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
      margin-top: 20px;
    }
  }
{%- endstyle -%}

<div class="dc_tcwi-section">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="dc_tcwi__heading" style="margin-bottom: {{ section.settings.heading_margin_bottom }}px;">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="dc_tcwi__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}

    {%- if section.settings.enable_mobile_carousel -%}
      <div class="dc_tcwi__carousel dc_tcwi__carousel-component carousel__component" data-section-id="{{ section.id }}">
        <div class="dc_tcwi__carousel-track-wrapper">
          <div
            id="Carousel-{{ section.id }}"
            class="dc_tcwi__track carousel__track"
            role="list"
            tabindex="0"
            aria-roledescription="carousel"
          >
            {%- for block in section.blocks -%}
              <div
                class="dc_tcwi__block carousel__slide{% if forloop.first %} is-selected{% endif %}"
                role="listitem"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="dc_tcwi__block-inner">
                {%- else -%}
                  <div class="dc_tcwi__block-inner">
                {%- endif -%}

                {%- if block.settings.show_dose_squares -%}
                  <div class="dc_tcwi__dose-grid" aria-hidden="true">
                    {%- assign fc = block.settings.fill_count -%}
                    <span class="dc_tcwi__dose-square{% if fc >= 1 %} dc_tcwi__dose-square--filled{% endif %}"></span>
                    <span class="dc_tcwi__dose-square{% if fc >= 2 %} dc_tcwi__dose-square--filled{% endif %}"></span>
                    <span class="dc_tcwi__dose-square{% if fc >= 3 %} dc_tcwi__dose-square--filled{% endif %}"></span>
                    <span class="dc_tcwi__dose-square{% if fc >= 4 %} dc_tcwi__dose-square--filled{% endif %}"></span>
                  </div>
                {%- elsif block.settings.image != blank -%}
                  <div class="dc_tcwi__image-wrapper {% if block.settings.turn_to_icon_size %} dc_tcwi__turn-to-icon-size__wrapper {% endif %}">
                    {{
                      block.settings.image
                      | image_url: width: 500
                      | image_tag:
                        loading: 'lazy',
                        widths: '120, 220, 440, 500',
                        sizes: '(min-width: 750px) 220px, 120px',
                        is: 'lazy-image'
                    }}
                  </div>
                {%- else -%}
                  <div class="dc_tcwi__image-wrapper">
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {%- endif -%}

                <div class="dc_tcwi__content">
                  {%- if block.settings.title != blank -%}
                    <p class="dc_tcwi__title">{{ block.settings.title | escape }}</p>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <div
                      class="dc_tcwi__text"
                      {%- if block.settings.text_color != blank %}
                        style="color: {{ block.settings.text_color }};"
                      {% endif %}
                    >
                      {{ block.settings.text }}
                    </div>
                  {%- endif -%}
                </div>

                {%- if block.settings.link != blank -%}
                  </a>
                {%- else -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
        <p class="carousel__status visually-hidden" aria-live="polite" aria-atomic="true"></p>
        {%- if section.blocks.size > 1 -%}
          <div class="carousel__indicators" role="tablist">
            {%- for block in section.blocks -%}
              <button
                class="carousel__indicator{% if forloop.first %} is-active{% endif %}"
                data-carousel-indicator="{{ forloop.index0 }}"
                aria-label="Go to slide {{ forloop.index }}"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- else -%}
      <div class="dc_tcwi__grid">
        {%- for block in section.blocks -%}
          <div class="dc_tcwi__block" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="dc_tcwi__block-inner">
            {%- else -%}
              <div class="dc_tcwi__block-inner">
            {%- endif -%}

            {%- if block.settings.show_dose_squares -%}
              <div class="dc_tcwi__dose-grid" aria-hidden="true">
                {%- assign fc = block.settings.fill_count -%}
                <span class="dc_tcwi__dose-square{% if fc >= 1 %} dc_tcwi__dose-square--filled{% endif %}"></span>
                <span class="dc_tcwi__dose-square{% if fc >= 2 %} dc_tcwi__dose-square--filled{% endif %}"></span>
                <span class="dc_tcwi__dose-square{% if fc >= 3 %} dc_tcwi__dose-square--filled{% endif %}"></span>
                <span class="dc_tcwi__dose-square{% if fc >= 4 %} dc_tcwi__dose-square--filled{% endif %}"></span>
              </div>
            {%- elsif block.settings.image != blank -%}
              <div class="dc_tcwi__image-wrapper">
                {{
                  block.settings.image
                  | image_url: width: 500
                  | image_tag:
                    loading: 'lazy',
                    widths: '120, 220, 440, 500',
                    sizes: '(min-width: 750px) 220px, 120px',
                    is: 'lazy-image'
                }}
              </div>
            {%- else -%}
              <div class="dc_tcwi__image-wrapper">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}

            <div class="dc_tcwi__content">
              {%- if block.settings.title != blank -%}
                <p class="dc_tcwi__title">{{ block.settings.title | escape }}</p>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div
                  class="dc_tcwi__text"
                  {%- if block.settings.text_color != blank %}
                    style="color: {{ block.settings.text_color }};"
                  {% endif %}
                >
                  {{ block.settings.text }}
                </div>
              {%- endif -%}
            </div>

            {%- if block.settings.link != blank -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{%- if section.settings.enable_mobile_carousel -%}
  <script>
    (() => {
      const sectionEl = document.getElementById('shopify-section-{{ section.id }}');
      if (!sectionEl) return;

      const carousel = sectionEl.querySelector('.dc_tcwi__carousel-component');
      const track = sectionEl.querySelector('#Carousel-{{ section.id }}');
      const slides = track ? Array.from(track.querySelectorAll('.carousel__slide')) : [];
      const dots = carousel ? Array.from(carousel.querySelectorAll('.carousel__indicator')) : [];
      const isCarousel = window.matchMedia('(max-width: 989px)');
      let rafId = null;

      if (!carousel || !track || !slides.length) return;

      const setActive = (index) => {
        dots.forEach((dot, dotIndex) => {
          const isActive = dotIndex === index;
          dot.classList.toggle('is-active', isActive);
          dot.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });

        const status = carousel.querySelector('.carousel__status');
        if (status) {
          status.textContent = `Slide ${index + 1} of ${slides.length}`;
        }
      };

      const getClosestIndex = () => {
        let closestIndex = 0;
        let closestDistance = Number.POSITIVE_INFINITY;
        const currentLeft = track.scrollLeft;

        slides.forEach((slide, index) => {
          const distance = Math.abs(slide.offsetLeft - currentLeft);
          if (distance < closestDistance) {
            closestDistance = distance;
            closestIndex = index;
          }
        });

        return closestIndex;
      };

      const handleScroll = () => {
        if (!isCarousel.matches) return;
        if (rafId) cancelAnimationFrame(rafId);

        rafId = requestAnimationFrame(() => {
          rafId = null;
          setActive(getClosestIndex());
        });
      };

      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          if (!isCarousel.matches) return;
          const targetSlide = slides[index];
          if (!targetSlide) return;
          track.scrollTo({ left: targetSlide.offsetLeft, behavior: 'smooth' });
          setActive(index);
        });
      });

      track.addEventListener('scroll', handleScroll, { passive: true });
      setActive(0);
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "📼 Columns with images",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Active ingredients",
      "label": "Heading"
    },
    {
      "id": "heading_margin_bottom",
      "type": "range",
      "min": 0,
      "max": 60,
      "label": "Heading margin bottom",
      "default": 0
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "grid_alignment",
      "label": "Grid alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "1"
    },
    {
      "type": "checkbox",
      "id": "enable_mobile_carousel",
      "label": "Enable mobile carousel",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "checkbox",
          "id": "turn_to_icon_size",
          "label": "Turn image to icon size (80px)",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_dose_squares",
          "label": "Show dose squares instead of image",
          "default": false
        },
        {
          "type": "range",
          "id": "fill_count",
          "label": "Filled squares (0–4)",
          "min": 0,
          "max": 4,
          "step": 1,
          "default": 1
        },
        {
          "type": "text",
          "id": "title",
          "default": "Column title",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post.</p>",
          "label": "Description"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "📼 Columns with images",
      "blocks": [{ "type": "column" }, { "type": "column" }, { "type": "column" }]
    }
  ]
}
{% endschema %}
