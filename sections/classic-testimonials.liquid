<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>

<style>
  #shopify-section-{{ section.id }} .dc_ct-wrapper {
    max-width: 1280px;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .dc_ct-wrapper {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  #shopify-section-{{ section.id }} .dc_ct-heading {
    text-align: {{ section.settings.heading_alignment }};
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    font-weight: 600;
    margin: 0 0 2.4rem 0;
    line-height: 1.2;
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .dc_ct-heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }
  }

  #shopify-section-{{ section.id }} .dc_ct-panel {
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 80px 50px;
    overflow: hidden;
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .dc_ct-panel {
      padding: 40px 25px;
    }
  }

  /* Slider list */
  #shopify-section-{{ section.id }} .dc_ct-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  #shopify-section-{{ section.id }} .dc_ct-list::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .dc_ct-list {
    transition: height 0.35s ease;
  }

  /* Slide layout */
  #shopify-section-{{ section.id }} .dc_ct-slide {
    min-width: 100%;
    width: 100%;
    scroll-snap-align: start;
    flex-shrink: 0;
  }

  /* Avatar row */
  #shopify-section-{{ section.id }} .dc_ct-avatar {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 2.4rem;
  }

  #shopify-section-{{ section.id }} .dc_ct-avatar__img-wrap {
    width: 7rem;
    height: 7rem;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: rgba(0,0,0,0.06);
  }

  #shopify-section-{{ section.id }} .dc_ct-avatar__img-wrap img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  #shopify-section-{{ section.id }} .dc_ct-avatar__name {
    display: block;
    font-size: 19px;
    font-weight: 400;
    line-height: 1.3;
  }

  @media only screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .dc_ct-avatar__name {
      font-size: 17px;
    }
  }

  #shopify-section-{{ section.id }} .dc_ct-avatar__title {
    display: block;
    font-size: 14px;
    color: #1d1d1d;
    line-height: 1.3;
    margin-top: 0.2rem;
  }

  @media only screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .dc_ct-avatar__title {
      font-size: 13px;
    }
  }

  /* Quote */
  #shopify-section-{{ section.id }} .dc_ct-quote {
    border-inline-start:none;
    color: #1d1d1d;
    font-family: "New York", "Iowan Old Style", "Apple Garamond", Baskerville, "Times New Roman", "Droid Serif", Times, "Source Serif Pro", serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-weight: 400;
    font-style: normal;
    font-size: {{ section.settings.quote_font_size }}px;
    line-height: {{ section.settings.quote_line_height }};
    padding: 0px;
    margin: 0;
    width:85%;
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .dc_ct-quote {
      font-size: 22.5px;
      hyphens: auto;
      width:100%;
    }
  }

  /* Navigation */
  #shopify-section-{{ section.id }} .dc_ct-nav {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-top: 2.8rem;
  }

  #shopify-section-{{ section.id }} .dc_ct-nav__btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.2s;
  }

  #shopify-section-{{ section.id }} .dc_ct-nav__btn[disabled] {
    opacity: 0.3;
    cursor: default;
  }

  #shopify-section-{{ section.id }} .dc_ct-dots {
    display: flex;
    gap: 0.6rem;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .dc_ct-dot {
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: #d1d5db;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s, width 0.2s;
  }

  #shopify-section-{{ section.id }} .dc_ct-dot.is-active {
    background: #111;
    width: 2.2rem;
    border-radius: 0.5rem;
  }
</style>

<div class="dc_ct-wrapper page-width">
  {%- if section.settings.heading != blank -%}
    <h2 class="dc_ct-heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="dc_ct-panel">
      <quote-slider class="slider-mobile-gutter">
        <ul
          id="Slider-{{ section.id }}"
          class="dc_ct-list slider"
          role="list"
        >
          {%- for block in section.blocks -%}
            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="dc_ct-slide slider__slide"
              {% if forloop.first %}
                aria-current="true"
              {% endif %}
              {{ block.shopify_attributes }}
            >
              <div class="dc_ct-slide__inner">
                <div class="dc_ct-avatar">
                  {%- if block.settings.image != blank -%}
                    <div class="dc_ct-avatar__img-wrap">
                      <img
                        src="{{ block.settings.image | image_url: width: 140, height: 140, crop: 'center' }}"
                        alt="{{ block.settings.image.alt | escape }}"
                        srcset="{{ block.settings.image | image_url: width: 70, height: 70, crop: 'center' }} 70w, {{ block.settings.image | image_url: width: 140, height: 140, crop: 'center' }} 140w"
                        loading="lazy"
                        width="70"
                        height="70"
                      >
                    </div>
                  {%- endif -%}
                  <div>
                    {%- if block.settings.author_name != blank -%}
                      <span class="dc_ct-avatar__name">{{ block.settings.author_name | escape }}</span>
                    {%- endif -%}
                    {%- if block.settings.author_title != blank -%}
                      <span class="dc_ct-avatar__title">{{ block.settings.author_title | escape }}</span>
                    {%- endif -%}
                  </div>
                </div>

                {%- if block.settings.quote != blank -%}
                  <blockquote class="dc_ct-quote">{{ block.settings.quote }}</blockquote>
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ul>

        {%- if section.blocks.size > 1 -%}
          <div class="dc_ct-nav no-js-hidden">
            <button
              type="button"
              class="dc_ct-nav__btn"
              name="previous"
              aria-label="{{ 'general.slider.previous_slide' | t }}"
            >
              <svg fill="none" height="13" viewBox="0 0 8 13" width="8" xmlns="http://www.w3.org/2000/svg">
                <g fill="currentColor"><path d="m7.91419 1.41431-6.48529 6.48528-1.4142102-1.41422 6.4852802-6.48527702z"/><path d="m6.48528 12.9849-6.48528027-6.48532 1.41421027-1.41421 6.48528 6.48523z"/></g>
              </svg>
            </button>

            <div class="dc_ct-dots" role="tablist">
              {%- for block in section.blocks -%}
                <button
                  type="button"
                  class="dc_ct-dot{% if forloop.first %} is-active{% endif %}"
                  data-index="{{ forloop.index0 }}"
                  aria-label="Slide {{ forloop.index }}"
                  role="tab"
                ></button>
              {%- endfor -%}
            </div>

            <button type="button" class="dc_ct-nav__btn" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
              <svg width="9" height="13" viewBox="0 0 9 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0.914169 11.5857L7.39945 5.10041L8.81367 6.51463L2.32838 12.9999L0.914169 11.5857Z" fill="currentColor"/><path d="M2.34307 0.0151367L8.82835 6.50042L7.41414 7.91463L0.928857 1.42935L2.34307 0.0151367Z" fill="currentColor"/>
              </svg>
            </button>
          </div>
        {%- endif -%}
      </quote-slider>
    </div>
  {%- endif -%}
</div>

<script>
  (function () {
    const section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    const slider = section.querySelector('#Slider-{{ section.id }}');
    const dots = section.querySelectorAll('.dc_ct-dot');
    const quoteSlider = section.querySelector('quote-slider');

    if (!slider || !quoteSlider) return;

    let currentIndex = 0;
    let observer = null;

    function setSliderHeight(inner) {
      if (!inner) return;
      slider.style.height = inner.offsetHeight + 'px';
    }

    function watchSlide(index) {
      const slides = slider.querySelectorAll('[id^="Slide-"]');
      if (!slides[index]) return;
      const inner = slides[index].querySelector('.dc_ct-slide__inner');
      if (!inner) return;

      // Stop watching previous slide
      if (observer) observer.disconnect();

      // Immediately measure
      setSliderHeight(inner);

      // Re-measure automatically whenever content size changes (fonts, reflow)
      observer = new ResizeObserver(() => setSliderHeight(inner));
      observer.observe(inner);
    }

    // Start watching first slide
    watchSlide(0);

    // Sync dots + height when slide changes
    quoteSlider.addEventListener('slideChanged', (e) => {
      currentIndex = e.detail.currentPage - 1;
      dots.forEach((dot, i) => dot.classList.toggle('is-active', i === currentIndex));
      watchSlide(currentIndex);
    });

    // Click dot to jump to slide
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.dataset.index, 10);
        const slides = slider.querySelectorAll('[id^="Slide-"]');
        if (slides[index]) {
          slider.scrollTo({ left: slides[index].offsetLeft, behavior: 'smooth' });
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "📼 Classic Testimonials",
  "tag": "section",
  "class": "dc_classic-testimonials-section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Endorsed by leading health professionals and high achievers"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "number",
      "id": "heading_font_size_desktop",
      "label": "Heading font size — desktop (px)",
      "default": 48
    },
    {
      "type": "number",
      "id": "heading_font_size_mobile",
      "label": "Heading font size — mobile (px)",
      "default": 28
    },
    {
      "type": "header",
      "content": "Quote Typography"
    },
    {
      "type": "range",
      "id": "quote_font_size",
      "label": "Quote font size (desktop)",
      "min": 14,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "quote_line_height",
      "label": "Quote line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.6
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Avatar image"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Author Name"
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author title",
          "default": "Title"
        },
        {
          "type": "richtext",
          "id": "quote",
          "label": "Quote",
          "default": "<p>\"Add your testimonial quote here.\"</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "📼Classic Testimonials",
      "blocks": [{ "type": "testimonial" }, { "type": "testimonial" }, { "type": "testimonial" }]
    }
  ]
}
{% endschema %}
