{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --image-position: {{ section.settings.image_position }};
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
    --featured-blog-v2-subheading-font-size: {{ section.settings.subheading_font_size | default: 20 }}px;
    --featured-blog-v2-subheading-color: {{ section.settings.subheading_color | default: '#6b7280' }};
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .featured-blog-v2__post--mobile-hidden {
      display: none;
    }
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .featured-blog-v2__post--desktop-hidden {
      display: none;
    }
  }

  #shopify-section-{{ section.id }} .featured-blog-v2__subheading {
    margin: 0.75rem 0 0;
    font-size: var(--featured-blog-v2-subheading-font-size);
    line-height: 1.3;
    color: var(--featured-blog-v2-subheading-color, rgba(var(--color-foreground), 0.7));
  }

  #shopify-section-{{ section.id }} .featured-blog-v2__heading-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  #shopify-section-{{ section.id }} .featured-blog-v2__heading-group .featured-blog-v2__subheading {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .title-wrapper.center .featured-blog-v2__heading-group {
    align-items: center;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .title-wrapper.right .featured-blog-v2__heading-group {
    align-items: flex-end;
    text-align: right;
  }

  #shopify-section-{{ section.id }} .featured-blog-v2__view-all-read-more {
    color: rgb(var(--color-link));
    text-decoration: none;
    font-size: 1.4rem;
    line-height: calc(1 + 0.6 / var(--font-body-scale));
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .featured-blog-v2__view-all-read-more::before {
    content: '';
    width: 2rem;
    height: 0.1rem;
    display: inline-block;
    vertical-align: middle;
    margin-inline-end: 1rem;
    background-color: currentColor;
    transition: width var(--duration-default) ease;
  }

  @media screen and (hover: hover) {
    #shopify-section-{{ section.id }} .featured-blog-v2__view-all-read-more:hover::before {
      width: 4rem;
    }
  }
{%- endstyle -%}

<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-card.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-article-card.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'section-featured-blog.css' | asset_url }}" media="print" onload="this.media='all'">

<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-card.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-article-card.css' | asset_url | stylesheet_tag }}</noscript>

{{ 'section-featured-blog.css' | asset_url | stylesheet_tag }}

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="blog page-width">
    {%- liquid
      assign desktop_post_limit = section.settings.post_limit
      assign mobile_post_limit = section.settings.post_limit_mobile | default: desktop_post_limit
      assign render_post_limit = desktop_post_limit
      if mobile_post_limit > render_post_limit
        assign render_post_limit = mobile_post_limit
      endif

      assign selected_articles_count = 0
      for block in section.blocks
        if block.type == 'post' and block.settings.article != blank
          assign selected_articles_count = selected_articles_count | plus: 1
        endif
      endfor

      assign desktop_needs_view_all = false
      assign should_show_view_all = false
      if section.settings.view_all_link != blank and section.settings.show_view_all
        assign should_show_view_all = true
      endif

      if should_show_view_all
        assign desktop_needs_view_all = true
      endif

      assign show_inline_view_all = false
      if section.settings.view_all_inline_with_header and section.settings.heading != blank and should_show_view_all
        assign show_inline_view_all = true
      endif

      assign show_bottom_desktop_view_all = desktop_needs_view_all
      if show_inline_view_all
        assign show_bottom_desktop_view_all = false
      endif

      assign view_all_is_read_more_style = false
      if section.settings.view_all_button_style == 'read_more'
        assign view_all_is_read_more_style = true
      endif

      assign view_all_label = section.settings.view_all_label | strip
      if view_all_label == blank
        assign view_all_label = 'sections.featured_blog.view_all' | t
      endif
    -%}
    <div class="title-wrapper{% if section.settings.heading == blank %} title-wrapper--no-heading{% endif %} {{ section.settings.heading_alignment }}">
      <div class="featured-blog-v2__heading-group">
        <{{ section.settings.heading_tag }} class="title {{ section.settings.heading_size }}">
          {%- render 'highlight-text', 
            hl_input: section.settings.heading, 
            hl_style: section.settings.highlight_style,
            hl_enable: section.settings.enable_highlight,
            hl_animateWrap: true -%}
        </{{ section.settings.heading_tag }}>

        {%- if section.settings.subheading != blank -%}
          <{{ section.settings.subheading_tag }} class="featured-blog-v2__subheading {{ section.settings.subheading_size }}">
            {{ section.settings.subheading }}
          </{{ section.settings.subheading_tag }}>
        {%- endif -%}
      </div>
      
      {%- if show_inline_view_all -%}
        {%- if view_all_is_read_more_style -%}
          <a href="{{ section.settings.view_all_link }}" class="featured-blog-v2__view-all-read-more small-hide medium-hide">
            {{ view_all_label }}
          </a>
        {%- else -%}
          <a href="{{ section.settings.view_all_link }}" class="button{% unless section.settings.view_all_button_style == 'primary' %} button--{{ section.settings.view_all_button_style }}{% endunless %} small-hide medium-hide">
            {{ view_all_label }}
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>
    {%- if selected_articles_count > 0 -%}
      <slider-component class="slider-mobile-gutter">
        <ul id="Slider-{{ section.id }}"
          class="blog__posts articles-wrapper flex-grid flex-grid--2-col{% if section.settings.columns_mobile == '1' %} flex-grid--1-col-mobile{% endif %}{% if section.settings.post_limit < 5 %} flex-grid--{{ section.settings.post_limit }}-col-tablet{% else %} flex-grid--3-col-tablet{% endif %}{% if section.settings.swipe_on_mobile %} slider slider--tablet{% endif %} blog__posts--{{ section.settings.post_limit }}-items"
          role="list"
        >
          {%- assign rendered_post_count = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'post' and block.settings.article != blank -%}
              {%- assign rendered_post_count = rendered_post_count | plus: 1 -%}
              {%- if rendered_post_count > render_post_limit -%}
                {%- break -%}
              {%- endif -%}
              {%- assign article = block.settings.article -%}
              <li id="Slide-{{ section.id }}-{{ rendered_post_count }}"
                class="blog__post flex-grid__item{% if section.settings.swipe_on_mobile %} slider__slide{% endif %}{% if rendered_post_count > mobile_post_limit %} featured-blog-v2__post--mobile-hidden{% endif %}{% if rendered_post_count > desktop_post_limit %} featured-blog-v2__post--desktop-hidden{% endif %}"
                {{ block.shopify_attributes }}
              >
                {% render 'card-article', blog: article.blog, article: article, show_image: section.settings.show_image, image_ratio: section.settings.image_ratio %}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </slider-component>

      {%- if should_show_view_all -%}
        <div class="view-all center{% if show_bottom_desktop_view_all == false %} large-up-hide{% endif %}">
          {%- if view_all_is_read_more_style -%}
            <a href="{{ section.settings.view_all_link }}" class="featured-blog-v2__view-all-read-more">
              {{ view_all_label }}
            </a>
          {%- else -%}
            <a href="{{ section.settings.view_all_link }}" class="button{% unless section.settings.view_all_button_style == 'primary' %} button--{{ section.settings.view_all_button_style }}{% endunless %}">
              {{ view_all_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="placeholder">
        <p class="h2">No posts selected</p>
        <p class="rte-width">Add blocks and pick articles to display in this section.</p>
      </div>
    {%- endif -%}
  </div>
</div>

