{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --image-position: {{ section.settings.image_position }};
    --card-border-radius: {{ section.settings.card_border_radius }}px;
    --multicolumn-v2-subheading-font-size: {{ section.settings.subheading_font_size | default: 20 }}px;
    --multicolumn-v2-subheading-color: {{ section.settings.subheading_color | default: '#6b7280' }};
    --multicolumn-v2-mobile-track-offset: 4rem;
    --multicolumn-v2-side-opacity-mobile: 0.55;
    --multicolumn-v2-dots-gap-mobile: {{ section.settings.mobile_indicator_gap | default: 12 }}px;
    --multicolumn-v2-icon-size: {{ section.settings.icon_size | default: 44 }}px;
    --multicolumn-v2-card-min-height: {{ section.settings.card_min_height | default: 268 }}px;
    --multicolumn-v2-card-min-height-mobile: {{ section.settings.mobile_card_min_height | default: 0 }}px;
    --multicolumn-v2-media-height-multiplier: {% if section.settings.taller_media_desktop %}1.28{% else %}1{% endif %};
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
  }
{%- endstyle -%}

{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}
{{ 'section-multicolumn-v2.css' | asset_url | stylesheet_tag }}

<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>
<script src="{{ 'section-multicolumn.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'section-multicolumn-v2.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign enable_mobile_carousel = false
  if section.blocks.size > 1
    assign enable_mobile_carousel = true
  endif

  assign show_heading_slot = false
  if section.settings.heading_in_grid_desktop
    if section.settings.heading != blank or section.settings.subheading != blank
      assign show_heading_slot = true
    endif
  endif
-%}

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="multicolumn multicolumn-v2 page-width{% if section.settings.taller_media_desktop %} multicolumn-v2--taller-media-desktop{% endif %}{% if section.settings.square_cards_desktop %} multicolumn-v2--square-cards-desktop{% endif %}{% if section.settings.square_cards_mobile %} multicolumn-v2--square-cards-mobile{% endif %}{% unless section.settings.match_card_heights_desktop %} multicolumn-v2--adaptive-cards-desktop{% endunless %}">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="title-wrapper multicolumn-v2__title{% if section.settings.heading == blank %} title-wrapper--no-heading{% endif %}{% if show_heading_slot %} multicolumn-v2__heading-main--mobile-only{% endif %} mobile-{{ section.settings.mobile_text_alignment }} {{ section.settings.heading_alignment }}">
        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="title {{ section.settings.heading_size }}">
            {%- render 'highlight-text',
              hl_input: section.settings.heading,
              hl_style: section.settings.highlight_style,
              hl_enable: section.settings.enable_highlight,
              hl_animateWrap: true
            -%}
          </{{ section.settings.heading_tag }}>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <{{ section.settings.subheading_tag }} class="multicolumn-v2__subheading {{ section.settings.subheading_size }}">
            {{ section.settings.subheading }}
          </{{ section.settings.subheading_tag }}>
        {%- endif -%}
      </div>
    {%- endif -%}

    <multicolumn-v2-component class="slider-mobile-gutter multicolumn-v2__component {{ section.settings.text_alignment }} mobile-{{ section.settings.mobile_text_alignment }}" data-match-card-heights="{{ section.settings.match_card_heights_desktop }}" data-match-card-heights-mobile="{{ section.settings.match_card_heights_mobile }}" data-square-cards-desktop="{{ section.settings.square_cards_desktop }}" data-square-cards-mobile="{{ section.settings.square_cards_mobile }}">
      <div class="multicolumn-v2__track-wrapper">
        <ul
          id="Slider-{{ section.id }}"
          class="multicolumn-list multicolumn-v2__list flex-grid flex-grid--2-col{% if section.settings.columns_mobile == '1' %} flex-grid--1-col-mobile{% endif %} flex-grid--rigid flex-grid--{{ section.settings.columns_desktop }}-col-desktop{% if enable_mobile_carousel %} slider slider--mobile{% endif %}"
          role="list"
        >
            {%- liquid
              if section.settings.image_ratio == 'adapt'
                assign highest_ratio = 1
                for block in section.blocks
                  assign candidate_ratio = blank

                  if block.settings.image != blank
                    assign candidate_ratio = block.settings.image.aspect_ratio
                  elsif block.settings.icon_image != blank
                    assign candidate_ratio = block.settings.icon_image.aspect_ratio
                  elsif block.settings.video != blank and block.settings.video.preview_image != blank
                    assign candidate_ratio = block.settings.video.preview_image.aspect_ratio
                  endif

                  if candidate_ratio != blank and candidate_ratio > highest_ratio
                    assign highest_ratio = candidate_ratio
                  endif
                endfor
              endif
            -%}

            {%- if show_heading_slot -%}
              <li class="multicolumn-list__item multicolumn-v2__heading-card flex-grid__item {{ section.settings.heading_alignment }}">
                <div class="multicolumn-card multicolumn-card--heading multicolumn-v2__heading-card-inner">
                  <div class="multicolumn-v2__heading-card-content">
                    <div class="title-wrapper{% if section.settings.heading == blank %} title-wrapper--no-heading{% endif %} {{ section.settings.heading_alignment }}">
                      {%- if section.settings.heading != blank -%}
                        <{{ section.settings.heading_tag }} class="title {{ section.settings.heading_size }}">
                          {%- render 'highlight-text',
                            hl_input: section.settings.heading,
                            hl_style: section.settings.highlight_style,
                            hl_enable: section.settings.enable_highlight,
                            hl_animateWrap: true
                          -%}
                        </{{ section.settings.heading_tag }}>
                      {%- endif -%}
                      {%- if section.settings.subheading != blank -%}
                        <{{ section.settings.subheading_tag }} class="multicolumn-v2__subheading {{ section.settings.subheading_size }}">
                          {{ section.settings.subheading }}
                        </{{ section.settings.subheading_tag }}>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              </li>
            {%- endif -%}

            {%- for block in section.blocks -%}
              {%- liquid
                assign uploaded_image_display = block.settings.uploaded_image_display | default: 'auto'
                assign uploaded_image_ratio = block.settings.uploaded_image_ratio | default: 'inherit'
                assign block_media_ratio = section.settings.image_ratio
                assign render_as_icon = false
                assign render_as_media = false
                assign icon_source = blank
                assign media_image = block.settings.image

                if uploaded_image_ratio != 'inherit'
                  assign block_media_ratio = uploaded_image_ratio
                endif

                case uploaded_image_display
                  when 'icon'
                    if block.settings.custom_icon != blank or block.settings.icon_image != blank or block.settings.image != blank
                      assign render_as_icon = true
                    endif
                  when 'image'
                    if block.settings.video != blank or block.settings.image != blank or block.settings.icon_image != blank
                      assign render_as_media = true
                    endif
                  else
                    if block.settings.custom_icon != blank or block.settings.icon_image != blank
                      assign render_as_icon = true
                    elsif block.settings.image != blank or block.settings.video != blank
                      assign render_as_media = true
                    endif
                endcase

                if render_as_icon
                  if block.settings.icon_image != blank
                    assign icon_source = block.settings.icon_image
                  elsif block.settings.image != blank
                    assign icon_source = block.settings.image
                  endif
                endif

                if render_as_media and media_image == blank and block.settings.icon_image != blank
                  assign media_image = block.settings.icon_image
                endif

                assign block_ratio_percent = blank
                if render_as_media and block_media_ratio == 'adapt'
                  if uploaded_image_ratio == 'inherit'
                    assign block_ratio_percent = 1 | divided_by: highest_ratio | times: 100
                  elsif media_image != blank
                    assign block_ratio_percent = 1 | divided_by: media_image.aspect_ratio | times: 100
                  elsif block.settings.video != blank and block.settings.video.preview_image != blank
                    assign block_ratio_percent = 1 | divided_by: block.settings.video.preview_image.aspect_ratio | times: 100
                  else
                    assign block_ratio_percent = 100
                  endif
                endif
              -%}
              <li
                id="Slide-{{ section.id }}-{{ forloop.index }}"
                class="multicolumn-list__item multicolumn-v2__item flex-grid__item{% if enable_mobile_carousel %} slider__slide{% endif %}{% if forloop.first %} is-selected{% endif %} {{ section.settings.text_alignment }}"
                {{ block.shopify_attributes }}
              >
                <div class="multicolumn-card{% if render_as_icon %} multicolumn-card--icon{% elsif render_as_media %} multicolumn-card--media{% else %} multicolumn-card--text-only{% endif %}"{% if block.settings.background_color != blank %} style="background-color: {{ block.settings.background_color }};"{% endif %}>
                  {%- if render_as_icon -%}
                    <div class="multicolumn-v2__icon-wrapper">
                      <span class="multicolumn-v2__icon"{% if block.settings.heading_color != blank %} style="color: {{ block.settings.heading_color }};"{% endif %}>
                        {%- if block.settings.custom_icon != blank -%}
                          {{ block.settings.custom_icon }}
                        {%- elsif icon_source != blank -%}
                          {%- liquid
                            assign icon_size = section.settings.icon_size | default: 44
                            assign icon_retina_size = icon_size | times: 2
                          -%}
                          {{
                            icon_source
                            | image_url: width: icon_retina_size
                            | image_tag:
                              loading: 'lazy',
                              widths: '24, 32, 40, 48, 64, 72, 88, 96, 128, 144, 176, 192',
                              sizes: icon_size | append: 'px',
                              class: 'multicolumn-v2__icon-image',
                              alt: icon_source.alt | default: block.settings.title | strip_html
                          }}
                        {%- endif -%}
                      </span>
                    </div>
                  {%- elsif render_as_media -%}
                    <use-animate data-animate="zoom-fade" class="media-wrapper multicolumn-card__image-wrapper multicolumn-card__image-wrapper--{{ section.settings.image_width }}-width{% if section.settings.image_width != 'full' %} multicolumn-card-spacing{% endif %}">
                      <div
                        class="image-animate media media--{{ block_media_ratio }}"
                        {%- if block_media_ratio == 'adapt' %} style="--image-ratio-percent: {{ block_ratio_percent }}%;"{% endif -%}
                      >
                        {%- if block.settings.video != blank -%}
                          <multicolumn-video-item class="video-wrapper" data-video-id="{{ block.settings.video.id }}" data-preview-duration="900">
                            {%- if block.settings.video_poster != blank -%}
                              {%- assign poster_url = block.settings.video_poster | image_url: width: 2000 -%}
                            {%- else -%}
                              {%- assign poster_url = block.settings.video.preview_image | image_url: width: 2000 -%}
                            {%- endif -%}
                            {{ block.settings.video | video_tag: image_size: '1100x',
                              loop: true,
                              controls: false,
                              muted: true,
                              playsinline: true,
                              poster: poster_url,
                              class: 'multicolumn-card__video'
                            }}
                            <button class="video-play-button" aria-label="{{ 'accessibility.play_video' | t }}">
                              <span class="play-icon">{% render 'icon', icon: 'play-alt' %}</span>
                              <span class="pause-icon">{% render 'icon', icon: 'pause' %}</span>
                            </button>
                          </multicolumn-video-item>
                        {%- else -%}
                          {%- liquid
                            assign number_of_columns = section.settings.columns_desktop
                            assign number_of_columns_mobile = section.settings.columns_mobile
                            assign grid_space_desktop = number_of_columns | minus: 1 | times: 30 | plus: 100 | append: 'px'
                            assign grid_space_tablet = number_of_columns_mobile | minus: 1 | times: 30 | plus: 100 | append: 'px'
                            assign grid_space_mobile = number_of_columns_mobile | minus: 1 | times: 30 | divided_by: 2 | plus: 30 | append: 'px'
                            if section.settings.image_width == 'half'
                              assign image_width = 0.5
                            elsif section.settings.image_width == 'third'
                              assign image_width = 0.33
                            else
                              assign image_width = 1
                            endif
                          -%}
                          {% capture sizes %}
                            (min-width: {{ settings.page_width }}px) calc(({{ settings.page_width }}px - {{ grid_space_desktop }}) * {{ image_width }} / {{ number_of_columns }}),
                            (min-width: 990px) calc((100vw - {{ grid_space_desktop }}) * {{ image_width }} / {{ number_of_columns }}),
                            (min-width: 750px) calc((100vw - {{ grid_space_tablet }}) * {{ image_width }} / {{ number_of_columns_mobile }}),
                            calc((100vw - {{ grid_space_mobile }}) * {{ image_width }} / {{ number_of_columns_mobile }})
                          {% endcapture %}
                          {{
                            media_image
                            | image_url: width: 3200
                            | image_tag:
                              loading: 'lazy',
                              widths: '50, 75, 100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500, 2750, 3000, 3200',
                              sizes: sizes,
                              class: 'multicolumn-card__image',
                              is: 'lazy-image'
                          }}
                        {%- endif -%}
                      </div>
                      {%- if block.settings.button_link != blank -%}
                        <a{% if section.settings.open_in_new_tab == true %} target="_blank" rel="noopener noreferrer"{% endif %} href="{{ block.settings.button_link }}" class="focus-inset full-unstyled-link" aria-label="{{ 'accessibility.view_image' | t: title: block.settings.title | default: 'image' }}">&nbsp;</a>
                      {%- endif -%}
                    </use-animate>
                  {%- endif -%}

                  {%- if block.settings.title != blank or block.settings.text != blank or block.settings.button_label != blank -%}
                    <div class="multicolumn-card__info">
                      <div class="multicolumn-card__title-wrapper">
                        <div class="multicolumn-v2__title-column">
                          <p class="multicolumn-card__title {{ block.settings.title_size }}"{% if block.settings.heading_color != blank %} style="color: {{ block.settings.heading_color }};"{% endif %}>
                            {%- render 'highlight-text',
                              hl_input: block.settings.title,
                              hl_style: block.settings.highlight_style,
                              hl_enable: block.settings.enable_highlight,
                              hl_animateWrap: true
                            -%}
                          </p>
                        </div>
                        {%- if block.settings.show_popup and block.settings.text != blank -%}
                          <modal-opener class="multicolumn-card__popup-button" data-modal="#Popup-{{ block.id }}">
                            <button class="multicolumn-card__popup-trigger focus-inset" aria-label="{{ 'accessibility.open_description_popup' | t }}">
                              {% render 'icon', icon: 'plus' %}
                            </button>
                          </modal-opener>
                        {%- endif -%}
                      </div>
                      {%- unless block.settings.show_popup -%}
                        <div class="rte typeset"{% if block.settings.text_color != blank %} style="color: {{ block.settings.text_color }};"{% endif %}>
                          {%- render 'highlight-text',
                            hl_input: block.settings.text,
                            hl_style: block.settings.highlight_style,
                            hl_enable: block.settings.enable_highlight,
                            hl_animateWrap: true
                          -%}
                        </div>
                        {%- if block.settings.button_label != blank -%}
                          {%- if block.settings.button_style_secondary -%}
                            <a{% if section.settings.open_in_new_tab == true %} target="_blank" rel="noopener noreferrer"{% endif %} class="button button--cta focus-inset"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %}>
                              <span class="label">{{ block.settings.button_label | escape }}</span>
                              {% render 'icon', icon: 'arrow' %}
                            </a>
                          {%- else -%}
                            <a{% if section.settings.open_in_new_tab == true %} target="_blank" rel="noopener noreferrer"{% endif %} class="button button--tertiary focus-inset"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %}>
                              {{ block.settings.button_label | escape }}
                            </a>
                          {%- endif -%}
                        {%- endif -%}
                      {%- endunless -%}
                    </div>
                  {%- endif -%}
                </div>
              </li>
            {%- endfor -%}
        </ul>
      </div>

      {%- if enable_mobile_carousel -%}
        <div class="multicolumn-v2__dots no-js-hidden medium-hide large-up-hide" aria-label="Multicolumn slide indicators">
          {%- for block in section.blocks -%}
            <button
              type="button"
              class="multicolumn-v2__dot{% if forloop.first %} is-active{% endif %}"
              data-slide-index="{{ forloop.index }}"
              aria-label="Go to slide {{ forloop.index }}"
              aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
            ></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </multicolumn-v2-component>
  </div>
</div>

{%- for block in section.blocks -%}
  {%- if block.settings.show_popup and block.settings.text != blank -%}
    <modal-dialog id="Popup-{{ block.id }}" class="multicolumn-popup modal">
      <div class="multicolumn-popup__content" role="dialog" aria-modal="true" aria-label="{{ block.settings.title | escape }}" data-image-position="{{ block.settings.popup_image_position }}">
        <button id="ModalClose-{{ block.id }}" type="button" class="multicolumn-popup__close-button" aria-label="{{ 'accessibility.close_popup' | t }}">
          {% render 'icon', icon: 'close' %}
        </button>

        {%- if block.settings.popup_image != blank and block.settings.popup_image_position != 'bottom' -%}
          <div class="media--wrapper">
            <div class="media media--adapt" style="--image-ratio-percent: {{ 1 | divided_by: block.settings.popup_image.aspect_ratio | times: 100 }}%;">
              {{
                block.settings.popup_image
                | image_url: width: 1500
                | image_tag:
                  loading: 'lazy',
                  widths: '300, 400, 500, 600, 700, 800, 900, 1000, 1200, 1500',
                  sizes: '(min-width: 750px) 50vw, 100vw',
                  class: 'image-fit'
              }}
            </div>
          </div>
        {%- endif -%}

        <div class="multicolumn-popup__content-wrapper">
          <div class="multicolumn-popup__text rte{% if block.settings.justify_text %} text-justify{% endif %}"{% if block.settings.text_color != blank %} style="color: {{ block.settings.text_color }};"{% endif %}>
            {%- render 'highlight-text',
              hl_input: block.settings.text,
              hl_style: block.settings.highlight_style,
              hl_enable: block.settings.enable_highlight,
              hl_animateWrap: true
            -%}
          </div>
          {%- if block.settings.popup_image != blank and block.settings.popup_image_position == 'bottom' -%}
            <div class="media--wrapper">
              <div class="media media--adapt" style="--image-ratio-percent: {{ 1 | divided_by: block.settings.popup_image.aspect_ratio | times: 100 }}%;">
                {{
                  block.settings.popup_image
                  | image_url: width: 1500
                  | image_tag:
                    loading: 'lazy',
                    widths: '300, 400, 500, 600, 700, 800, 900, 1000, 1200, 1500',
                    sizes: '(min-width: 750px) 50vw, 100vw',
                    class: 'image-fit'
                }}
              </div>
            </div>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <div class="multicolumn-popup__button-wrapper">
              {%- if block.settings.button_style_secondary -%}
                <a{% if section.settings.open_in_new_tab == true %} target="_blank" rel="noopener noreferrer"{% endif %} class="button button--cta focus-inset"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %}>
                  <span class="label">{{ block.settings.button_label | escape }}</span>
                  {% render 'icon', icon: 'arrow' %}
                </a>
              {%- else -%}
                <a{% if section.settings.open_in_new_tab == true %} target="_blank" rel="noopener noreferrer"{% endif %} class="button button--tertiary focus-inset"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% else %} role="link" aria-disabled="true"{% endif %}>
                  {{ block.settings.button_label | escape }}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </modal-dialog>
  {%- endif -%}
{%- endfor -%}

{% schema %}
{
  "name": "Multicolumn v2",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.all.card_image_ratio.options__1.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.card_image_ratio.options__2.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.card_image_ratio.options__3.label"
        },
        {
          "value": "landscape",
          "label": "t:sections.all.card_image_ratio.options__4.label"
        },
        {
          "value": "wide",
          "label": "t:sections.all.card_image_ratio.options__5.label"
        }
      ],
      "default": "landscape",
      "label": "t:sections.all.card_image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_position",
      "options": [
        {
          "value": "20% 0",
          "label": "t:sections.all.image_position.options__1.label"
        },
        {
          "value": "top center",
          "label": "t:sections.all.image_position.options__2.label"
        },
        {
          "value": "80% 0",
          "label": "t:sections.all.image_position.options__3.label"
        },
        {
          "value": "20% 50%",
          "label": "t:sections.all.image_position.options__4.label"
        },
        {
          "value": "center center",
          "label": "t:sections.all.image_position.options__5.label"
        },
        {
          "value": "80% 50%",
          "label": "t:sections.all.image_position.options__6.label"
        },
        {
          "value": "20% 100%",
          "label": "t:sections.all.image_position.options__7.label"
        },
        {
          "value": "bottom center",
          "label": "t:sections.all.image_position.options__8.label"
        },
        {
          "value": "80% 100%",
          "label": "t:sections.all.image_position.options__9.label"
        }
      ],
      "default": "center center",
      "label": "t:sections.all.image_position.label",
      "info": "t:sections.all.image_position.info"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.all.text_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.all.text_alignment.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.all.text_alignment.options__3.label"
        }
      ],
      "default": "center",
      "label": "t:sections.all.text_alignment.label"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "default": false,
      "label": "t:sections.all.show_divider.label"
    },
    {
      "type": "select",
      "id": "image_width",
      "options": [
        {
          "value": "third",
          "label": "t:sections.multicolumn.settings.image_width.options__1.label"
        },
        {
          "value": "half",
          "label": "t:sections.multicolumn.settings.image_width.options__2.label"
        },
        {
          "value": "full",
          "label": "t:sections.multicolumn.settings.image_width.options__3.label"
        }
      ],
      "default": "full",
      "label": "t:sections.multicolumn.settings.image_width.label"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 24,
      "max": 96,
      "step": 4,
      "unit": "px",
      "label": "Icon size",
      "default": 44
    },
    {
      "type": "range",
      "id": "card_min_height",
      "min": 180,
      "max": 420,
      "step": 4,
