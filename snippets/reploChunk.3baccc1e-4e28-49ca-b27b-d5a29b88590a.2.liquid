<script>
  document.addEventListener("DOMContentLoaded", function() {
  // Function to format date as "Month DD"
  function formatShortBusinessDate(date) {
    return date.toLocaleDateString('en-US', {
      month: 'long',
      day: '2-digit'
    });
  }

  // Get today's date
  const today = new Date();

  // Get date after 3 days
  const after3Days = new Date();
  after3Days.setDate(today.getDate() + 3);

  // Get date after 7 days
  const after7Days = new Date();
  after7Days.setDate(today.getDate() + 7);

  // Output like "November 06 to November 10"
  const formattedRange = `${formatShortBusinessDate(after3Days)} to ${formatShortBusinessDate(after7Days)}`;

  // Update element text
  const dateBlock = document.querySelector(".shipping-block .date-block");
  if (dateBlock) {
    dateBlock.textContent = formattedRange;
  }
});
