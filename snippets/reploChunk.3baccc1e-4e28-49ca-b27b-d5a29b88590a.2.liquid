document.addEventListener("DOMContentLoaded", function () {
  console.log("Dom Loaded by Diego");

  // ---- your existing code ----
  const basePriceSixTeenEl = document.querySelector('[data-price-16-ser="true"]');
  const basePriceFortyEightEl = document.querySelector('[data-price-48-ser="true"]');
  const qtyContainerEl = document.querySelector('[data-quantity-selector="true"]');

  const basePriceSixTeen = basePriceSixTeenEl
    ? parseFloat(basePriceSixTeenEl.textContent.replace(/[^0-9.]/g, ''))
    : 0;

  const basePriceFortyEight = basePriceFortyEightEl
    ? parseFloat(basePriceFortyEightEl.textContent.replace(/[^0-9.]/g, ''))
    : 0;

  const quantity = qtyContainerEl
    ? parseInt(qtyContainerEl.textContent.replace(/[^0-9]/g, ''))
    : 0;

  console.log("Parsed Values:");
  console.log("Base Price 16oz:", basePriceSixTeen);
  console.log("Base Price 48oz:", basePriceFortyEight);
  console.log("Quantity:", quantity);

  // ---- NEW: Watch for quantity changes ----
  if (qtyContainerEl) {
    const updatePrices = () => {
      const newQty = parseInt(qtyContainerEl.textContent.replace(/[^0-9]/g, '')) || 0;
      console.log("New quantity detected:", newQty);

      // Calculate new totals
      const newPrice16 = (basePriceSixTeen * newQty).toFixed(2);
      const newPrice48 = (basePriceFortyEight * newQty).toFixed(2);

      // Update DOM elements with new calculated prices
      if (basePriceSixTeenEl) {
        basePriceSixTeenEl.textContent = `$${newPrice16}`;
      }

      if (basePriceFortyEightEl) {
        basePriceFortyEightEl.textContent = `$${newPrice48}`;
      }

      console.log(`Updated prices — 16oz: $${newPrice16}, 48oz: $${newPrice48}`);
    };

    // Initial calculation
    updatePrices();

    const observer = new MutationObserver(() => {
      updatePrices();
    });

    observer.observe(qtyContainerEl, {
      childList: true,
      characterData: true,
      subtree: true,
    });

    console.log("Now watching for quantity changes...");
  }
});
