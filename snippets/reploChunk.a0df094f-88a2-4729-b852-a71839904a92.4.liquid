1acky2h" aria-hidden="true"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="img" aria-label="Collapse/Expand" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-590s5j" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"></path></svg></div></div><div class="replo-animated" hidden="" id="replo-:R5n32:"><div data-rid="050061f2-3576-408c-b625-e81170a3d289" class="r-1dhb24t"><div data-rid="cfcafb99-4764-4b54-8140-21393ec42a0b" class="r-gy1lwr alchemy-rte"><span style="width:100%"><p><a target="_blank" rel="noopener nofollow noreferrer" href="https://troscriptions.com/blogs/main/cordycepin"><u>Cordycepin</u></a><br><a target="_blank" rel="noopener nofollow noreferrer" href="https://troscriptions.com/blogs/main/5-htp"><u>5-HTP</u></a><br><a target="_blank" rel="noopener nofollow noreferrer" href="https://troscriptions.com/blogs/main/honokiol"><u>Honokiol</u></a><br><a target="_blank" rel="noopener nofollow noreferrer" href="https://troscriptions.com/blogs/main/agarin"><u>Agarin</u></a><br><a target="_blank" rel="noopener nofollow noreferrer" href="https://troscriptions.com/blogs/main/adenosine"><u>Adenosine</u></a><br><a target="_blank" rel="noopener nofollow noreferrer" href="https://troscriptions.com/blogs/main/melatonin"><u>Melatonin</u></a></p></span></div></div></div></div><div data-rid="9a4432e5-5856-4244-993c-dcdcc5e38c38" class="r-zap1ke"></div><div data-rid="1994b880-4678-454b-b6c3-40ad707688ba" class="r-xtpoih" data-replo-collapsible="true" data-state="closed" data-orientation="vertical"><div data-rid="9c560cae-b15d-488d-be0f-d78a6f62c990" aria-expanded="false" aria-controls="replo-:R7n32:" tabindex="0" role="button" class="r-z7nwnn"><div data-rid="429213df-934f-495c-982f-608dba7e52a2" class="r-18ip9ax alchemy-rte"><span style="width:100%"><p>Will it turn my mouth purple?</p></span></div><div data-rid="26ed201e-6433-41e5-8752-302df741c51d" class="r-1yg9u28" aria-hidden="true"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="img" aria-label="Collapse/Expand" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-14naidt" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"></path></svg></div></div><div class="replo-animated" hidden="" id="replo-:R7n32:"><div data-rid="34746564-60a0-47da-876e-01c32a51c988" class="r-bknq0t"><div data-rid="424a3685-f415-41b2-afc3-17dfdbe2b4a4" class="r-tskmx9 alchemy-rte"><span style="width:100%"><p>Just a little. We recommend taking it before you brush your teeth. Let the troche dissolve for 15 minutes between your upper lip between your cheek and gum, then swallow.</p></span></div></div></div></div><div data-rid="bb7ecfdb-a098-49e8-a75a-ac400d8f01c8" class="r-leonc1"></div><div data-rid="c6236464-dadf-4b9e-a555-1a5613e7ac3c" class="r-ea5me8" data-replo-collapsible="true" data-state="closed" data-orientation="vertical"><div data-rid="e57aa5bf-510e-41e2-a96d-56c13e053bb4" aria-expanded="false" aria-controls="replo-:R9n32:" tabindex="0" role="button" class="r-1gscy0o"><div data-rid="b0de0642-8d09-4d18-a4ad-2d797c0abf63" class="r-1itvbms alchemy-rte"><span style="width:100%"><p>Can I see the 3rd party testing?</p></span></div><div data-rid="7b1dd79f-e7f8-48b1-b8ba-653411b94f45" class="r-jsgebv" aria-hidden="true"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="img" aria-label="Collapse/Expand" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-39m6g7" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"></path></svg></div></div><div class="replo-animated" hidden="" id="replo-:R9n32:"><div data-rid="4daeccbf-fc5a-452f-b965-4cc0b9e16e7a" class="r-1brqqwx"><div data-rid="0dc74496-a017-4c5d-85f2-1a47fa391e8c" class="r-1qe652e alchemy-rte"><span style="width:100%"><p>Please email <a href="mailto:buccalup@troscriptions.com">buccalup@troscriptions.com</a> and we are happy to share!</p></span></div></div></div></div><div data-rid="4a7bf8a7-bf88-490e-8928-efa2443671cb" class="r-1y9iw82"></div><div data-rid="bd46b715-e7e9-4aa1-b7c6-437271f1b3f5" class="r-1dgpkb6" data-replo-collapsible="true" data-state="closed" data-orientation="vertical"><div data-rid="85de499a-1a09-4225-b72b-bcdae89385e1" aria-expanded="false" aria-controls="replo-:Rbn32:" tabindex="0" role="button" class="r-4qsjeu"><div data-rid="9d48a518-567a-4e88-b777-32e789f0ee8c" class="r-1dmz536 alchemy-rte"><span style="width:100%"><p>Why does it contain Polyethylene Glycol (PEG)?</p></span></div><div data-rid="7dc140ff-a5b3-4776-99b8-5943e21b1dc4" class="r-1ypi30i" aria-hidden="true"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="img" aria-label="Collapse/Expand" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-10ybghy" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"></path></svg></div></div><div class="replo-animated" hidden="" id="replo-:Rbn32:"><div data-rid="b380f7b6-8695-432e-aae9-81931e010a9c" class="r-1whswpg"><div data-rid="cc8d3f26-592a-4edd-b055-03818ef41a7b" class="r-1cs74s7 alchemy-rte"><span style="width:100%"><p>Polyethylene Glycol is a long-established FDA-approved drug delivery method used around the world, especially by compounding pharmacists. Do not confuse polyethylene glycol with propylene glycol. The latter is antifreeze and will kill you if you drink it…so please don’t do that!  </p><p><br></p><p>Our formulations use polyethylene glycol that is both non-absorbable and very low dose, meaning that it does not get absorbed into your body and it will not cause GI distress or any of those other symptoms/issues that you may have heard about.</p><p><br></p><p>For more information, please see&nbsp;<a target="_blank" rel="noopener nofollow noreferrer" href="https://troscriptions.com/blogs/main/polyethylene-glycol-peg"><u>this article</u></a>&nbsp;for an in-depth explanation.</p></span></div></div></div></div><div data-rid="039fa34c-62c5-42ba-a2a6-8ea8f6bc783a" class="r-1r7za69"></div><div data-rid="e6e2af65-9f96-4804-acad-8e0c7d5e1ffd" class="r-apvwgh" data-replo-collapsible="true" data-state="closed" data-orientation="vertical"><div data-rid="9c99ebdf-1329-406a-948c-ac938b04f17e" aria-expanded="false" aria-controls="replo-:Rdn32:" tabindex="0" role="button" class="r-1hnij3e"><div data-rid="adb7200e-c117-4023-bc0b-abc6945888d5" class="r-rwxw8y alchemy-rte"><span style="width:100%"><p>How many troches am I getting?</p></span></div><div data-rid="f0da7756-fadd-42c4-accb-916b0926eff7" class="r-wk5e95" aria-hidden="true"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="img" aria-label="Collapse/Expand" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-umwtev" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"></path></svg></div></div><div class="replo-animated" hidden="" id="replo-:Rdn32:"><div data-rid="e48c7774-d6a2-46f4-83b4-c7a682e5d164" class="r-1xo0qbg"><div data-rid="a88ded3c-05f3-4933-a9e1-171b988ab5b5" class="r-1w30on0 alchemy-rte"><span style="width:100%"><p>There are 4 whole troches in each package and each troche can be cut into four quarters. Therefore, one pack can yield up to 16 doses, depending on your personalized needs. The troches are scored for easy titration.</p><br><p>Start with 1/4 troche to 1/2 troche and increase the dosage from there until you reach your optimal dose.</p></span></div></div></div></div><div data-rid="753280ce-31be-4a2b-9eb3-9e6a5e8c4b83" class="r-rdm3y0"></div><div data-rid="6baec92c-591b-4f7e-b7d5-5c050419797b" class="r-yon7iw" data-replo-collapsible="true" data-state="closed" data-orientation="vertical"><div data-rid="35417502-1344-4fa8-b92e-7c46a18ba9fb" aria-expanded="false" aria-controls="replo-:Rfn32:" tabindex="0" role="button" class="r-1uol7nc"><div data-rid="6c7e3ee5-0609-485f-b480-f5d1b8f20226" class="r-1mgt2mv alchemy-rte"><span style="width:100%"><p>Are there any contraindications for Tro Zzz™?</p></span></div><div data-rid="d9698612-553b-4011-9c4c-8df5710c449e" class="r-rvz1v7" aria-hidden="true"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="img" aria-label="Collapse/Expand" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-wct84i" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"></path></svg></div></div><div class="replo-animated" hidden="" id="replo-:Rfn32:"><div data-rid="233e443e-ae75-467e-83dc-2ff15d02efcc" class="r-1coal7"><div data-rid="6383505b-e6fc-492f-97d7-e2a9c8731f2e" class="r-17t0sj alchemy-rte"><span style="width:100%"><p>1. Do not take Tro Zzz™ if you are pregnant or breastfeeding.</p><p>2. Do not combine with alcohol or other drugs and supplements that modulate the GABA system without speaking to your healthcare provider.</p><p>3. Do not drive or operate any heavy machinery while taking Tro Zzz™.</p></span></div></div></div></div><div data-rid="59a726c1-ac13-4068-8dd9-adc50c0a823d" class="r-i8hykc"></div><div data-rid="8f614b35-5052-4ddf-a8d4-e9cec738b090" class="r-mk8p18" data-replo-collapsible="true" data-state="closed" data-orientation="vertical"><div data-rid="a54fd346-df39-4ee0-b39d-eec4cc1b65c9" aria-expanded="false" aria-controls="replo-:Rhn32:" tabindex="0" role="button" class="r-1eb0yux"><div data-rid="8f0a96b0-6921-4e4e-b19e-246d313d722b" class="r-g4foat alchemy-rte"><span style="width:100%"><p>What is Oblipair™ and why is it important?</p></span></div><div data-rid="3c7ae2c0-7077-4b0e-a7ed-84d346e94564" class="r-buwikn" aria-hidden="true"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="img" aria-label="Collapse/Expand" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-9gdnyd" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"></path></svg></div></div><div class="replo-animated" hidden="" id="replo-:Rhn32:"><div data-rid="0cfb6673-5c99-4b5c-87e2-7288944c61ec" class="r-83jrgs"><div data-rid="e5f2f51e-ca95-4fd6-92c4-92f6fa54e6e3" class="r-1px2549 alchemy-rte"><span style="width:100%"><p>Imagine a team-up of two superstar molecules: one that steps in like a perfect substitute, activating a receptor just like your body's natural molecule would (its fancy name: an orthosteric ligand), and another that plays the role of the cool sidekick,&nbsp;boosting the receptor’s connection with your natural molecule by binding to a separate site on the receptor&nbsp;(its fancy name: an allosteric modulator).&nbsp;</p><br><p>At Troscriptions® we call this patent-pending combination an obligate pair, or Oblipair™.</p><br><p>Why is this so important? Most supplements and formulas only use the sidekick (i.e. the allosteric modulator) which will deplete the natural molecule that binds to the receptor. An Oblipair™, in contrast, prevents this depletion by also giving the orthosteric ligand, reducing the risk of tolerance, withdrawal, or dependence.&nbsp;</p></span></div></div></div></div></div></div></div></div></div><style>@import url(https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900;950&family=Inter:wght@100;200;300;400;500;600;700;800;900;950)</style></div>
