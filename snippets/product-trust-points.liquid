            {%- render 'product-trust-point-icon', icon: item_4_icon -%}
          </span>
        {%- endif -%}
        <span class="product__trust-points-text">{{ block.settings.item_4_text }}</span>
      </li>
    {%- endif -%}
    {%- if block.settings.item_5_text != blank -%}
      {%- assign item_5_icon = block.settings.item_5_icon -%}
