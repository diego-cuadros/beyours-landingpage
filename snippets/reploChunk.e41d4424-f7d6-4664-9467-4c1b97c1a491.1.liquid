<script>
document.addEventListener("DOMContentLoaded", function () {

  function getOrdinal(day) {
    if (day > 3 && day < 21) return "th";
    switch (day % 10) {
      case 1: return "st";
      case 2: return "nd";
      case 3: return "rd";
      default: return "th";
    }
  }

  function addBusinessDays(startDate, days) {
    const date = new Date(startDate);
    let addedDays = 0;

    while (addedDays < days) {
      date.setDate(date.getDate() + 1);
      const day = date.getDay();
      if (day !== 0 && day !== 6) { // skip Sunday (0) & Saturday (6)
        addedDays++;
      }
    }

    return date;
  }

  const today = new Date();

  const earliest = addBusinessDays(today, 3);
  const latest = addBusinessDays(today, 7);

  const dayEarliest = earliest.getDate();
  const suffixEarliest = getOrdinal(dayEarliest);
  const monthEarliest = earliest.toLocaleString("en-US", { month: "short" });

  const dayLatest = latest.getDate();
  const suffixLatest = getOrdinal(dayLatest);
  const monthLatest = latest.toLocaleString("en-US", { month: "short" });

  document.getElementById("delivery-date").innerHTML =
    `${dayEarliest}${suffixEarliest} ${monthEarliest} – ${dayLatest}${suffixLatest} ${monthLatest}`;
});
</script>
