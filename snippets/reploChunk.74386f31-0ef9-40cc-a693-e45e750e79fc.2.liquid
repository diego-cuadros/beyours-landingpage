<div class="replo-price-mobile">
</div>
<script>
(function() {
    const priceDisplay = document.querySelector('.replo-price-mobile');
    if (!priceDisplay) return;

    const getAndSetPrice = () => {
        // 1. Find all radio groups (Replo often has one for Desktop and one for Mobile)
        const groups = document.querySelectorAll('[role="radiogroup"]');
        
        for (let group of groups) {
            // 2. Check visibility: Only pull price from the group the user can actually see
            const isVisible = group.offsetWidth > 0 && group.offsetHeight > 0;
            
            if (isVisible) {
                const checkedInput = group.querySelector('input[type="radio"]:checked');
                if (checkedInput) {
                    // Replo logic: The button/label is usually the sibling immediately BEFORE the hidden radio input
                    const activeBtn = checkedInput.previousElementSibling;
                    
                    if (activeBtn && activeBtn.getAttribute('role') === 'button') {
                        // 3. Target all possible price attributes found in your HTML
                        const priceTarget = activeBtn.querySelector('[data-regular-price], [data-replo-price], [data-replo-price-mobile]');
                        
                        if (priceTarget) {
                            const newPrice = priceTarget.innerText.trim();
                            // Update only if changed to prevent unnecessary DOM flickering
                            if (priceDisplay.innerText !== newPrice) {
                                priceDisplay.innerText = newPrice;
                            }
                        }
                    }
                }
                // Stop the loop once we've processed the single visible active group
                break; 
            }
        }
    };

    // --- Execution Hooks ---

    // Initial load
    getAndSetPrice();

    // Listen for clicks: Replo interactions are usually click-based
    document.body.addEventListener('click', (event) => {
        const isReploClick = event.target.closest('[role="button"], [role="radiogroup"], input[type="radio"]');
        if (isReploClick) {
            // 100ms delay allows Replo's internal state/classes to update before we read the DOM
            setTimeout(getAndSetPrice, 100);
        }
    });

    // Handle visibility swaps:
    // If Replo swaps containers on scroll or resize, this keeps the price synced.
    window.addEventListener('scroll', getAndSetPrice, { passive: true });
    window.addEventListener('resize', getAndSetPrice);
    
    // Safety Net: A persistent interval to catch state changes that don't trigger events
