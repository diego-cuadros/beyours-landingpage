{%- assign counter = 0 -%}

{%- for i in (1..30) -%}
  {%- assign ts = ts | plus: one_day -%}
  {%- assign weekday = ts | date: "%w" -%}

  {%- if weekday != "0" and weekday != "6" -%}
    {%- assign counter = counter | plus: 1 -%}
  {%- endif -%}

  {%- if counter == 3 -%}
    {%- assign delivery_start_ts = ts -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- assign ts2 = delivery_start_ts -%}
{%- assign counter2 = 3 -%}


{%- for i in (1..30) -%}
  {%- assign ts2 = ts2 | plus: one_day -%}
  {%- assign weekday2 = ts2 | date: "%w" -%}

  {%- if weekday2 != "0" and weekday2 != "5" -%}
    {%- assign counter2 = counter2 | plus: 1 -%}
  {%- endif -%}

  {%- if counter2 == 7 -%}
    {%- assign delivery_end_ts = ts2 -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- assign delivery_start = delivery_start_ts | date: "%-d %b" -%}
{%- assign delivery_end   = delivery_end_ts   | date: "%-d %b" -%}

<div class="shipping-info">
