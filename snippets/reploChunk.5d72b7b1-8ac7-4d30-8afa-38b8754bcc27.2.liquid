            const priceSymbol = originalText.replace(/[0-9.,]/g, '');
            const price = parseFloat(originalText.replace(/[^0-9.]/g, ''));
            const serving = parseFloat(selectedPack.getAttribute('data-serving'));

            if (!isNaN(price) && !isNaN(serving) && serving > 0) {
                const dividedPrice = price / serving;
                printValue.textContent = `${priceSymbol}${dividedPrice.toFixed(2)}`;
            }
        }
    }

