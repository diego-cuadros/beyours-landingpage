<script>
document.addEventListener("DOMContentLoaded", function() {

  console.log("MMMMMMMMM");

function updateSavings() {
  // Get compare-at price and regular price elements
  const compriceElement = document.querySelector('[data-compare-price] span');
  const priceElement = document.querySelector('[data-regular-price] span');

  // Extract and clean text values
  const compriceText = compriceElement ? compriceElement.textContent.trim() : "0";
  const priceText = priceElement ? priceElement.textContent.trim() : "0";

  // Convert text (like "$49.99") into numbers
  const comprice = parseFloat(compriceText.replace(/[^0-9.]/g, ""));
  const price = parseFloat(priceText.replace(/[^0-9.]/g, ""));

  // Calculate savings
  const savings = comprice - price;

  // Output results
  console.log("Compare at price:", comprice);
  console.log("Regular price:", price);
  console.log("You save:", savings.toFixed(2));

  // Update the element text (formerly jQuery('[data-serving-price] p').text(...))
