function addBusinessDays(startDate, days) {
    let date = new Date(startDate);
    let added = 0;

    while (added < days) {
        date.setDate(date.getDate() + 1);

        if (date.getDay() !== 0 && date.getDay() !== 6) {
            added++;
        }
    }
    return date;
}

function formatDate(date) {
    const day = date.getDate();
    const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
                    "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

    const suffix = (d => {
        if (d > 3 && d < 21) return "th";
        switch (d % 10) {
            case 1: return "st";
            case 2: return "nd";
            case 3: return "rd";
            default: return "th";
        }
    })(day);

    return `${day}${suffix} ${months[date.getMonth()]}`;
}

const today = new Date();
const minDelivery = addBusinessDays(today, 3);
const maxDelivery = addBusinessDays(today, 7);

const minDateStr = formatDate(minDelivery);
const maxDateStr = formatDate(maxDelivery);

// ⭐ Correct bold format
const message = `Ships out in 24 hours! Delivery between <strong>${minDateStr} – ${maxDateStr}</strong>`;

// ⭐ Use innerHTML so <strong> renders as bold
