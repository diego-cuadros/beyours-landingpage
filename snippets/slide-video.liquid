{%- comment -%}
  Slide Video
  Parameters:
  - block: the block object
  - section: the section object  
  - position: slide position (1-based)
  - lazy: if true, defer video loading until slide is active (default: true)
{%- endcomment -%}

{%- liquid
  assign video_autoplay = true
  assign video_preload = 'auto'
  if lazy
    assign video_autoplay = false
    assign video_preload = 'none'
  endif
-%}

<div class="slideshow__image-wrapper media-wrapper banner__media">
  <div class="slideshow__image media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}">
    {%- if block.settings.video != blank -%}
      <video-section data-video-hero data-type="mp4" data-loop="1"{% if lazy %} data-lazy-video{% endif %}>
        {{
          block.settings.video
          | video_tag:
            autoplay: video_autoplay,
            loop: true,
            muted: true,
            controls: false,
            preload: video_preload,
            playsinline: true
        }}
      </video-section>
    {%- elsif block.settings.video_url != blank -%}
      <video-section
        data-video-hero
        data-type="{{ block.settings.video_url.type }}"
        data-video-id="{{ block.settings.video_url.id }}"
        data-loop="1"
        {%- if lazy %} data-lazy-video data-init-mode="manual"{% endif -%}
      >
      </video-section>
    {%- else -%}
      <div class="slideshow__image slideshow__image--placeholder media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}">
        {%- assign current = position | modulo: 2 | plus: 1 -%}
        {{ 'lifestyle-' | append: current | placeholder_svg_tag: 'placeholder' }}
      </div>
    {%- endif -%}
  </div>
  {%- if block.settings.button_link != blank -%}
    <a href="{{ block.settings.button_link }}" class="full-unstyled-link" aria-label="{{ 'accessibility.view_slide_video' | t }}">&nbsp;</a>
  {%- endif -%}
</div>
