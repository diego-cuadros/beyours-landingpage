<div class="replo-price">
</div>
<script>
(function() {
    const priceDisplay = document.querySelector('.replo-price');
    if (!priceDisplay) return;

    const getAndSetPrice = () => {
        // 1. Find all radio groups
        const groups = document.querySelectorAll('[role="radiogroup"]');
        
        for (let group of groups) {
            // 2. Only pull price from the VISIBLE group
            const isVisible = group.offsetWidth > 0 && group.offsetHeight > 0;
            
            if (isVisible) {
                const checkedInput = group.querySelector('input[type="radio"]:checked');
                if (checkedInput) {
                    const activeBtn = checkedInput.previousElementSibling;
                    if (activeBtn && activeBtn.getAttribute('role') === 'button') {
                        const priceTarget = activeBtn.querySelector('[data-regular-price], [data-replo-price]');
                        if (priceTarget) {
                            const newPrice = priceTarget.innerText.trim();
                            // Only update DOM if the price actually changed to save resources
                            if (priceDisplay.innerText !== newPrice) {
                                priceDisplay.innerText = newPrice;
                            }
                        }
                    }
                }
                // Once we found the visible one and set the price, stop looking
                break; 
            }
        }
    };

    // Initialize
    getAndSetPrice();

    // Listen for clicks (Very efficient)
    document.body.addEventListener('click', (event) => {
        const isReploClick = event.target.closest('[role="button"], [role="radiogroup"]');
        if (isReploClick) {
            // Small delay to let Replo finish its internal state swap
            setTimeout(getAndSetPrice, 100);
        }
    });

    // Handle the "Container Swap" without crashing:
    // Instead of a heavy Observer, we check when the window is scrolled 
    // or resized, which is usually when Replo's visibility logic triggers.
    window.addEventListener('scroll', getAndSetPrice, { passive: true });
    
    // Safety net: Check every 1 second just in case a swap happened without a click
    const backupInterval = setInterval(getAndSetPrice, 500);

    // Clean up if the script is ever re-run
    window.addEventListener('beforeunload', () => clearInterval(backupInterval));
})();
</script></div></div><div data-rid="0a3899b9-5ae2-45ba-b939-913f1df82ec7" class="r-1a52jxj"><div data-rid="155a055f-90e9-44d4-af65-c6f2c0caaee5" class="r-1wu1v5v alchemy-rte"><span style="width:100%">{%- comment -%}replo-liquid-chunk-begin{%- endcomment -%}
