    if (!button) return null;

    const text = button.innerText.toLowerCase();
    return text.includes('subscribe') ? 'subscribe' : 'one';
  }

  function syncOtherGroups(activeGroup, selectedType) {
    const allGroups = document.querySelectorAll('[role="radiogroup"]');

    allGroups.forEach(group => {
      if (group === activeGroup) return;

      const buttons = group.querySelectorAll('[role="button"]');

      buttons.forEach(btn => {
        const text = btn.innerText.toLowerCase();

        const isMatch =
          (selectedType === 'subscribe' && text.includes('subscribe')) ||
          (selectedType === 'one' && text.includes('one'));

        if (!isMatch) return;

        const radio = btn.nextElementSibling;
        if (!radio || radio.checked) return;

        // 🔑 Click the button (not the radio) to let Replo handle state
        btn.click();
      });
    });
  }

  function sync() {
    const groups = document.querySelectorAll('[role="radiogroup"]');
    let activeGroup = null;

    for (const group of groups) {
      if (isVisible(group)) {
        activeGroup = group;
        break;
      }
    }

    if (!activeGroup) return;

    const selectedType = getSelectedType(activeGroup);
    if (!selectedType) return;

    // Update price
    const price =
      selectedType === 'subscribe'
        ? PRICE_SUBSCRIBE
        : PRICE_ONE_TIME;

    if (display.innerText !== price) {
      display.innerText = price;
    }

    // Sync hidden container
    syncOtherGroups(activeGroup, selectedType);
  }

  // Replo-safe polling
  const interval = setInterval(sync, 120);

  window.addEventListener('beforeunload', () => {
    clearInterval(interval);
  });
})();
