    "rich_text_NgpMzJ": {
      "type": "rich-text-v2",
      "blocks": {
        "text_rirJNc": {
          "type": "text",
          "settings": {
            "text": "<p>GABA is an neurotransmitter that decreases the firing of neurons in the brain, relaxing and chilling out your brain (and you). But there is a <strong>paradox</strong> and a <strong>problem</strong>.</p>",
            "text_size": "typeset2",
            "secondary_color": false,
            "enable_highlight": false,
            "highlight_style": "marker",
            "horizontal_span": 1
          }
        },
        "text_8fpbb9": {
          "type": "text",
          "settings": {
            "text": "<p>The <strong>paradox</strong>? You have to get excited before you can chill out. This is because GABA is made in the brain from glutamate, our primary excitatory neurotransmitter. </p><p>The <strong>problem</strong>? Despite what your<strong> GABA supplements</strong> may tell you, GABA itself can’t get across the blood- brain barrier (BBB) to work its magic.  </p>",
            "text_size": "typeset2",
            "secondary_color": false,
            "enable_highlight": false,
            "highlight_style": "marker",
            "horizontal_span": 1
          }
        }
      },
