    "faq_v2_9CNdnt": {
      "type": "faq-v2",
      "blocks": {
        "question_G9HaPy": {
          "type": "question",
          "settings": {
            "title": "What is Tro Perks?",
            "text": "<p>Tro Perks is our exclusive perks program for active Troscriptions subscribers. As a member, you’ll unlock insider-only discounts on products and services from brands we love, use, and trust — from cutting-edge tech to foundational health tools. These are deals you<em>won’t</em>find publicly.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "question_wwFCbE": {
          "type": "question",
          "settings": {
            "title": "Who is eligible to use Tro Perks?",
            "text": "<p>Any active Troscriptions subscriber (to any product) is automatically eligible. As long as your subscription is active, your access to Tro Perks is too.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "question_6fKDBq": {
          "type": "question",
          "settings": {
            "title": "How do I access my perks?",
            "text": "<p>Once subscribed, you’ll receive a private link to the Tro Perks portal. From there, you can browse current perks, grab discount codes, and discover new tools to support your health optimization journey. We’ll also email you when new perks drop.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "question_zfNqe9": {
          "type": "question",
          "settings": {
            "title": "Who is eligible to use TroPerks?",
            "text": "<p>Once subscribed, you’ll receive a private link to the Tro Perks portal. From there, you can browse current perks, grab discount codes, and discover new tools to support your health optimization journey. We’ll also email you when new perks drop.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "question_YycFpU": {
          "type": "question",
          "settings": {
            "title": "Interested in joining Tro Perks?",
            "text": "<p>Simple: subscribe to any Troscriptions product and you're in. No hoops. No forms. Just perks.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "question_iLpThP": {
          "type": "question",
          "settings": {
            "title": "Have an idea for a new Tro Perks partner?",
            "text": "<p>Yes please. Send suggestions to <strong>buccalup@troscriptions.com</strong>— whether it’s your favorite red light panel, magnesium spray, or tech tool you swear by. If it aligns with smarter health, we’ll check it out.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "question_hBPBjG": {
          "type": "question",
          "settings": {
            "title": "What kinds of companies are part of Tro Perks?",
            "text": "<p>We partner with brands that align with our values: quality, transparency, innovation, and real-world impact. Expect a curated mix of health tech, supplements, wearables, testing platforms, and lifestyle optimization tools — stuff we actually use ourselves.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "question_HQxeXc": {
          "type": "question",
          "settings": {
            "title": "Can I share my Tro Perks codes with friends or patients?",
            "text": "<p>Nope — these are just for you. Sharing codes may void access to future perks, and we’d hate to see you miss out. Let’s keep it in the (Tro)fam.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "question_FqkCdH": {
          "type": "question",
          "settings": {
            "title": "What happens if I cancel my subscription?",
            "text": "<p>If your subscription ends, so does access to Tro Perks — including use of current codes. Reactivate your subscription, and your perks will come right back.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "question_QdeDRx": {
          "type": "question",
          "settings": {
            "title": "How often are new perks added?",
            "text": "<p>Constantly. We’re always testing and vetting new products behind the scenes. When something makes the cut, it goes live on Tro Perks. Stay tuned — and subscribed!</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        }
