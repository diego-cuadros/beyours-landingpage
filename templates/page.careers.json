      "blocks": {
        "column_c4fmpB": {
          "type": "step",
          "settings": {
            "step_number": "1",
            "title": "Intro chat (30 min)",
            "text": "<p>A conversation about you, us, and whether the timing and role make sense.</p>",
            "border_color": "#007078"
          }
        },
        "column_XiJP3E": {
          "type": "step",
          "settings": {
            "step_number": "2",
            "title": "Culture fit interview",
            "text": "<p>Meet several members of the team who will aim to understand whether your values match ours.</p>",
            "border_color": "#9595d2"
          }
        },
        "column_BYegPi": {
          "type": "step",
          "settings": {
            "step_number": "3",
            "title": "Case study",
            "text": "<p>A time-bounded exercise that mirrors the real work (e.g., small technical task, a short ops scenario, or a mini launch plan).</p>",
            "border_color": "#0077c8"
          }
        },
        "column_WRiV9q": {
          "type": "step",
          "settings": {
            "step_number": "4",
            "title": "Final round",
            "text": "<p>A two-hour deep-dive with your potential team lead to discuss team strategy, clarify goals, and ensure alignment.</p>",
