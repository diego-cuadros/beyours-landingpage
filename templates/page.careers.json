    "image_with_text_v2_alt_T9AKx3": {
      "type": "image-with-text-v2-alt",
      "blocks": {
        "item_cNNRYH": {
          "type": "item",
          "settings": {
            "heading": "Small team, big surface area.",
            "heading_tag": "h3",
            "heading_size": "h3",
            "text": "<p>Working at Troscriptions means thinking and acting like an owner, taking initiative and building something you are proud of.</p>",
            "text_size": "typeset",
            "enable_highlight": false,
            "highlight_style": "circle"
          }
        },
        "item_pkG6BX": {
          "type": "item",
          "settings": {
            "heading": "Science + storytelling.",
            "heading_tag": "h3",
            "heading_size": "h3",
            "text": "<p>One day you’re working with physicians on a white paper; the next you’re helping explain “why your tongue is blue” in a way a sleep-deprived customer will actually read.</p>",
            "text_size": "typeset",
            "enable_highlight": false,
            "highlight_style": "circle"
          }
        },
        "item_hQAH3x": {
          "type": "item",
          "settings": {
            "heading": "Customer-obsessed.",
            "heading_tag": "h3",
            "heading_size": "h3",
            "text": "<p>Our customers write us about how Tro Zzz™ gave them their first full night of sleep in years or how Just Blue™ changed their workdays. We design products <em>and</em> experiences to be worthy of that trust.</p>",
            "text_size": "typeset",
            "enable_highlight": false,
            "highlight_style": "circle"
          }
        }
      },
