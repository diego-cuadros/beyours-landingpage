        "text_qMF3Le": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Blue Cannatine </strong>was created by <strong>Dr. Ted Achacoso</strong> to solve a real problem: staying sharp, focused, and resilient while traveling internationally and pushing performance without burnout.</p><p><br/>It worked.<br/>Not just for him—but for the people he cared for.</p><p><br/>Patients felt the difference.</p><p> Practitioners paid attention. </p><p>Clinics asked what was next.<br/></p><p>What followed wasn’t a single product—it was momentum. A growing line of precision-dosed tools built around real physiological demands, not passing trends.</p>",
            "text_size": "typeset",
            "secondary_color": false,
            "show_hanging_quotes": false,
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        }
